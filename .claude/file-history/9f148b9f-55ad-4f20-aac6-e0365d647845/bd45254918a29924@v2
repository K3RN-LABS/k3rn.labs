import { NextRequest, NextResponse } from 'next/server';
import { getDb } from '@/lib/db';

export const dynamic = 'force-dynamic';

export async function GET(
  request: NextRequest,
  { params }: { params: Promise<{ id: string }> }
) {
  const { id } = await params;
  const db = getDb();

  try {
    const skill = db.prepare(`
      SELECT * FROM skills WHERE id = ?
    `).get(id);

    if (!skill) {
      return NextResponse.json({ error: 'Skill not found' }, { status: 404 });
    }

    const card = db.prepare(`
      SELECT * FROM skill_cards WHERE skill_id = ?
    `).get(id);

    const result = {
      ...(skill as any),
      tags: JSON.parse((skill as any).tags_json || '[]'),
      triggers: JSON.parse((skill as any).triggers_json || '[]'),
      card: card || null,
    };

    // Parse card JSON fields
    if (result.card) {
      result.card.use_when = JSON.parse(result.card.use_when_json || '[]');
      result.card.avoid_when = JSON.parse(result.card.avoid_when_json || '[]');
      result.card.similar = JSON.parse(result.card.similar_json || '[]');
    }

    return NextResponse.json(result);
  } catch (error) {
    console.error('Skill fetch error:', error);
    return NextResponse.json({ error: 'Failed to fetch skill' }, { status: 500 });
  }
}

export async function PUT(
  request: NextRequest,
  { params }: { params: Promise<{ id: string }> }
) {
  const { id } = await params;
  const body = await request.json();
  const db = getDb();

  try {
    // Check if skill exists
    const skill = db.prepare('SELECT id FROM skills WHERE id = ?').get(id);
    if (!skill) {
      return NextResponse.json({ error: 'Skill not found' }, { status: 404 });
    }

    // Upsert skill card
    db.prepare(`
      INSERT INTO skill_cards (
        skill_id, use_when_json, avoid_when_json, inputs, outputs,
        activation, similar_json, diff_notes, risk_level
      )
      VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
      ON CONFLICT(skill_id) DO UPDATE SET
        use_when_json = excluded.use_when_json,
        avoid_when_json = excluded.avoid_when_json,
        inputs = excluded.inputs,
        outputs = excluded.outputs,
        activation = excluded.activation,
        similar_json = excluded.similar_json,
        diff_notes = excluded.diff_notes,
        risk_level = excluded.risk_level
    `).run(
      id,
      JSON.stringify(body.use_when || []),
      JSON.stringify(body.avoid_when || []),
      body.inputs || null,
      body.outputs || null,
      body.activation || null,
      JSON.stringify(body.similar || []),
      body.diff_notes || null,
      body.risk_level || null
    );

    return NextResponse.json({ success: true });
  } catch (error) {
    console.error('Skill card update error:', error);
    return NextResponse.json({ error: 'Failed to update skill card' }, { status: 500 });
  }
}
