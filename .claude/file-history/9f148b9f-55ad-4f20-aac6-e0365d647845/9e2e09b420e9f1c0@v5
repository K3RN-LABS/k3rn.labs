'use client';

import { useState, useEffect } from 'react';
import SearchBar from '@/components/SearchBar';
import Filters from '@/components/Filters';
import ResultsList from '@/components/ResultsList';
import StackPanel from '@/components/StackPanel';
import { useAppStore } from '@/store/appStore';

export default function Home() {
  const [query, setQuery] = useState('');
  const [category, setCategory] = useState('');
  const [tags, setTags] = useState('');
  const [hasCard, setHasCard] = useState(false);
  const [results, setResults] = useState<any[]>([]);
  const [loading, setLoading] = useState(false);
  const [metadata, setMetadata] = useState<any>(null);

  // Use global store for skill stack (persists across navigation)
  const { skillStack, addToStack, removeFromStack, reorderStack } = useAppStore();

  // Fetch metadata on mount
  useEffect(() => {
    fetch('/api/metadata')
      .then((res) => res.json())
      .then((data) => setMetadata(data))
      .catch((err) => console.error('Failed to fetch metadata:', err));
  }, []);

  // Search whenever filters change
  useEffect(() => {
    const search = async () => {
      setLoading(true);
      try {
        const params = new URLSearchParams();
        if (query) params.set('q', query);
        if (category) params.set('category', category);
        if (tags) params.set('tags', tags);
        if (hasCard) params.set('hasCard', 'true');

        const res = await fetch(`/api/search?${params.toString()}`);
        const data = await res.json();
        setResults(data.results || []);
      } catch (error) {
        console.error('Search failed:', error);
        setResults([]);
      } finally {
        setLoading(false);
      }
    };

    search();
  }, [query, category, tags, hasCard]);

  return (
    <div className="page-container">
      <div className="page-header">
        <div className="container">
          <h1 className="h1">
            Recherche de Skills
          </h1>
          <p className="text-muted" style={{ marginTop: 'var(--sp-2)' }}>
            Recherchez parmi 622+ skills et construisez votre stack
          </p>
        </div>
      </div>

      <div className="container" style={{ paddingTop: 'var(--sp-6)', paddingBottom: 'var(--sp-8)' }}>
        <SearchBar query={query} setQuery={setQuery} />

        <div className="page-layout">
          <div className="page-main">
            <Filters
              metadata={metadata}
              category={category}
              setCategory={setCategory}
              tags={tags}
              setTags={setTags}
              hasCard={hasCard}
              setHasCard={setHasCard}
            />

            <div style={{ marginTop: 'var(--sp-6)' }}>
              {loading ? (
                <div className="loading-state">
                  <div className="spinner"></div>
                  <p className="text-muted" style={{ marginTop: 'var(--sp-2)' }}>Searching...</p>
                </div>
              ) : (
                <ResultsList
                  results={results}
                  query={query}
                  addToStack={addToStack}
                  stack={skillStack}
                />
              )}
            </div>
          </div>

          <StackPanel
            stack={skillStack}
            results={results}
            removeFromStack={removeFromStack}
            reorderStack={reorderStack}
          />
        </div>
      </div>
    </div>
  );
}
