    },
    "framework": null,
    "language": "JavaScript",
    "runtime": "Node.js",
    "package_manager": "yarn",
    "notes": "**Stack technique:** JavaScript + (node)\n**Package manager:** yarn\n\n*Score de confiance: 40% • Sources: package.json*"
  },
