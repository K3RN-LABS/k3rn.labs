import { NextRequest, NextResponse } from 'next/server';
import { getDb, SearchResult } from '@/lib/db';

export const dynamic = 'force-dynamic';

export async function GET(request: NextRequest) {
  const searchParams = request.nextUrl.searchParams;
  const query = searchParams.get('q') || '';
  const category = searchParams.get('category') || '';
  const tags = searchParams.get('tags') || '';
  const hasCard = searchParams.get('hasCard') === 'true';
  const limit = parseInt(searchParams.get('limit') || '50', 10);

  const db = getDb();

  try {
    let sql: string;
    let params: any[];
    let results: any[] = [];

    if (query) {
      // Strategy: Try FTS first, fallback to LIKE if no results
      // This handles both normal queries and short tokens (UI, UX, etc.)

      // Step 1: Try FTS search with BM25 ranking
      const ftsSql = `
        SELECT
          s.id,
          s.name,
          s.category,
          s.description,
          s.tags_json,
          s.triggers_json,
          fts.rank as score,
          'name,description,triggers,tags' as matched_fields
        FROM skills_fts fts
        JOIN skills s ON s.name = fts.name
        ${hasCard ? 'JOIN skill_cards sc ON sc.skill_id = s.id' : ''}
        WHERE fts MATCH ?
        ${category ? 'AND s.category = ?' : ''}
        ${tags ? 'AND s.tags_json LIKE ?' : ''}
        ORDER BY fts.rank
        LIMIT ?
      `;

      const ftsParams: any[] = [query];
      if (category) ftsParams.push(category);
      if (tags) ftsParams.push(`%${tags}%`);
      ftsParams.push(limit);

      try {
        results = db.prepare(ftsSql).all(...ftsParams) as any[];
      } catch (ftsError) {
        console.warn('FTS search failed, using LIKE fallback:', ftsError);
        results = [];
      }

      // Step 2: If FTS returned no results, fallback to LIKE
      if (results.length === 0) {
        const likePattern = `%${query}%`;
        const likeSql = `
          SELECT
            s.id,
            s.name,
            s.category,
            s.description,
            s.tags_json,
            s.triggers_json,
            0 as score,
            'name,tags,description' as matched_fields
          FROM skills s
          ${hasCard ? 'JOIN skill_cards sc ON sc.skill_id = s.id' : ''}
          WHERE (s.name LIKE ? COLLATE NOCASE
                 OR s.tags_json LIKE ? COLLATE NOCASE
                 OR s.description LIKE ? COLLATE NOCASE)
          ${category ? 'AND s.category = ?' : ''}
          ${tags ? 'AND s.tags_json LIKE ?' : ''}
          ORDER BY
            CASE
              WHEN s.name LIKE ? COLLATE NOCASE THEN 1
              WHEN s.tags_json LIKE ? COLLATE NOCASE THEN 2
              ELSE 3
            END,
            s.name
          LIMIT ?
        `;

        const likeParams: any[] = [likePattern, likePattern, likePattern];
        if (category) likeParams.push(category);
        if (tags) likeParams.push(`%${tags}%`);
        likeParams.push(likePattern, likePattern); // For ORDER BY CASE
        likeParams.push(limit);

        results = db.prepare(likeSql).all(...likeParams) as any[];
      }
    } else {
      // No query: return all with optional filters
      const allSql = `
        SELECT
          s.id,
          s.name,
          s.category,
          s.description,
          s.tags_json,
          s.triggers_json,
          0 as score,
          '' as matched_fields
        FROM skills s
        ${hasCard ? 'JOIN skill_cards sc ON sc.skill_id = s.id' : ''}
        WHERE 1=1
        ${category ? 'AND s.category = ?' : ''}
        ${tags ? 'AND s.tags_json LIKE ?' : ''}
        ORDER BY s.name
        LIMIT ?
      `;

      const allParams: any[] = [];
      if (category) allParams.push(category);
      if (tags) allParams.push(`%${tags}%`);
      allParams.push(limit);

      results = db.prepare(allSql).all(...allParams) as any[];
    }

    const formattedResults = results.map((row, index) => ({
      id: row.id,
      name: row.name,
      category: row.category,
      description: row.description,
      tags: JSON.parse(row.tags_json || '[]'),
      triggers: JSON.parse(row.triggers_json || '[]'),
      score: row.score || 0,
      rank: index + 1,
      matched_fields: row.matched_fields || '',
    }));

    return NextResponse.json({ results: formattedResults });
  } catch (error) {
    console.error('Search error:', error);
    return NextResponse.json({ error: 'Search failed', results: [] }, { status: 500 });
  }
}
