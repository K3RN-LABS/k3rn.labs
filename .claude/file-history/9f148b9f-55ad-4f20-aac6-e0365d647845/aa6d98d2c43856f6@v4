'use client';

import Link from 'next/link';

interface ResultsListProps {
  results: any[];
  query: string;
  addToStack: (skillId: number) => void;
  stack: number[];
}

export default function ResultsList({
  results,
  query,
  addToStack,
  stack,
}: ResultsListProps) {
  if (results.length === 0) {
    return (
      <div className="card" style={{ textAlign: 'center', padding: 'var(--sp-8)' }}>
        <p className="text-muted">
          {query ? 'No skills found. Try a different search.' : 'Enter a search query to find skills.'}
        </p>
      </div>
    );
  }

  return (
    <div style={{ display: 'flex', flexDirection: 'column', gap: 'var(--sp-3)' }}>
      <div className="text-small text-muted">
        Found {results.length} skill{results.length !== 1 ? 's' : ''}
      </div>

      {results.map((skill) => (
        <div key={skill.id} className="card card-clickable">
          <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start' }}>
            <div style={{ flex: 1 }}>
              <div style={{ display: 'flex', alignItems: 'center', gap: 'var(--sp-3)' }}>
                <Link
                  href={`/skills/${skill.id}`}
                  className="skill-link"
                >
                  {skill.name}
                </Link>
                <span className="pill">
                  {skill.category}
                </span>
                {skill.source_type === 'external' && (
                  <span className="pill" style={{ background: 'var(--primary-100)', color: 'var(--primary-700)' }}>
                    {skill.source_name || 'External'}
                  </span>
                )}
                {skill.score !== 0 && (
                  <span className="pill pill-success">
                    Score: {Math.abs(skill.score).toFixed(2)}
                  </span>
                )}
              </div>

              <p className="text-small" style={{ marginTop: 'var(--sp-2)', color: 'var(--text-2)' }}>
                {skill.description}
              </p>

              {skill.repo_url && (
                <p className="text-small" style={{ marginTop: 'var(--sp-2)' }}>
                  <a href={skill.repo_url} target="_blank" rel="noopener noreferrer" style={{ color: 'var(--primary-600)' }}>
                    View on GitHub →
                  </a>
                  {skill.license && <span className="text-muted"> • {skill.license}</span>}
                </p>
              )}

              <div style={{ marginTop: 'var(--sp-2)', display: 'flex', flexWrap: 'wrap', gap: 'var(--sp-1)' }}>
                {skill.tags.slice(0, 5).map((tag: string) => (
                  <span
                    key={tag}
                    className="pill"
                  >
                    {tag}
                  </span>
                ))}
                {skill.tags.length > 5 && (
                  <span className="text-small text-muted">
                    +{skill.tags.length - 5} more
                  </span>
                )}
              </div>

              {skill.matched_fields && (
                <div className="text-small text-muted" style={{ marginTop: 'var(--sp-2)' }}>
                  Matched: {skill.matched_fields}
                </div>
              )}
            </div>

            <button
              className={stack.includes(skill.id) ? 'btn secondary' : 'btn dark'}
              style={{ marginLeft: 'var(--sp-4)' }}
              onClick={() => addToStack(skill.id)}
              disabled={stack.includes(skill.id)}
            >
              {stack.includes(skill.id) ? 'In Stack' : 'Add to Stack'}
            </button>
          </div>
        </div>
      ))}
    </div>
  );
}
