import fs from 'fs';

export interface ParsedSkill {
  name: string;
  category: string;
  description: string;
  tags: string[];
  triggers: string[];
}

export function parseCatalog(filePath: string): ParsedSkill[] {
  const content = fs.readFileSync(filePath, 'utf-8');
  const skills: ParsedSkill[] = [];

  const lines = content.split('\n');
  let currentCategory = '';
  let inTable = false;

  for (let i = 0; i < lines.length; i++) {
    const line = lines[i].trim();

    // Detect category headers (e.g., "## architecture (62)")
    const categoryMatch = line.match(/^##\s+([a-zA-Z0-9_/-]+)\s+\((\d+)\)/);
    if (categoryMatch) {
      currentCategory = categoryMatch[1];
      inTable = false;
      continue;
    }

    // Detect table header
    if (line.startsWith('| Skill | Description | Tags | Triggers |')) {
      inTable = true;
      i++; // Skip the separator line
      continue;
    }

    // Parse table rows
    if (inTable && line.startsWith('|') && !line.startsWith('| ---')) {
      const parts = line.split('|').map(s => s.trim()).filter(s => s);

      if (parts.length >= 4) {
        const nameMatch = parts[0].match(/`([^`]+)`/);
        const name = nameMatch ? nameMatch[1] : parts[0];
        const description = parts[1];
        const tagsStr = parts[2];
        const triggersStr = parts[3];

        // Parse tags and triggers (comma-separated)
        const tags = tagsStr
          .split(',')
          .map(t => t.trim())
          .filter(t => t && t !== '');

        const triggers = triggersStr
          .split(',')
          .map(t => t.trim())
          .filter(t => t && t !== '');

        if (name && currentCategory) {
          skills.push({
            name,
            category: currentCategory,
            description,
            tags,
            triggers,
          });
        }
      }
    }

    // Empty line might end the table
    if (inTable && line === '') {
      inTable = false;
    }
  }

  return skills;
}
