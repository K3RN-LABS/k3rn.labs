import { NextRequest, NextResponse } from 'next/server';
import { fetchRepoMetadata } from '@/lib/project-context/repo-fetcher';
import { analyzeProject } from '@/lib/project-context/summarizer';
import type { AnalysisInput, AnalysisResult } from '@/lib/project-context/types';

export const dynamic = 'force-dynamic';

// Simple in-memory cache (24h TTL)
const cache = new Map<string, { result: AnalysisResult; timestamp: number }>();
const CACHE_TTL_MS = 24 * 60 * 60 * 1000; // 24 hours

/**
 * POST /api/project-context/analyze
 * Analyze GitHub repository and return project context
 */
export async function POST(request: NextRequest) {
  try {
    const body: AnalysisInput = await request.json();
    const { github_url, branch, github_token } = body;

    if (!github_url) {
      return NextResponse.json(
        { success: false, error: 'github_url is required' },
        { status: 400 }
      );
    }

    // Check cache
    const cacheKey = `${github_url}:${branch || 'default'}`;
    const cached = cache.get(cacheKey);

    if (cached && Date.now() - cached.timestamp < CACHE_TTL_MS) {
      return NextResponse.json({
        ...cached.result,
        cached: true,
      });
    }

    // Fetch repo metadata
    let metadata;
    try {
      metadata = await fetchRepoMetadata(github_url, branch, github_token);
    } catch (error: any) {
      return NextResponse.json(
        {
          success: false,
          error: error.message || 'Failed to fetch repository metadata',
        },
        { status: 400 }
      );
    }

    // Analyze project
    const context = analyzeProject(metadata);

    // Build result
    const result: AnalysisResult = {
      success: true,
      context,
      analyzed_at: new Date().toISOString(),
      cached: false,
    };

    // Cache result
    cache.set(cacheKey, { result, timestamp: Date.now() });

    // Clean old cache entries (simple cleanup)
    if (cache.size > 100) {
      const now = Date.now();
      for (const [key, value] of cache.entries()) {
        if (now - value.timestamp > CACHE_TTL_MS) {
          cache.delete(key);
        }
      }
    }

    return NextResponse.json(result);
  } catch (error: any) {
    console.error('Project context analysis error:', error);
    return NextResponse.json(
      {
        success: false,
        error: error.message || 'Analysis failed',
      },
      { status: 500 }
    );
  }
}
