#!/usr/bin/env tsx

import Database from 'better-sqlite3';
import fs from 'fs';
import path from 'path';
import { initSchema } from '../src/lib/db';
import { parseCatalog } from '../src/lib/parser';

const DATA_DIR = path.join(process.cwd(), 'data');
const DB_PATH = path.join(DATA_DIR, 'skills.db');
const CATALOG_SOURCE = path.join(process.cwd(), '.agent', 'skills', 'CATALOG.md');
const CATALOG_DEST = path.join(DATA_DIR, 'CATALOG.md');

async function main() {
  console.log('🚀 Initializing database...');

  // Ensure data directory exists
  if (!fs.existsSync(DATA_DIR)) {
    fs.mkdirSync(DATA_DIR, { recursive: true });
  }

  // Copy CATALOG.md if needed
  if (fs.existsSync(CATALOG_SOURCE)) {
    console.log('📋 Copying CATALOG.md to data directory...');
    fs.copyFileSync(CATALOG_SOURCE, CATALOG_DEST);
  } else {
    console.error('❌ CATALOG.md not found at:', CATALOG_SOURCE);
    process.exit(1);
  }

  // Remove existing database
  if (fs.existsSync(DB_PATH)) {
    console.log('🗑️  Removing existing database...');
    fs.unlinkSync(DB_PATH);
  }

  // Create database and schema
  console.log('📊 Creating database schema...');
  const db = new Database(DB_PATH);
  initSchema(db);

  // Parse catalog
  console.log('📖 Parsing CATALOG.md...');
  const skills = parseCatalog(CATALOG_DEST);
  console.log(`✅ Parsed ${skills.length} skills`);

  // Insert skills
  console.log('💾 Inserting skills into database...');
  const insertSkill = db.prepare(`
    INSERT INTO skills (name, category, description, tags_json, triggers_json)
    VALUES (?, ?, ?, ?, ?)
  `);

  const insertMany = db.transaction((skillsToInsert) => {
    for (const skill of skillsToInsert) {
      insertSkill.run(
        skill.name,
        skill.category,
        skill.description,
        JSON.stringify(skill.tags),
        JSON.stringify(skill.triggers)
      );
    }
  });

  insertMany(skills);

  // Verify
  const count = db.prepare('SELECT COUNT(*) as count FROM skills').get() as { count: number };
  console.log(`✅ Inserted ${count.count} skills`);

  // Populate FTS index manually
  console.log('🔍 Building FTS index...');
  db.prepare(`
    INSERT INTO skills_fts(name, description, triggers, tags)
    SELECT name, description, triggers_json, tags_json FROM skills
  `).run();

  // Verify FTS
  const ftsCount = db.prepare('SELECT COUNT(*) as count FROM skills_fts').get() as { count: number };
  console.log(`✅ FTS index contains ${ftsCount.count} entries`);

  db.close();
  console.log('🎉 Database initialization complete!');
}

main().catch((error) => {
  console.error('❌ Error:', error);
  process.exit(1);
});
