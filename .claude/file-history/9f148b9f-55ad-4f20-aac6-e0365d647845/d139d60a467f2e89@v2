'use client';

import { useState } from 'react';

interface StackPanelProps {
  stack: number[];
  results: any[];
  removeFromStack: (skillId: number) => void;
  reorderStack: (fromIndex: number, toIndex: number) => void;
}

export default function StackPanel({
  stack,
  results,
  removeFromStack,
  reorderStack,
}: StackPanelProps) {
  const [exporting, setExporting] = useState(false);
  const [exportFormat, setExportFormat] = useState<'markdown' | 'json'>('markdown');

  const handleExport = async () => {
    if (stack.length === 0) {
      alert('Add skills to your stack first!');
      return;
    }

    setExporting(true);
    try {
      const res = await fetch('/api/export', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ skillIds: stack, format: exportFormat }),
      });

      const data = await res.json();

      // Download file
      const blob = new Blob([data.content], { type: 'text/plain' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = exportFormat === 'json' ? 'stack.json' : 'skill_stack.md';
      a.click();
      URL.revokeObjectURL(url);
    } catch (error) {
      console.error('Export failed:', error);
      alert('Export failed. Please try again.');
    } finally {
      setExporting(false);
    }
  };

  const getSkillName = (skillId: number) => {
    const skill = results.find((r) => r.id === skillId);
    return skill ? skill.name : `Skill ${skillId}`;
  };

  return (
    <div className="w-80 sticky top-6 self-start">
      <div className="card">
        <h3 className="font-semibold text-gray-900 mb-4">
          Stack Builder ({stack.length})
        </h3>

        {stack.length === 0 ? (
          <p className="text-sm text-gray-600 text-center py-8">
            Add skills to build your stack
          </p>
        ) : (
          <>
            <div className="space-y-2 mb-4 max-h-96 overflow-y-auto">
              {stack.map((skillId, index) => (
                <div
                  key={skillId}
                  className="flex items-center justify-between p-2 bg-gray-50 rounded"
                >
                  <div className="flex items-center gap-2 flex-1">
                    <div className="flex flex-col gap-1">
                      <button
                        className="text-xs text-gray-500 hover:text-gray-700"
                        onClick={() => index > 0 && reorderStack(index, index - 1)}
                        disabled={index === 0}
                      >
                        ▲
                      </button>
                      <button
                        className="text-xs text-gray-500 hover:text-gray-700"
                        onClick={() =>
                          index < stack.length - 1 && reorderStack(index, index + 1)
                        }
                        disabled={index === stack.length - 1}
                      >
                        ▼
                      </button>
                    </div>
                    <span className="text-sm text-gray-700">
                      {getSkillName(skillId)}
                    </span>
                  </div>
                  <button
                    className="text-red-600 hover:text-red-800 text-sm"
                    onClick={() => removeFromStack(skillId)}
                  >
                    ✕
                  </button>
                </div>
              ))}
            </div>

            <div className="space-y-3">
              <div>
                <label className="block text-sm font-medium text-gray-700 mb-2">
                  Export Format
                </label>
                <div className="flex gap-2">
                  <button
                    className={`flex-1 px-3 py-2 text-sm rounded ${
                      exportFormat === 'markdown'
                        ? 'bg-blue-600 text-white'
                        : 'bg-gray-100 text-gray-700'
                    }`}
                    onClick={() => setExportFormat('markdown')}
                  >
                    Markdown
                  </button>
                  <button
                    className={`flex-1 px-3 py-2 text-sm rounded ${
                      exportFormat === 'json'
                        ? 'bg-blue-600 text-white'
                        : 'bg-gray-100 text-gray-700'
                    }`}
                    onClick={() => setExportFormat('json')}
                  >
                    JSON
                  </button>
                </div>
              </div>

              <button
                className="btn-primary w-full"
                onClick={handleExport}
                disabled={exporting}
              >
                {exporting ? 'Exporting...' : 'Export Stack'}
              </button>
            </div>
          </>
        )}
      </div>
    </div>
  );
}
