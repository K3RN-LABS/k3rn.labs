/**
 * Repository Fetcher
 * Orchestrates GitHub API calls to fetch repository metadata
 */

import { GitHubClient } from './github-client';
import type { GitHubRepoInfo, GitHubTreeItem, PackageJson } from './types';

export interface RepoMetadata {
  info: GitHubRepoInfo;
  tree: GitHubTreeItem[];
  packageJson: PackageJson | null;
}

const MAX_TREE_SIZE_MB = 5;
const FETCH_TIMEOUT_MS = 10000; // 10s

/**
 * Fetch repository metadata with timeout and size constraints
 */
export async function fetchRepoMetadata(
  githubUrl: string,
  branch?: string,
  token?: string
): Promise<RepoMetadata> {
  const parsed = GitHubClient.parseGitHubUrl(githubUrl);
  if (!parsed) {
    throw new Error('Invalid GitHub URL format');
  }

  const client = new GitHubClient(token);

  // Set up timeout
  const timeoutPromise = new Promise<never>((_, reject) => {
    setTimeout(() => reject(new Error('Repository fetch timeout (10s)')), FETCH_TIMEOUT_MS);
  });

  try {
    // Fetch repo info
    const info = await Promise.race([
      client.getRepoInfo(parsed.owner, parsed.repo),
      timeoutPromise,
    ]);

    // Use provided branch or default branch
    const targetBranch = branch || info.default_branch;

    // Check size constraint (GitHub size is in KB)
    if (info.size > MAX_TREE_SIZE_MB * 1024) {
      throw new Error(
        `Repository too large (${(info.size / 1024).toFixed(1)}MB). Maximum size: ${MAX_TREE_SIZE_MB}MB`
      );
    }

    // Fetch tree and package.json in parallel
    const [tree, packageJson] = await Promise.race([
      Promise.all([
        client.getTree(parsed.owner, parsed.repo, targetBranch, true),
        client.getPackageJson(parsed.owner, parsed.repo, targetBranch),
      ]),
      timeoutPromise,
    ]);

    return {
      info: { ...info, branch: targetBranch },
      tree,
      packageJson,
    };
  } catch (error: any) {
    if (error.message?.includes('timeout')) {
      throw error;
    }
    throw new Error(`Failed to fetch repository: ${error.message}`);
  }
}
