import { NextRequest, NextResponse } from 'next/server';
import { getDb } from '@/lib/db';

export const dynamic = 'force-dynamic';

/**
 * GET /api/sources
 * List all skill sources with indexed skill counts
 */
export async function GET() {
  try {
    const db = getDb();

    const sources = db.prepare(`
      SELECT
        s.*,
        (SELECT COUNT(*) FROM external_skill_refs WHERE source_id = s.id) as skill_count
      FROM skill_sources s
      ORDER BY s.id
    `).all() as any[];

    return NextResponse.json({ sources });
  } catch (error) {
    console.error('Failed to fetch sources:', error);
    return NextResponse.json({ error: 'Failed to fetch sources', sources: [] }, { status: 500 });
  }
}

/**
 * POST /api/sources
 * Create a new skill source
 */
export async function POST(request: NextRequest) {
  try {
    const body = await request.json();
    const { name, type, config, terms_url } = body;

    if (!name || !type) {
      return NextResponse.json({ error: 'name and type are required' }, { status: 400 });
    }

    if (!['local', 'github'].includes(type)) {
      return NextResponse.json({ error: 'type must be local or github' }, { status: 400 });
    }

    const db = getDb();

    // Validate config for GitHub sources
    if (type === 'github') {
      if (!config?.repo_url) {
        return NextResponse.json({ error: 'repo_url required in config for github sources' }, { status: 400 });
      }
    }

    const result = db.prepare(`
      INSERT INTO skill_sources (name, type, config_json, terms_url, enabled)
      VALUES (?, ?, ?, ?, 1)
    `).run(name, type, JSON.stringify(config || {}), terms_url || null);

    const source = db.prepare('SELECT * FROM skill_sources WHERE id = ?').get(result.lastInsertRowid) as any;

    return NextResponse.json({ source }, { status: 201 });
  } catch (error: any) {
    console.error('Failed to create source:', error);
    return NextResponse.json({ error: error.message || 'Failed to create source' }, { status: 500 });
  }
}

/**
 * PATCH /api/sources
 * Update a skill source (enable/disable)
 */
export async function PATCH(request: NextRequest) {
  try {
    const body = await request.json();
    const { sourceId, enabled } = body;

    if (!sourceId) {
      return NextResponse.json({ error: 'sourceId required' }, { status: 400 });
    }

    const db = getDb();

    db.prepare('UPDATE skill_sources SET enabled = ? WHERE id = ?').run(enabled ? 1 : 0, sourceId);

    return NextResponse.json({ success: true });
  } catch (error) {
    console.error('Failed to update source:', error);
    return NextResponse.json({ error: 'Failed to update source' }, { status: 500 });
  }
}
