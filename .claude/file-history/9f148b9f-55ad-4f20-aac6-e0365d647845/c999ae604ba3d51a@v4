'use client';

import { useState, useEffect } from 'react';

interface SkillSource {
  id: number;
  name: string;
  type: string;
  config_json: string;
  terms_url: string | null;
  enabled: number;
  last_sync_at: string | null;
  created_at: string;
  skill_count?: number;
}

interface SyncResult {
  indexed: number;
  updated: number;
  removed: number;
  errors: Array<{ step: string; message: string; path?: string }>;
  scannedPaths?: string[];
  detectedFiles?: string[];
}

export default function SourcesPage() {
  const [sources, setSources] = useState<SkillSource[]>([]);
  const [loading, setLoading] = useState(true);
  const [syncing, setSyncing] = useState<Record<number, boolean>>({});
  const [validating, setValidating] = useState<Record<number, boolean>>({});
  const [syncResults, setSyncResults] = useState<Record<number, SyncResult | null>>({});
  const [showAddForm, setShowAddForm] = useState(false);
  const [newSource, setNewSource] = useState({
    name: '',
    repo_url: '',
    branch: 'main',
    github_token: '',
  });
  const [addError, setAddError] = useState('');

  useEffect(() => {
    fetchSources();
  }, []);

  const fetchSources = async () => {
    try {
      const res = await fetch('/api/sources');
      const data = await res.json();
      setSources(data.sources || []);
    } catch (error) {
      console.error('Failed to fetch sources:', error);
    } finally {
      setLoading(false);
    }
  };

  const handleSync = async (sourceId: number) => {
    setSyncing({ ...syncing, [sourceId]: true });
    setSyncResults({ ...syncResults, [sourceId]: null });

    try {
      const res = await fetch('/api/sources/sync', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ sourceId }),
      });

      const data = await res.json();

      if (res.ok && data.success !== false) {
        const result: SyncResult = {
          indexed: data.indexed || 0,
          updated: data.updated || 0,
          removed: data.removed || 0,
          errors: data.errors || [],
          scannedPaths: data.scannedPaths || [],
          detectedFiles: data.detectedFiles || [],
        };
        setSyncResults({ ...syncResults, [sourceId]: result });
        fetchSources();
      } else {
        const result: SyncResult = {
          indexed: 0,
          updated: 0,
          removed: 0,
          errors: data.errors || [
            {
              step: data.step || 'unknown',
              message: data.error || 'Sync failed',
            },
          ],
          scannedPaths: data.scannedPaths || [],
          detectedFiles: data.detectedFiles || [],
        };
        setSyncResults({ ...syncResults, [sourceId]: result });
      }
    } catch (error: any) {
      setSyncResults({
        ...syncResults,
        [sourceId]: {
          indexed: 0,
          updated: 0,
          removed: 0,
          errors: [{ step: 'network', message: error.message }],
        },
      });
    } finally {
      setSyncing({ ...syncing, [sourceId]: false });
    }
  };

  const handleValidate = async (sourceId: number) => {
    setValidating({ ...validating, [sourceId]: true });

    try {
      const res = await fetch(`/api/sources/${sourceId}/validate`);
      const data = await res.json();

      if (res.ok && data.success) {
        alert(
          `Validation Results:\n\n` +
            `Scanned: ${data.scan.scannedPaths} paths\n` +
            `Detected: ${data.scan.detectedSkills} SKILL.md files\n` +
            `Patterns: ${data.scan.patterns.slice(0, 3).join(', ')}${data.scan.patterns.length > 3 ? '...' : ''}\n\n` +
            `${data.detected.length > 0 ? `Skills:\n${data.detected.slice(0, 5).map((d: any) => `  - ${d.slug} (${d.path})`).join('\n')}${data.detected.length > 5 ? `\n  ... and ${data.detected.length - 5} more` : ''}` : 'No skills detected.'}\n\n` +
            `${data.issues.duplicateSlugs.length > 0 ? `⚠️ Duplicate slugs: ${data.issues.duplicateSlugs.join(', ')}` : ''}`
        );
      } else {
        alert(`Validation failed: ${data.error}`);
      }
    } catch (error: any) {
      alert(`Validation error: ${error.message}`);
    } finally {
      setValidating({ ...validating, [sourceId]: false });
    }
  };

  const handleToggleEnabled = async (sourceId: number, enabled: boolean) => {
    try {
      await fetch('/api/sources', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ sourceId, enabled: enabled ? 1 : 0 }),
      });

      fetchSources();
    } catch (error) {
      console.error('Failed to toggle source:', error);
    }
  };

  const handleAddSource = async (e: React.FormEvent) => {
    e.preventDefault();
    setAddError('');

    if (!newSource.name || !newSource.repo_url) {
      setAddError('Name and repo URL are required');
      return;
    }

    try {
      const res = await fetch('/api/sources', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: newSource.name,
          type: 'github',
          config: {
            repo_url: newSource.repo_url,
            branch: newSource.branch || 'main',
            github_token: newSource.github_token || undefined,
          },
        }),
      });

      const data = await res.json();

      if (res.ok) {
        setShowAddForm(false);
        setNewSource({ name: '', repo_url: '', branch: 'main', github_token: '' });
        fetchSources();
      } else {
        setAddError(data.error || 'Failed to add source');
      }
    } catch (error: any) {
      setAddError(error.message);
    }
  };

  return (
    <div style={{ minHeight: '100vh', background: 'var(--bg-primary)' }}>
      <main style={{ maxWidth: '1200px', margin: '0 auto', padding: 'var(--sp-8)' }}>
        <div style={{ marginBottom: 'var(--sp-6)' }}>
          <h1 className="h1">Skill Sources</h1>
          <p className="text-muted" style={{ marginTop: 'var(--sp-2)' }}>
            Manage external skill repositories and indexes
          </p>
        </div>

        {!showAddForm && (
          <div style={{ marginBottom: 'var(--sp-6)' }}>
            <button className="btn primary" onClick={() => setShowAddForm(true)}>
              + Add GitHub Source
            </button>
          </div>
        )}

        {showAddForm && (
          <div className="card" style={{ marginBottom: 'var(--sp-6)' }}>
            <h2 className="h2" style={{ marginBottom: 'var(--sp-4)' }}>
              Add GitHub Source
            </h2>

            <form onSubmit={handleAddSource} style={{ display: 'flex', flexDirection: 'column', gap: 'var(--sp-4)' }}>
              <div>
                <label className="input-label">Source Name *</label>
                <input
                  type="text"
                  className="input"
                  placeholder="e.g., Anthropic Skills, Community Skills"
                  value={newSource.name}
                  onChange={(e) => setNewSource({ ...newSource, name: e.target.value })}
                  required
                />
              </div>

              <div>
                <label className="input-label">GitHub Repo URL *</label>
                <input
                  type="url"
                  className="input"
                  placeholder="https://github.com/owner/repo"
                  value={newSource.repo_url}
                  onChange={(e) => setNewSource({ ...newSource, repo_url: e.target.value })}
                  required
                />
              </div>

              <div>
                <label className="input-label">Branch (optional)</label>
                <input
                  type="text"
                  className="input"
                  placeholder="main"
                  value={newSource.branch}
                  onChange={(e) => setNewSource({ ...newSource, branch: e.target.value })}
                />
              </div>

              <div>
                <label className="input-label">GitHub Token (optional)</label>
                <input
                  type="password"
                  className="input"
                  placeholder="ghp_xxxx (for private repos or higher rate limits)"
                  value={newSource.github_token}
                  onChange={(e) => setNewSource({ ...newSource, github_token: e.target.value })}
                />
                <p className="text-small text-muted" style={{ marginTop: 'var(--sp-1)' }}>
                  Optional: improves rate limits (5000 req/hour) or allows private repo access
                </p>
              </div>

              {addError && (
                <div style={{ padding: 'var(--sp-3)', background: 'var(--error-50)', borderRadius: 'var(--radius-md)' }}>
                  <p className="text-small" style={{ color: 'var(--error-700)' }}>
                    {addError}
                  </p>
                </div>
              )}

              <div style={{ display: 'flex', gap: 'var(--sp-2)' }}>
                <button type="submit" className="btn primary">
                  Add Source
                </button>
                <button
                  type="button"
                  className="btn secondary"
                  onClick={() => {
                    setShowAddForm(false);
                    setAddError('');
                  }}
                >
                  Cancel
                </button>
              </div>
            </form>
          </div>
        )}

        {loading ? (
          <div className="card">
            <p className="text-muted">Loading sources...</p>
          </div>
        ) : sources.length === 0 ? (
          <div className="card">
            <p className="text-muted">No sources configured yet.</p>
          </div>
        ) : (
          <div style={{ display: 'flex', flexDirection: 'column', gap: 'var(--sp-4)' }}>
            {sources.map((source) => {
              const config = JSON.parse(source.config_json || '{}');

              return (
                <div key={source.id} className="card">
                  <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start', marginBottom: 'var(--sp-3)' }}>
                    <div>
                      <div style={{ display: 'flex', alignItems: 'center', gap: 'var(--sp-2)' }}>
                        <h3 className="h3">{source.name}</h3>
                        <span className="kicker">{source.type}</span>
                        {!source.enabled && (
                          <span className="kicker" style={{ background: 'var(--gray-200)', color: 'var(--gray-600)' }}>
                            disabled
                          </span>
                        )}
                      </div>

                      {config.repo_url && (
                        <p className="text-small text-muted" style={{ marginTop: 'var(--sp-1)' }}>
                          <a href={config.repo_url} target="_blank" rel="noopener noreferrer" style={{ color: 'var(--primary-600)' }}>
                            {config.repo_url}
                          </a>
                          {config.branch && ` (branch: ${config.branch})`}
                        </p>
                      )}
                    </div>

                    <div style={{ display: 'flex', gap: 'var(--sp-2)' }}>
                      <label style={{ display: 'flex', alignItems: 'center', gap: 'var(--sp-1)', cursor: 'pointer' }}>
                        <input
                          type="checkbox"
                          checked={source.enabled === 1}
                          onChange={(e) => handleToggleEnabled(source.id, e.target.checked)}
                        />
                        <span className="text-small">Enabled</span>
                      </label>

                      {source.type === 'github' && (
                        <button
                          className="btn secondary"
                          onClick={() => handleValidate(source.id)}
                          disabled={validating[source.id]}
                          title="Preview what skills would be detected"
                        >
                          {validating[source.id] ? 'Validating...' : 'Validate'}
                        </button>
                      )}

                      <button
                        className="btn secondary"
                        onClick={() => handleSync(source.id)}
                        disabled={!source.enabled || syncing[source.id]}
                      >
                        {syncing[source.id] ? 'Syncing...' : 'Sync Now'}
                      </button>
                    </div>
                  </div>

                  <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(150px, 1fr))', gap: 'var(--sp-3)', paddingTop: 'var(--sp-3)', borderTop: '1px solid var(--divider)' }}>
                    <div>
                      <p className="text-small text-muted">Indexed Skills</p>
                      <p className="h3" style={{ marginTop: 'var(--sp-1)' }}>
                        {source.skill_count || 0}
                      </p>
                    </div>

                    <div>
                      <p className="text-small text-muted">Last Sync</p>
                      <p className="text-small" style={{ marginTop: 'var(--sp-1)' }}>
                        {source.last_sync_at
                          ? new Date(source.last_sync_at).toLocaleString()
                          : 'Never'}
                      </p>
                    </div>

                    <div>
                      <p className="text-small text-muted">Created</p>
                      <p className="text-small" style={{ marginTop: 'var(--sp-1)' }}>
                        {new Date(source.created_at).toLocaleDateString()}
                      </p>
                    </div>
                  </div>

                  {/* Sync Result Panel */}
                  {syncResults[source.id] && (
                    <div style={{ marginTop: 'var(--sp-4)', paddingTop: 'var(--sp-4)', borderTop: '1px solid var(--divider)' }}>
                      <h4 className="h4" style={{ marginBottom: 'var(--sp-3)' }}>
                        Last Sync Result
                      </h4>

                      <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(120px, 1fr))', gap: 'var(--sp-2)', marginBottom: 'var(--sp-3)' }}>
                        <div>
                          <p className="text-small text-muted">Indexed</p>
                          <p className="text-small" style={{ fontWeight: 600, color: 'var(--success-600)' }}>
                            +{syncResults[source.id]!.indexed}
                          </p>
                        </div>
                        <div>
                          <p className="text-small text-muted">Updated</p>
                          <p className="text-small" style={{ fontWeight: 600, color: 'var(--primary-600)' }}>
                            ~{syncResults[source.id]!.updated}
                          </p>
                        </div>
                        <div>
                          <p className="text-small text-muted">Removed</p>
                          <p className="text-small" style={{ fontWeight: 600, color: 'var(--error-600)' }}>
                            -{syncResults[source.id]!.removed}
                          </p>
                        </div>
                        <div>
                          <p className="text-small text-muted">Scanned</p>
                          <p className="text-small" style={{ fontWeight: 600 }}>
                            {syncResults[source.id]!.scannedPaths?.length || 0} paths
                          </p>
                        </div>
                        <div>
                          <p className="text-small text-muted">Detected</p>
                          <p className="text-small" style={{ fontWeight: 600 }}>
                            {syncResults[source.id]!.detectedFiles?.length || 0} files
                          </p>
                        </div>
                      </div>

                      {syncResults[source.id]!.errors.length > 0 && (
                        <div style={{ padding: 'var(--sp-3)', background: 'var(--error-50)', borderRadius: 'var(--radius-md)', border: '1px solid var(--error-200)' }}>
                          <p className="text-small" style={{ fontWeight: 600, color: 'var(--error-700)', marginBottom: 'var(--sp-2)' }}>
                            Errors ({syncResults[source.id]!.errors.length})
                          </p>
                          {syncResults[source.id]!.errors.slice(0, 5).map((err, idx) => (
                            <div key={idx} style={{ marginBottom: idx < Math.min(4, syncResults[source.id]!.errors.length - 1) ? 'var(--sp-2)' : 0 }}>
                              <p className="text-small" style={{ color: 'var(--error-700)' }}>
                                <strong>{err.step}:</strong> {err.message}
                                {err.path && <span className="text-muted"> ({err.path})</span>}
                              </p>
                            </div>
                          ))}
                          {syncResults[source.id]!.errors.length > 5 && (
                            <p className="text-small text-muted" style={{ marginTop: 'var(--sp-2)' }}>
                              ... and {syncResults[source.id]!.errors.length - 5} more errors
                            </p>
                          )}
                        </div>
                      )}

                      {syncResults[source.id]!.errors.length === 0 &&
                        syncResults[source.id]!.indexed === 0 &&
                        syncResults[source.id]!.updated === 0 && (
                          <div style={{ padding: 'var(--sp-3)', background: 'var(--warning-50)', borderRadius: 'var(--radius-md)', border: '1px solid var(--warning-200)' }}>
                            <p className="text-small" style={{ color: 'var(--warning-700)' }}>
                              No skills detected. Scanned {syncResults[source.id]!.scannedPaths?.length || 0} paths.
                              Try clicking "Validate" to see why no SKILL.md files were found.
                            </p>
                          </div>
                        )}
                    </div>
                  )}
                </div>
              );
            })}
          </div>
        )}
      </main>
    </div>
  );
}
