/**
 * GitHub repository skill indexing (metadata-only, no content scraping)
 */

import Database from 'better-sqlite3';
import { parseSkillFrontmatter } from './skill-parser';
import type { SyncResult, SyncError, GitHubConfig } from './types';
import { detectSkillFiles, COMMON_PATTERNS } from './skill-scanner';

interface GitHubTreeItem {
  path: string;
  mode: string;
  type: 'blob' | 'tree';
  sha: string;
  size?: number;
  url: string;
}

/**
 * Sync GitHub repository: index SKILL.md files as external skill refs
 */
export async function syncGitHubSource(
  db: Database.Database,
  sourceId: number,
  config: GitHubConfig
): Promise<SyncResult> {
  const result: SyncResult = {
    indexed: 0,
    updated: 0,
    removed: 0,
    errors: [],
    scannedPaths: [],
    detectedFiles: [],
  };

  console.log(`[Sync] Starting GitHub sync for source ${sourceId}`);

  try {
    // Parse repo URL to extract owner/repo
    const { owner, repo } = parseGitHubUrl(config.repo_url);
    const branch = config.branch || 'main';
    const patterns = config.patterns || COMMON_PATTERNS;

    console.log(`[Sync] Fetching tree for ${owner}/${repo}@${branch}`);

    // Fetch repository tree via GitHub API
    let tree: GitHubTreeItem[];
    try {
      tree = await fetchGitHubTree(owner, repo, branch, config.github_token);
      result.scannedPaths = tree.map((item) => item.path);
      console.log(`[Sync] Scanned ${tree.length} paths in repository`);
    } catch (error: any) {
      const syncError: SyncError = {
        step: 'fetch_tree',
        message: error.message,
        httpStatus: extractHttpStatus(error.message),
      };
      result.errors.push(syncError);
      console.error(`[Sync] Failed to fetch tree:`, error);
      return result;
    }

    // Auto-detect SKILL.md files using scanner (case-insensitive, multiple patterns)
    const allPaths = tree.filter((item) => item.type === 'blob').map((item) => item.path);
    const detected = detectSkillFiles(allPaths, patterns, { caseSensitive: false });

    result.detectedFiles = detected.map((d) => d.path);
    console.log(
      `[Sync] Detected ${detected.length} SKILL.md files matching patterns:`,
      patterns
    );

    // Build lookup map for tree items by path
    const treeMap = new Map<string, GitHubTreeItem>();
    tree.forEach((item) => treeMap.set(item.path, item));

    // Track seen slugs for pruning
    const seenSlugs = new Set<string>();

    // Process each detected skill
    for (const detectedSkill of detected) {
      const file = treeMap.get(detectedSkill.path);
      if (!file) continue;

      try {
        const slug = detectedSkill.slug;
        seenSlugs.add(slug);

        // Fetch file content (raw)
        const content = await fetchFileContent(owner, repo, file.path, branch, config.github_token);

        // Parse frontmatter + extract metadata
        const metadata = parseSkillFrontmatter(content);

        // Build repo_url for this specific skill
        const skillRepoUrl = `https://github.com/${owner}/${repo}/blob/${branch}/${file.path}`;

        // Check if skill already exists
        const existing = db
          .prepare('SELECT id FROM external_skill_refs WHERE source_id = ? AND slug = ?')
          .get(sourceId, slug) as any;

        if (existing) {
          // Update existing
          db.prepare(`
            UPDATE external_skill_refs
            SET name = ?, description = ?, tags_json = ?, triggers_json = ?,
                license = ?, repo_url = ?, version = ?, sha = ?, last_seen_at = datetime('now')
            WHERE id = ?
          `).run(
            metadata.name,
            metadata.description,
            JSON.stringify(metadata.tags),
            JSON.stringify(metadata.triggers),
            metadata.license,
            skillRepoUrl,
            metadata.version,
            file.sha,
            existing.id
          );
          result.updated++;
        } else {
          // Insert new
          db.prepare(`
            INSERT INTO external_skill_refs
            (source_id, slug, name, description, tags_json, triggers_json, license, repo_url, version, sha)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
          `).run(
            sourceId,
            slug,
            metadata.name,
            metadata.description,
            JSON.stringify(metadata.tags),
            JSON.stringify(metadata.triggers),
            metadata.license,
            skillRepoUrl,
            metadata.version,
            file.sha
          );
          result.indexed++;

          // Index in FTS
          db.prepare(`
            INSERT INTO external_skills_fts (name, description, triggers, tags)
            VALUES (?, ?, ?, ?)
          `).run(
            metadata.name,
            metadata.description,
            JSON.stringify(metadata.triggers),
            JSON.stringify(metadata.tags)
          );
        }
      } catch (error: any) {
        const syncError: SyncError = {
          step: 'parse_file',
          message: error.message,
          path: file.path,
        };
        result.errors.push(syncError);
        console.error(`[Sync] Failed to process ${file.path}:`, error);
      }
    }

    // Prune skills that are no longer in the repo
    const allExisting = db
      .prepare('SELECT id, slug FROM external_skill_refs WHERE source_id = ?')
      .all(sourceId) as Array<{ id: number; slug: string }>;

    for (const existing of allExisting) {
      if (!seenSlugs.has(existing.slug)) {
        db.prepare('DELETE FROM external_skill_refs WHERE id = ?').run(existing.id);
        result.removed++;
      }
    }

    return result;
  } catch (error: any) {
    console.error('GitHub sync failed:', error);
    throw new Error(`GitHub sync failed: ${error.message}`);
  }
}

/**
 * Parse GitHub URL to extract owner/repo
 */
function parseGitHubUrl(url: string): { owner: string; repo: string } {
  const match = url.match(/github\.com\/([^\/]+)\/([^\/\.]+)/);
  if (!match) {
    throw new Error('Invalid GitHub URL format');
  }
  return { owner: match[1], repo: match[2] };
}

/**
 * Fetch repository tree via GitHub API (recursive)
 */
async function fetchGitHubTree(
  owner: string,
  repo: string,
  branch: string,
  token?: string
): Promise<GitHubTreeItem[]> {
  const headers: Record<string, string> = {
    Accept: 'application/vnd.github.v3+json',
  };

  if (token) {
    headers.Authorization = `token ${token}`;
  }

  // Get branch ref to find tree SHA
  const refUrl = `https://api.github.com/repos/${owner}/${repo}/git/ref/heads/${branch}`;
  const refRes = await fetch(refUrl, { headers });

  if (!refRes.ok) {
    throw new Error(`Failed to fetch branch ref: ${refRes.status} ${refRes.statusText}`);
  }

  const refData = await refRes.json();
  const commitSha = refData.object.sha;

  // Get commit to find tree SHA
  const commitUrl = `https://api.github.com/repos/${owner}/${repo}/git/commits/${commitSha}`;
  const commitRes = await fetch(commitUrl, { headers });

  if (!commitRes.ok) {
    throw new Error(`Failed to fetch commit: ${commitRes.status} ${commitRes.statusText}`);
  }

  const commitData = await commitRes.json();
  const treeSha = commitData.tree.sha;

  // Get tree recursively
  const treeUrl = `https://api.github.com/repos/${owner}/${repo}/git/trees/${treeSha}?recursive=1`;
  const treeRes = await fetch(treeUrl, { headers });

  if (!treeRes.ok) {
    throw new Error(`Failed to fetch tree: ${treeRes.status} ${treeRes.statusText}`);
  }

  const treeData = await treeRes.json();
  return treeData.tree as GitHubTreeItem[];
}

/**
 * Fetch file content from GitHub
 */
async function fetchFileContent(
  owner: string,
  repo: string,
  path: string,
  branch: string,
  token?: string
): Promise<string> {
  const headers: Record<string, string> = {
    Accept: 'application/vnd.github.v3.raw',
  };

  if (token) {
    headers.Authorization = `token ${token}`;
  }

  const url = `https://api.github.com/repos/${owner}/${repo}/contents/${path}?ref=${branch}`;
  const res = await fetch(url, { headers });

  if (!res.ok) {
    throw new Error(`Failed to fetch file: ${res.status} ${res.statusText}`);
  }

  return await res.text();
}

/**
 * Check if path matches any of the patterns (case-insensitive for .md extension)
 */
function matchesPattern(path: string, patterns: string[]): boolean {
  return patterns.some((pattern) => {
    // Simple glob matching: **/* = any depth, * = single segment
    const regexPattern = pattern
      .replace(/\*\*/g, '.*')
      .replace(/\*/g, '[^/]*')
      .replace(/\//g, '\\/');

    const regex = new RegExp(`^${regexPattern}$`, 'i'); // Case-insensitive flag
    return regex.test(path);
  });
}

/**
 * Extract slug from file path (e.g., "skills/react/SKILL.md" -> "react")
 * Case-insensitive for SKILL.md matching
 */
function extractSlugFromPath(path: string): string {
  // Remove SKILL.md and get the parent directory name (case-insensitive)
  const parts = path.split('/');
  const lastPart = parts[parts.length - 1];

  // If pattern is skills/*/SKILL.md, slug is the folder name (case-insensitive match)
  if (parts.length >= 2 && lastPart.toLowerCase() === 'skill.md') {
    return parts[parts.length - 2];
  }

  // Fallback: use the full path without .md as slug
  return path.replace(/\.md$/i, '').replace(/\//g, '-');
}

/**
 * Extract HTTP status code from error message
 */
function extractHttpStatus(message: string): number | undefined {
  const statusMatch = message.match(/(\d{3})/);
  return statusMatch ? parseInt(statusMatch[1], 10) : undefined;
}
