'use client';

import { useState, useEffect } from 'react';

interface SkillCardEditorProps {
  card: any;
  editing: boolean;
  onSave: (cardData: any) => void;
}

export default function SkillCardEditor({
  card,
  editing,
  onSave,
}: SkillCardEditorProps) {
  const [formData, setFormData] = useState({
    use_when: [] as string[],
    avoid_when: [] as string[],
    inputs: '',
    outputs: '',
    activation: '',
    similar: [] as string[],
    diff_notes: '',
    risk_level: 'low',
  });

  useEffect(() => {
    if (card) {
      setFormData({
        use_when: card.use_when || [],
        avoid_when: card.avoid_when || [],
        inputs: card.inputs || '',
        outputs: card.outputs || '',
        activation: card.activation || '',
        similar: card.similar || [],
        diff_notes: card.diff_notes || '',
        risk_level: card.risk_level || 'low',
      });
    }
  }, [card]);

  const handleAddItem = (field: 'use_when' | 'avoid_when' | 'similar') => {
    const value = prompt(`Add new item to ${field.replace('_', ' ')}:`);
    if (value) {
      setFormData({
        ...formData,
        [field]: [...formData[field], value],
      });
    }
  };

  const handleRemoveItem = (
    field: 'use_when' | 'avoid_when' | 'similar',
    index: number
  ) => {
    setFormData({
      ...formData,
      [field]: formData[field].filter((_, i) => i !== index),
    });
  };

  const handleSave = () => {
    onSave(formData);
  };

  if (!editing && !card) {
    return (
      <div className="text-center py-8 text-gray-600">
        <p>No skill card data. Click "Edit Card" to add details.</p>
      </div>
    );
  }

  return (
    <div className="space-y-6">
      {/* Use When */}
      <div>
        <div className="flex justify-between items-center mb-2">
          <h3 className="text-sm font-semibold text-gray-700">Use When</h3>
          {editing && (
            <button
              className="text-sm text-blue-600 hover:text-blue-800"
              onClick={() => handleAddItem('use_when')}
            >
              + Add
            </button>
          )}
        </div>
        {formData.use_when.length === 0 ? (
          <p className="text-sm text-gray-500 italic">No items</p>
        ) : (
          <ul className="list-disc list-inside space-y-1">
            {formData.use_when.map((item, index) => (
              <li key={index} className="text-sm text-gray-900">
                {item}
                {editing && (
                  <button
                    className="ml-2 text-red-600 hover:text-red-800"
                    onClick={() => handleRemoveItem('use_when', index)}
                  >
                    ✕
                  </button>
                )}
              </li>
            ))}
          </ul>
        )}
      </div>

      {/* Avoid When */}
      <div>
        <div className="flex justify-between items-center mb-2">
          <h3 className="text-sm font-semibold text-gray-700">Avoid When</h3>
          {editing && (
            <button
              className="text-sm text-blue-600 hover:text-blue-800"
              onClick={() => handleAddItem('avoid_when')}
            >
              + Add
            </button>
          )}
        </div>
        {formData.avoid_when.length === 0 ? (
          <p className="text-sm text-gray-500 italic">No items</p>
        ) : (
          <ul className="list-disc list-inside space-y-1">
            {formData.avoid_when.map((item, index) => (
              <li key={index} className="text-sm text-gray-900">
                {item}
                {editing && (
                  <button
                    className="ml-2 text-red-600 hover:text-red-800"
                    onClick={() => handleRemoveItem('avoid_when', index)}
                  >
                    ✕
                  </button>
                )}
              </li>
            ))}
          </ul>
        )}
      </div>

      {/* Inputs */}
      <div>
        <h3 className="text-sm font-semibold text-gray-700 mb-2">Inputs</h3>
        {editing ? (
          <textarea
            className="input w-full"
            rows={3}
            value={formData.inputs}
            onChange={(e) =>
              setFormData({ ...formData, inputs: e.target.value })
            }
          />
        ) : (
          <p className="text-sm text-gray-900">
            {formData.inputs || <span className="text-gray-500 italic">No data</span>}
          </p>
        )}
      </div>

      {/* Outputs */}
      <div>
        <h3 className="text-sm font-semibold text-gray-700 mb-2">Outputs</h3>
        {editing ? (
          <textarea
            className="input w-full"
            rows={3}
            value={formData.outputs}
            onChange={(e) =>
              setFormData({ ...formData, outputs: e.target.value })
            }
          />
        ) : (
          <p className="text-sm text-gray-900">
            {formData.outputs || <span className="text-gray-500 italic">No data</span>}
          </p>
        )}
      </div>

      {/* Activation */}
      <div>
        <h3 className="text-sm font-semibold text-gray-700 mb-2">Activation</h3>
        {editing ? (
          <textarea
            className="input w-full"
            rows={2}
            value={formData.activation}
            onChange={(e) =>
              setFormData({ ...formData, activation: e.target.value })
            }
          />
        ) : (
          <p className="text-sm text-gray-900">
            {formData.activation || (
              <span className="text-gray-500 italic">No data</span>
            )}
          </p>
        )}
      </div>

      {/* Risk Level */}
      <div>
        <h3 className="text-sm font-semibold text-gray-700 mb-2">Risk Level</h3>
        {editing ? (
          <select
            className="input"
            value={formData.risk_level}
            onChange={(e) =>
              setFormData({ ...formData, risk_level: e.target.value })
            }
          >
            <option value="low">Low</option>
            <option value="medium">Medium</option>
            <option value="high">High</option>
          </select>
        ) : (
          <span
            className={`px-2 py-1 text-sm rounded ${
              formData.risk_level === 'high'
                ? 'bg-red-100 text-red-700'
                : formData.risk_level === 'medium'
                ? 'bg-yellow-100 text-yellow-700'
                : 'bg-green-100 text-green-700'
            }`}
          >
            {formData.risk_level}
          </span>
        )}
      </div>

      {/* Diff Notes */}
      <div>
        <h3 className="text-sm font-semibold text-gray-700 mb-2">
          Differentiation Notes
        </h3>
        {editing ? (
          <textarea
            className="input w-full"
            rows={3}
            placeholder="How to choose this skill vs alternatives..."
            value={formData.diff_notes}
            onChange={(e) =>
              setFormData({ ...formData, diff_notes: e.target.value })
            }
          />
        ) : (
          <p className="text-sm text-gray-900">
            {formData.diff_notes || (
              <span className="text-gray-500 italic">No data</span>
            )}
          </p>
        )}
      </div>

      {editing && (
        <div className="flex justify-end">
          <button className="btn-primary" onClick={handleSave}>
            Save Changes
          </button>
        </div>
      )}
    </div>
  );
}
