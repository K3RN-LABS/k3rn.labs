'use client';

import { useState } from 'react';
import type { Ticket, RoadmapPhase } from '@/lib/ticketpack/types';

interface TicketListProps {
  tickets: Ticket[];
  phases: RoadmapPhase[];
}

export default function TicketList({ tickets, phases }: TicketListProps) {
  const [selectedPhase, setSelectedPhase] = useState<string>('all');
  const [expandedTicket, setExpandedTicket] = useState<string | null>(null);

  const filteredTickets =
    selectedPhase === 'all'
      ? tickets
      : tickets.filter((t) => t.phase_id === selectedPhase);

  const getTypeColor = (type: string) => {
    switch (type) {
      case 'epic':
        return 'bg-purple-100 text-purple-800';
      case 'story':
        return 'bg-blue-100 text-blue-800';
      case 'task':
        return 'bg-green-100 text-green-800';
      default:
        return 'bg-gray-100 text-gray-800';
    }
  };

  return (
    <div className="card">
      <div className="flex justify-between items-center mb-4">
        <h3 className="text-xl font-semibold text-gray-900">
          Tickets ({filteredTickets.length})
        </h3>

        <select
          className="input"
          value={selectedPhase}
          onChange={(e) => setSelectedPhase(e.target.value)}
        >
          <option value="all">Toutes les phases</option>
          {phases.map((phase) => (
            <option key={phase.phase_id} value={phase.phase_id}>
              {phase.phase_id}: {phase.name}
            </option>
          ))}
        </select>
      </div>

      <div className="space-y-3">
        {filteredTickets.map((ticket) => (
          <div
            key={ticket.ticket_id}
            className="border border-gray-200 rounded-lg overflow-hidden"
          >
            <div
              className="p-4 bg-gray-50 cursor-pointer hover:bg-gray-100"
              onClick={() =>
                setExpandedTicket(
                  expandedTicket === ticket.ticket_id ? null : ticket.ticket_id
                )
              }
            >
              <div className="flex items-start justify-between">
                <div className="flex-1">
                  <div className="flex items-center gap-2 mb-1">
                    <span className="text-sm font-mono text-gray-600">
                      {ticket.ticket_id}
                    </span>
                    <span className={`px-2 py-0.5 text-xs font-semibold rounded ${getTypeColor(ticket.type)}`}>
                      {ticket.type}
                    </span>
                    <span className="px-2 py-0.5 text-xs bg-gray-200 text-gray-700 rounded">
                      {ticket.phase_id}
                    </span>
                  </div>
                  <h4 className="font-semibold text-gray-900">{ticket.title}</h4>
                </div>
                <span className="text-gray-400">
                  {expandedTicket === ticket.ticket_id ? '▼' : '▶'}
                </span>
              </div>
            </div>

            {expandedTicket === ticket.ticket_id && (
              <div className="p-4 border-t border-gray-200 bg-white space-y-3">
                <div>
                  <p className="text-sm font-medium text-gray-700 mb-1">
                    Description:
                  </p>
                  <p className="text-sm text-gray-600">{ticket.description}</p>
                </div>

                {ticket.dependencies.length > 0 && (
                  <div>
                    <p className="text-sm font-medium text-gray-700 mb-1">
                      Dépendances:
                    </p>
                    <div className="flex flex-wrap gap-1">
                      {ticket.dependencies.map((dep) => (
                        <span
                          key={dep}
                          className="px-2 py-1 text-xs bg-yellow-100 text-yellow-800 rounded"
                        >
                          {dep}
                        </span>
                      ))}
                    </div>
                  </div>
                )}

                <div>
                  <p className="text-sm font-medium text-gray-700 mb-1">
                    Critères d'acceptation:
                  </p>
                  <ul className="space-y-1">
                    {ticket.acceptance_criteria.map((criterion, i) => (
                      <li key={i} className="text-sm text-gray-600 flex items-start">
                        <span className="text-green-500 mr-2">✓</span>
                        {criterion}
                      </li>
                    ))}
                  </ul>
                </div>

                {ticket.risks.length > 0 && (
                  <div>
                    <p className="text-sm font-medium text-gray-700 mb-1">Risques:</p>
                    {ticket.risks.map((risk, i) => (
                      <div key={i} className="text-sm bg-red-50 p-2 rounded mb-1">
                        <p className="text-red-800">
                          <strong>⚠ {risk.risk}</strong>
                        </p>
                        <p className="text-red-700">→ {risk.mitigation}</p>
                      </div>
                    ))}
                  </div>
                )}

                <div className="pt-2 border-t border-gray-100">
                  <p className="text-xs text-gray-500">
                    Prompt Claude Code:{' '}
                    <code className="bg-gray-100 px-1 rounded">
                      {ticket.claude_code_prompt_ref}
                    </code>
                  </p>
                </div>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  );
}
