/**
 * Recommendation de skills via FTS5
 */

import { getDb } from '../db';
import type { RecommendedSkill } from './types';

export interface SkillRecommendation {
  id: number;
  name: string;
  category: string;
  description: string;
  score: number;
  rationale: string;
}

/**
 * Recommande top-K skills basé sur le brief + deliverable type
 * Enhanced with optional project context for better recommendations
 */
export async function recommendSkills(
  brief: string,
  deliverableType: string,
  topK: number = 10,
  projectContext?: {
    framework?: string;
    language: string;
    runtime: 'node' | 'edge' | 'browser';
    packageManager?: string;
    testing?: string;
    architecture?: string;
    confidenceScore: number;
    detectionSources: string[];
  }
): Promise<SkillRecommendation[]> {
  const db = getDb();

  // Construire query FTS5 à partir du brief + contexte projet
  let query = extractKeywords(brief, deliverableType);

  // Enhance query with detected context (if confidence >= 60%)
  if (projectContext && projectContext.confidenceScore >= 60) {
    const contextTerms: string[] = [];
    if (projectContext.framework) contextTerms.push(projectContext.framework);
    if (projectContext.language) contextTerms.push(projectContext.language);
    if (projectContext.testing) contextTerms.push(projectContext.testing);
    if (contextTerms.length > 0) {
      query = `${query} ${contextTerms.join(' ')}`;
    }
  }

  try {
    const results = db
      .prepare(
        `
        SELECT
          s.id,
          s.name,
          s.category,
          s.description,
          fts.rank as score
        FROM skills_fts fts
        JOIN skills s ON s.name = fts.name
        WHERE fts MATCH ?
        ORDER BY fts.rank
        LIMIT ?
      `
      )
      .all(query, topK) as Array<{
      id: number;
      name: string;
      category: string;
      description: string;
      score: number;
    }>;

    return results.map((r) => ({
      ...r,
      score: normalizeScore(r.score),
      rationale: generateRationale(r.name, r.category, deliverableType),
    }));
  } catch (error) {
    console.error('Skills recommendation error:', error);
    return [];
  }
}

/**
 * Extrait keywords du brief + boost selon deliverable type
 */
function extractKeywords(brief: string, deliverableType: string): string {
  const words = brief
    .toLowerCase()
    .replace(/[^\w\sàâäçéèêëïîôùûü]/g, ' ')
    .split(/\s+/)
    .filter((w) => w.length > 3);

  // Keywords boost selon deliverable
  const boostKeywords: Record<string, string[]> = {
    saas: ['nextjs', 'react', 'api', 'database', 'auth', 'backend'],
    app: ['react', 'mobile', 'ui', 'frontend'],
    landing_page: ['react', 'tailwind', 'ui', 'frontend', 'design'],
    feature: ['react', 'typescript', 'frontend'],
    bugfix: ['debug', 'testing', 'error'],
  };

  const boost = boostKeywords[deliverableType] || [];
  const allKeywords = [...new Set([...words.slice(0, 10), ...boost])];

  return allKeywords.join(' OR ');
}

/**
 * Normalise BM25 score (négatif) vers 0-1
 */
function normalizeScore(bm25Score: number): number {
  // BM25 est négatif, plus proche de 0 = meilleur
  const normalized = 1 / (1 + Math.abs(bm25Score));
  return Math.round(normalized * 100) / 100;
}

/**
 * Génère une justification de recommendation
 */
function generateRationale(skillName: string, category: string, deliverableType: string): string {
  const rationales: Record<string, string> = {
    saas: `Essentiel pour développer une application SaaS moderne`,
    app: `Recommandé pour le développement d'applications`,
    landing_page: `Utile pour créer des pages d'atterrissage performantes`,
    feature: `Pertinent pour implémenter de nouvelles fonctionnalités`,
    bugfix: `Aide à identifier et corriger les bugs`,
  };

  const base = rationales[deliverableType] || 'Recommandé pour ce type de projet';
  return `${base}. Catégorie: ${category}.`;
}
