'use client';

import { useState } from 'react';
import InputForm from '@/components/ticketpack/InputForm';
import PackView from '@/components/ticketpack/PackView';
import type { TicketPack } from '@/lib/ticketpack/types';
import { useAppStore } from '@/store/appStore';

export default function TicketPackPage() {
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState<string | null>(null);

  // Use global store for generated pack (persists across navigation)
  const { generatedPack, setGeneratedPack } = useAppStore();

  const handleGenerate = async (input: {
    brief: string;
    sources: Array<{ type: 'text' | 'url'; content: string }>;
    deliverable_type: string;
    project_name: string;
  }) => {
    setLoading(true);
    setError(null);

    try {
      const res = await fetch('/api/ticketpack/generate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(input),
      });

      if (!res.ok) {
        const data = await res.json();
        throw new Error(data.error || 'Erreur de génération');
      }

      const generatedPack = await res.json();
      setGeneratedPack(generatedPack);
    } catch (err) {
      console.error('Generation error:', err);
      setError(err instanceof Error ? err.message : 'Erreur inconnue');
    } finally {
      setLoading(false);
    }
  };

  const handleReset = () => {
    setGeneratedPack(null);
    setError(null);
  };

  return (
    <div className="page-container">
      <div className="page-header">
        <div className="container">
          <h1 className="h1">
            TicketPack Generator
          </h1>
          <p className="text-muted" style={{ marginTop: 'var(--sp-2)' }}>
            Transformez votre idée en un pack livrable complet
          </p>
        </div>
      </div>

      <div className="container" style={{ paddingTop: 'var(--sp-6)', paddingBottom: 'var(--sp-8)' }}>
        {!generatedPack ? (
          <InputForm onGenerate={handleGenerate} loading={loading} error={error} />
        ) : (
          <PackView pack={generatedPack} onReset={handleReset} />
        )}
      </div>
    </div>
  );
}
