/**
 * Local filesystem skill indexing
 * Scans .agent/skills directory and indexes SKILL.md files
 */

import Database from 'better-sqlite3';
import fs from 'fs/promises';
import path from 'path';
import { parseSkillFrontmatter } from './skill-parser';
import type { SyncResult, SyncError, LocalConfig } from './types';
import { scanLocalDirectory } from './skill-scanner';

/**
 * Sync local filesystem source: index SKILL.md files from .agent/skills
 */
export async function syncLocalSource(
  db: Database.Database,
  sourceId: number,
  config: LocalConfig
): Promise<SyncResult> {
  const result: SyncResult = {
    indexed: 0,
    updated: 0,
    removed: 0,
    errors: [],
    scannedPaths: [],
    detectedFiles: [],
  };

  console.log(`[Sync:Local] Starting local sync for source ${sourceId}`);

  try {
    // Default base path: .agent/skills in project root
    const basePath = config.base_path || path.join(process.cwd(), '.agent', 'skills');

    // Check if directory exists
    try {
      const stats = await fs.stat(basePath);
      if (!stats.isDirectory()) {
        throw new Error(`Path exists but is not a directory: ${basePath}`);
      }
    } catch (error: any) {
      if (error.code === 'ENOENT') {
        const syncError: SyncError = {
          step: 'scan_local',
          message: `Directory not found: ${basePath}. Create this directory and add SKILL.md files to index local skills.`,
        };
        result.errors.push(syncError);
        console.warn(`[Sync:Local] ${syncError.message}`);
        return result;
      }
      throw error;
    }

    console.log(`[Sync:Local] Scanning directory: ${basePath}`);

    // Scan directory recursively
    const detected = await scanLocalDirectory(basePath, {
      maxDepth: 10,
      maxFiles: 1000,
      caseSensitive: false,
    });

    result.detectedFiles = detected.map((d) => d.path);
    result.scannedPaths = result.detectedFiles; // For local, scanned = detected paths
    console.log(`[Sync:Local] Detected ${detected.length} SKILL.md files`);

    // Track seen slugs for pruning
    const seenSlugs = new Set<string>();

    // Process each detected skill
    for (const detectedSkill of detected) {
      try {
        const slug = detectedSkill.slug;
        seenSlugs.add(slug);

        // Read file content
        const fullPath = path.join(basePath, detectedSkill.path);
        const content = await fs.readFile(fullPath, 'utf-8');

        // Parse frontmatter + extract metadata
        const metadata = parseSkillFrontmatter(content);

        // Build local file path reference
        const skillFilePath = path.relative(process.cwd(), fullPath);

        // Check if skill already exists
        const existing = db
          .prepare('SELECT id FROM external_skill_refs WHERE source_id = ? AND slug = ?')
          .get(sourceId, slug) as any;

        if (existing) {
          // Update existing
          db.prepare(`
            UPDATE external_skill_refs
            SET name = ?, description = ?, tags_json = ?, triggers_json = ?,
                license = ?, repo_url = ?, version = ?, last_seen_at = datetime('now')
            WHERE id = ?
          `).run(
            metadata.name,
            metadata.description,
            JSON.stringify(metadata.tags),
            JSON.stringify(metadata.triggers),
            metadata.license,
            skillFilePath,
            metadata.version,
            existing.id
          );
          result.updated++;
        } else {
          // Insert new
          db.prepare(`
            INSERT INTO external_skill_refs
            (source_id, slug, name, description, tags_json, triggers_json, license, repo_url, version)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
          `).run(
            sourceId,
            slug,
            metadata.name,
            metadata.description,
            JSON.stringify(metadata.tags),
            JSON.stringify(metadata.triggers),
            metadata.license,
            skillFilePath,
            metadata.version
          );
          result.indexed++;

          // Index in FTS
          db.prepare(`
            INSERT INTO external_skills_fts (name, description, triggers, tags)
            VALUES (?, ?, ?, ?)
          `).run(
            metadata.name,
            metadata.description,
            JSON.stringify(metadata.triggers),
            JSON.stringify(metadata.tags)
          );
        }
      } catch (error: any) {
        const syncError: SyncError = {
          step: 'parse_file',
          message: error.message,
          path: detectedSkill.path,
        };
        result.errors.push(syncError);
        console.error(`[Sync:Local] Failed to process ${detectedSkill.path}:`, error);
      }
    }

    // Prune skills that are no longer in the directory
    const allExisting = db
      .prepare('SELECT id, slug FROM external_skill_refs WHERE source_id = ?')
      .all(sourceId) as Array<{ id: number; slug: string }>;

    for (const existing of allExisting) {
      if (!seenSlugs.has(existing.slug)) {
        db.prepare('DELETE FROM external_skill_refs WHERE id = ?').run(existing.id);
        result.removed++;
      }
    }

    console.log(
      `[Sync:Local] Complete: indexed=${result.indexed}, updated=${result.updated}, removed=${result.removed}`
    );

    return result;
  } catch (error: any) {
    console.error('[Sync:Local] Failed:', error);
    throw new Error(`Local sync failed: ${error.message}`);
  }
}
