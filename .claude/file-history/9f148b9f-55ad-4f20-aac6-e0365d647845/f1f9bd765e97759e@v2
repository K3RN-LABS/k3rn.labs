/**
 * Architecture Detector
 * Heuristic-based architecture style detection from folder structure
 */

import type { GitHubTreeItem, DetectionSignal } from '../types';

interface ArchitecturePattern {
  signals: string[]; // Required folder patterns
  architecture: string;
  confidence: 'high' | 'medium' | 'low';
}

const ARCHITECTURE_PATTERNS: ArchitecturePattern[] = [
  // Domain-Driven Design
  {
    signals: ['src/domain', 'src/infrastructure', 'src/application'],
    architecture: 'DDD (Domain-Driven Design)',
    confidence: 'high',
  },
  {
    signals: ['domain/', 'infrastructure/'],
    architecture: 'DDD (Domain-Driven Design)',
    confidence: 'medium',
  },

  // Clean Architecture
  {
    signals: ['src/entities', 'src/use-cases', 'src/adapters'],
    architecture: 'Clean Architecture',
    confidence: 'high',
  },
  {
    signals: ['src/core', 'src/infrastructure', 'src/presentation'],
    architecture: 'Clean Architecture',
    confidence: 'high',
  },

  // Hexagonal / Ports & Adapters
  {
    signals: ['src/ports', 'src/adapters'],
    architecture: 'Hexagonal (Ports & Adapters)',
    confidence: 'high',
  },

  // Modular Monolith
  {
    signals: ['src/modules/', 'modules/'],
    architecture: 'Modular Monolith',
    confidence: 'medium',
  },

  // Next.js patterns
  {
    signals: ['app/', 'app/api/'],
    architecture: 'Next.js App Router',
    confidence: 'high',
  },
  {
    signals: ['pages/', 'pages/api/'],
    architecture: 'Next.js Pages Router',
    confidence: 'high',
  },

  // MVC
  {
    signals: ['models/', 'views/', 'controllers/'],
    architecture: 'MVC (Model-View-Controller)',
    confidence: 'high',
  },
  {
    signals: ['src/models', 'src/views', 'src/controllers'],
    architecture: 'MVC (Model-View-Controller)',
    confidence: 'high',
  },

  // Feature-based
  {
    signals: ['src/features/', 'features/'],
    architecture: 'Feature-based',
    confidence: 'medium',
  },

  // Layered
  {
    signals: ['src/data', 'src/business', 'src/presentation'],
    architecture: 'Layered Architecture',
    confidence: 'medium',
  },
];

/**
 * Detect architecture style from folder structure
 */
export function detectArchitecture(tree: GitHubTreeItem[]): DetectionSignal | null {
  const folders = tree
    .filter((item) => item.type === 'tree')
    .map((item) => item.path.toLowerCase());

  // Check each pattern
  for (const pattern of ARCHITECTURE_PATTERNS) {
    const matches = pattern.signals.filter((signal) =>
      folders.some((folder) => folder.includes(signal.toLowerCase()))
    );

    if (matches.length === pattern.signals.length) {
      return {
        confidence: pattern.confidence,
        evidence: `Folders: ${matches.join(', ')}`,
        value: pattern.architecture,
      };
    }
  }

  // Fallback: detect simple structure
  const hasSrc = folders.some((f) => f.startsWith('src/'));
  const hasComponents = folders.some((f) => f.includes('components'));
  const hasPages = folders.some((f) => f.includes('pages'));

  if (hasSrc && hasComponents) {
    return {
      confidence: 'low',
      evidence: 'Standard src/ + components/ structure',
      value: 'Component-based',
    };
  }

  if (hasPages && hasComponents) {
    return {
      confidence: 'low',
      evidence: 'pages/ + components/ structure',
      value: 'Page-based',
    };
  }

  return null;
}

/**
 * Detect if project is a monorepo
 */
export function detectMonorepo(
  packageJson: any | null,
  tree: GitHubTreeItem[]
): boolean {
  // Check workspaces in package.json
  if (packageJson?.workspaces) {
    return true;
  }

  // Check for common monorepo tools
  const files = tree.filter((f) => f.type === 'blob').map((f) => f.path);

  if (
    files.includes('lerna.json') ||
    files.includes('nx.json') ||
    files.includes('turbo.json') ||
    files.includes('pnpm-workspace.yaml')
  ) {
    return true;
  }

  // Check for packages/ or apps/ folders
  const folders = tree.filter((f) => f.type === 'tree').map((f) => f.path);

  if (folders.some((f) => f === 'packages' || f === 'apps')) {
    return true;
  }

  return false;
}
