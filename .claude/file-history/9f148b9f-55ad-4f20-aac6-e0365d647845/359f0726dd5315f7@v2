import { NextRequest, NextResponse } from 'next/server';
import { getDb } from '@/lib/db';
import type { GitHubConfig } from '@/lib/sources/types';
import { detectSkillFiles, COMMON_PATTERNS, validateDetected } from '@/lib/sources/skill-scanner';

export const dynamic = 'force-dynamic';

interface GitHubTreeItem {
  path: string;
  type: 'blob' | 'tree';
}

/**
 * GET /api/sources/[id]/validate
 * Dry-run validation: preview what skills would be detected without syncing
 */
export async function GET(
  request: NextRequest,
  context: { params: Promise<{ id: string }> }
) {
  try {
    const { id } = await context.params;
    const sourceId = parseInt(id, 10);

    if (isNaN(sourceId)) {
      return NextResponse.json({ error: 'Invalid source ID' }, { status: 400 });
    }

    const db = getDb();

    // Fetch source configuration
    const source = db
      .prepare('SELECT * FROM skill_sources WHERE id = ?')
      .get(sourceId) as any;

    if (!source) {
      return NextResponse.json({ error: 'Source not found' }, { status: 404 });
    }

    if (source.type !== 'github') {
      return NextResponse.json(
        { error: 'Validation only supported for GitHub sources' },
        { status: 400 }
      );
    }

    const config: GitHubConfig = JSON.parse(source.config_json || '{}');

    if (!config.repo_url) {
      return NextResponse.json({ error: 'repo_url required in config' }, { status: 400 });
    }

    console.log(`[Validate] Starting dry-run for source ${sourceId}`);

    // Parse repo URL
    const { owner, repo } = parseGitHubUrl(config.repo_url);
    const branch = config.branch || 'main';
    const patterns = config.patterns || COMMON_PATTERNS;

    // Fetch repository tree via GitHub API
    let tree: GitHubTreeItem[];
    try {
      tree = await fetchGitHubTree(owner, repo, branch, config.github_token);
    } catch (error: any) {
      return NextResponse.json(
        {
          success: false,
          error: error.message,
          httpStatus: extractHttpStatus(error.message),
          step: 'fetch_tree',
        },
        { status: 500 }
      );
    }

    // Auto-detect SKILL.md files
    const allPaths = tree.filter((item) => item.type === 'blob').map((item) => item.path);
    const detected = detectSkillFiles(allPaths, patterns, { caseSensitive: false });

    // Validate detected skills
    const validation = validateDetected(detected);

    console.log(`[Validate] Detected ${detected.length} skills in ${owner}/${repo}`);

    return NextResponse.json({
      success: true,
      source: {
        id: sourceId,
        name: source.name,
        repo_url: config.repo_url,
        branch,
      },
      scan: {
        scannedPaths: allPaths.length,
        detectedSkills: detected.length,
        patterns,
      },
      detected: validation.valid.map((d) => ({
        path: d.path,
        slug: d.slug,
      })),
      issues: {
        duplicateSlugs: validation.duplicates,
        invalidSlugs: validation.invalidSlugs,
      },
    });
  } catch (error: any) {
    console.error('[Validate] Error:', error);
    return NextResponse.json(
      {
        success: false,
        error: error.message || 'Validation failed',
      },
      { status: 500 }
    );
  }
}

/**
 * Parse GitHub URL to extract owner/repo
 */
function parseGitHubUrl(url: string): { owner: string; repo: string } {
  const match = url.match(/github\.com\/([^\/]+)\/([^\/\.]+)/);
  if (!match) {
    throw new Error('Invalid GitHub URL format');
  }
  return { owner: match[1], repo: match[2] };
}

/**
 * Fetch repository tree via GitHub API (recursive)
 */
async function fetchGitHubTree(
  owner: string,
  repo: string,
  branch: string,
  token?: string
): Promise<GitHubTreeItem[]> {
  const headers: Record<string, string> = {
    Accept: 'application/vnd.github.v3+json',
  };

  if (token) {
    headers.Authorization = `token ${token}`;
  }

  // Get branch ref to find tree SHA
  const refUrl = `https://api.github.com/repos/${owner}/${repo}/git/ref/heads/${branch}`;
  const refRes = await fetch(refUrl, { headers });

  if (!refRes.ok) {
    throw new Error(`Failed to fetch branch ref: ${refRes.status} ${refRes.statusText}`);
  }

  const refData = await refRes.json();
  const commitSha = refData.object.sha;

  // Get commit to find tree SHA
  const commitUrl = `https://api.github.com/repos/${owner}/${repo}/git/commits/${commitSha}`;
  const commitRes = await fetch(commitUrl, { headers });

  if (!commitRes.ok) {
    throw new Error(`Failed to fetch commit: ${commitRes.status} ${commitRes.statusText}`);
  }

  const commitData = await commitRes.json();
  const treeSha = commitData.tree.sha;

  // Get tree recursively
  const treeUrl = `https://api.github.com/repos/${owner}/${repo}/git/trees/${treeSha}?recursive=1`;
  const treeRes = await fetch(treeUrl, { headers });

  if (!treeRes.ok) {
    throw new Error(`Failed to fetch tree: ${treeRes.status} ${treeRes.statusText}`);
  }

  const treeData = await treeRes.json();
  return treeData.tree as GitHubTreeItem[];
}

/**
 * Extract HTTP status code from error message
 */
function extractHttpStatus(message: string): number | undefined {
  const statusMatch = message.match(/(\d{3})/);
  return statusMatch ? parseInt(statusMatch[1], 10) : undefined;
}
