'use client';

import { useState, useEffect } from 'react';
import SearchBar from '@/components/SearchBar';
import Filters from '@/components/Filters';
import ResultsList from '@/components/ResultsList';
import StackPanel from '@/components/StackPanel';

export default function Home() {
  const [query, setQuery] = useState('');
  const [category, setCategory] = useState('');
  const [tags, setTags] = useState('');
  const [hasCard, setHasCard] = useState(false);
  const [results, setResults] = useState<any[]>([]);
  const [loading, setLoading] = useState(false);
  const [metadata, setMetadata] = useState<any>(null);
  const [stack, setStack] = useState<number[]>([]);

  // Fetch metadata on mount
  useEffect(() => {
    fetch('/api/metadata')
      .then((res) => res.json())
      .then((data) => setMetadata(data))
      .catch((err) => console.error('Failed to fetch metadata:', err));
  }, []);

  // Search whenever filters change
  useEffect(() => {
    const search = async () => {
      setLoading(true);
      try {
        const params = new URLSearchParams();
        if (query) params.set('q', query);
        if (category) params.set('category', category);
        if (tags) params.set('tags', tags);
        if (hasCard) params.set('hasCard', 'true');

        const res = await fetch(`/api/search?${params.toString()}`);
        const data = await res.json();
        setResults(data.results || []);
      } catch (error) {
        console.error('Search failed:', error);
        setResults([]);
      } finally {
        setLoading(false);
      }
    };

    search();
  }, [query, category, tags, hasCard]);

  const addToStack = (skillId: number) => {
    if (!stack.includes(skillId)) {
      setStack([...stack, skillId]);
    }
  };

  const removeFromStack = (skillId: number) => {
    setStack(stack.filter((id) => id !== skillId));
  };

  const reorderStack = (fromIndex: number, toIndex: number) => {
    const newStack = [...stack];
    const [removed] = newStack.splice(fromIndex, 1);
    newStack.splice(toIndex, 0, removed);
    setStack(newStack);
  };

  return (
    <div className="min-h-screen">
      <header className="bg-white border-b border-gray-200">
        <div className="max-w-7xl mx-auto px-4 py-6">
          <h1 className="text-3xl font-bold text-gray-900">
            Skill Search & Stack Builder
          </h1>
          <p className="text-gray-600 mt-1">
            Search 631+ skills and build your custom stack
          </p>
        </div>
      </header>

      <div className="max-w-7xl mx-auto px-4 py-6">
        <SearchBar query={query} setQuery={setQuery} />

        <div className="mt-6 flex gap-6">
          <div className="flex-1">
            <Filters
              metadata={metadata}
              category={category}
              setCategory={setCategory}
              tags={tags}
              setTags={setTags}
              hasCard={hasCard}
              setHasCard={setHasCard}
            />

            <div className="mt-6">
              {loading ? (
                <div className="text-center py-12">
                  <div className="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-blue-600"></div>
                  <p className="mt-2 text-gray-600">Searching...</p>
                </div>
              ) : (
                <ResultsList
                  results={results}
                  query={query}
                  addToStack={addToStack}
                  stack={stack}
                />
              )}
            </div>
          </div>

          <StackPanel
            stack={stack}
            results={results}
            removeFromStack={removeFromStack}
            reorderStack={reorderStack}
          />
        </div>
      </div>
    </div>
  );
}
