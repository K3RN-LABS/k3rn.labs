/**
 * Parse SKILL.md frontmatter and extract metadata
 * Index-only: we extract key fields but don't store full content
 */

export interface SkillMetadata {
  name: string;
  description: string;
  tags: string[];
  triggers: string[];
  license: string | null;
  version: string | null;
}

/**
 * Parse SKILL.md content and extract frontmatter + key metadata
 */
export function parseSkillFrontmatter(content: string): SkillMetadata {
  const metadata: SkillMetadata = {
    name: '',
    description: '',
    tags: [],
    triggers: [],
    license: null,
    version: null,
  };

  // Extract YAML frontmatter if present (between --- delimiters)
  const frontmatterMatch = content.match(/^---\n([\s\S]*?)\n---/);

  if (frontmatterMatch) {
    const frontmatter = frontmatterMatch[1];

    // Parse simple YAML fields (name, description, tags, triggers, license, version)
    const nameMatch = frontmatter.match(/^name:\s*(.+)$/m);
    if (nameMatch) metadata.name = nameMatch[1].trim();

    const descMatch = frontmatter.match(/^description:\s*(.+)$/m);
    if (descMatch) metadata.description = descMatch[1].trim();

    const licenseMatch = frontmatter.match(/^license:\s*(.+)$/m);
    if (licenseMatch) metadata.license = licenseMatch[1].trim();

    const versionMatch = frontmatter.match(/^version:\s*(.+)$/m);
    if (versionMatch) metadata.version = versionMatch[1].trim();

    // Parse array fields (tags, triggers)
    const tagsMatch = frontmatter.match(/^tags:\s*\[(.*?)\]$/m);
    if (tagsMatch) {
      metadata.tags = tagsMatch[1].split(',').map((t) => t.trim().replace(/['"]/g, ''));
    }

    const triggersMatch = frontmatter.match(/^triggers:\s*\[(.*?)\]$/m);
    if (triggersMatch) {
      metadata.triggers = triggersMatch[1]
        .split(',')
        .map((t) => t.trim().replace(/['"]/g, ''));
    }
  }

  // Fallback: if no frontmatter, extract from markdown headers
  if (!metadata.name) {
    const h1Match = content.match(/^#\s+(.+)$/m);
    if (h1Match) metadata.name = h1Match[1].trim();
  }

  if (!metadata.description) {
    // Extract first paragraph after frontmatter/title
    const descMatch = content.match(/^#{1,2}\s+.+\n\n(.+?)(?:\n\n|$)/m);
    if (descMatch) {
      metadata.description = descMatch[1].trim().slice(0, 200);
    } else {
      // Fallback: first non-empty line after title
      const lines = content.split('\n').filter((l) => l.trim() && !l.startsWith('#'));
      if (lines.length > 0) {
        metadata.description = lines[0].slice(0, 200);
      }
    }
  }

  // If still no name, use generic fallback
  if (!metadata.name) {
    metadata.name = 'Unknown Skill';
  }

  return metadata;
}
