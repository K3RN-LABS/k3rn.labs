import React from 'react';

export interface HeadingProps {
  level: 1 | 2 | 3;
  children: React.ReactNode;
  className?: string;
}

export function Heading({ level, children, className = '' }: HeadingProps) {
  const Tag = `h${level}` as keyof React.JSX.IntrinsicElements;
  const headingClass = `h${level}`;

  return React.createElement(
    Tag,
    { className: `${headingClass} ${className}`.trim() },
    children
  );
}

export interface KickerProps {
  children: React.ReactNode;
  className?: string;
}

/**
 * k3rn.labs Kicker Component
 *
 * Uppercase label with increased letter-spacing
 * Use for section labels and metadata
 */
export function Kicker({ children, className = '' }: KickerProps) {
  return (
    <div className={`kicker ${className}`.trim()}>
      {children}
    </div>
  );
}

export interface TextProps {
  variant?: 'body' | 'small' | 'muted';
  children: React.ReactNode;
  className?: string;
}

export function Text({ variant = 'body', children, className = '' }: TextProps) {
  const textClass = variant === 'small' ? 'text-small' : variant === 'muted' ? 'text-muted' : '';

  return (
    <p className={`${textClass} ${className}`.trim()}>
      {children}
    </p>
  );
}
