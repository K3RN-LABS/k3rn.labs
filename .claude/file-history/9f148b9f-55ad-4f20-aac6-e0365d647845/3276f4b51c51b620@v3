import { NextRequest, NextResponse } from 'next/server';
import { getDb } from '@/lib/db';

export const dynamic = 'force-dynamic';

export async function POST(request: NextRequest) {
  const body = await request.json();
  const { skillIds, format = 'markdown', priority = [] } = body;

  if (!skillIds || !Array.isArray(skillIds)) {
    return NextResponse.json({ error: 'Invalid skill IDs' }, { status: 400 });
  }

  const db = getDb();

  try {
    // Fetch skills with cards
    const placeholders = skillIds.map(() => '?').join(',');
    const skills = db.prepare(`
      SELECT s.*, sc.*
      FROM skills s
      LEFT JOIN skill_cards sc ON sc.skill_id = s.id
      WHERE s.id IN (${placeholders})
    `).all(...skillIds) as any[];

    // Minimal JSON for TicketPack import
    if (format === 'minimal-json') {
      const minimalData = {
        version: '1.0.0',
        skills: skills.map((skill, index) => ({
          id: skill.id,
          slug: skill.name, // name is the slug
          priority: priority[index] || 'support', // 'primary' or 'support'
        })),
      };

      return NextResponse.json({ format: 'minimal-json', content: JSON.stringify(minimalData, null, 2) });
    }

    // Activation XML for Claude Code agent-resolved
    if (format === 'activation-xml') {
      let xml = `<skills_context mode="agent-resolved">\n`;
      xml += `  <skills>\n`;

      skills.forEach((skill, index) => {
        const skillPriority = priority[index] || 'support';
        xml += `    <skill slug="${skill.name}" priority="${skillPriority}"/>\n`;
      });

      xml += `  </skills>\n\n`;

      xml += `  <resolution_protocol>\n`;
      xml += `    <step>For each skill, navigate to .agent/skills/skills/{slug}/</step>\n`;
      xml += `    <step>Read SKILL.md first.</step>\n`;
      xml += `    <step>If a reference/ folder exists, read only files that are directly required for the current ticket.</step>\n`;
      xml += `    <step>Extract: activation steps, constraints, stop conditions. Apply them while implementing.</step>\n`;
      xml += `    <step>Do not load unrelated skills or the full catalogue. Keep context minimal.</step>\n`;
      xml += `  </resolution_protocol>\n\n`;

      xml += `  <stop_conditions>\n`;
      xml += `    <stop>If the slug folder does not exist, STOP and report missing skill mapping.</stop>\n`;
      xml += `    <stop>If instructions conflict, STOP and ask for precedence (primary over support unless specified).</stop>\n`;
      xml += `  </stop_conditions>\n`;
      xml += `</skills_context>`;

      return NextResponse.json({ format: 'activation-xml', content: xml });
    }

    if (format === 'json') {
      const jsonData = skills.map((skill) => ({
        id: skill.id,
        name: skill.name,
        category: skill.category,
        description: skill.description,
        tags: JSON.parse(skill.tags_json || '[]'),
        triggers: JSON.parse(skill.triggers_json || '[]'),
        card: skill.skill_id ? {
          use_when: JSON.parse(skill.use_when_json || '[]'),
          avoid_when: JSON.parse(skill.avoid_when_json || '[]'),
          inputs: skill.inputs,
          outputs: skill.outputs,
          activation: skill.activation,
          similar: JSON.parse(skill.similar_json || '[]'),
          diff_notes: skill.diff_notes,
          risk_level: skill.risk_level,
        } : null,
      }));

      return NextResponse.json({ format: 'json', content: JSON.stringify(jsonData, null, 2) });
    }

    // Markdown format
    let markdown = '# Skill Stack\n\n';
    markdown += `Generated: ${new Date().toISOString()}\n\n`;
    markdown += `## Core Skills (${skills.length})\n\n`;

    skills.forEach((skill) => {
      markdown += `### ${skill.name}\n\n`;
      markdown += `**Category:** ${skill.category}\n\n`;
      markdown += `**Description:** ${skill.description}\n\n`;

      const tags = JSON.parse(skill.tags_json || '[]');
      if (tags.length > 0) {
        markdown += `**Tags:** ${tags.join(', ')}\n\n`;
      }

      const triggers = JSON.parse(skill.triggers_json || '[]');
      if (triggers.length > 0) {
        markdown += `**Triggers:** ${triggers.join(', ')}\n\n`;
      }

      if (skill.skill_id) {
        const useWhen = JSON.parse(skill.use_when_json || '[]');
        if (useWhen.length > 0) {
          markdown += `**Use When:**\n`;
          useWhen.forEach((item: string) => {
            markdown += `- ${item}\n`;
          });
          markdown += '\n';
        }

        const avoidWhen = JSON.parse(skill.avoid_when_json || '[]');
        if (avoidWhen.length > 0) {
          markdown += `**Avoid When:**\n`;
          avoidWhen.forEach((item: string) => {
            markdown += `- ${item}\n`;
          });
          markdown += '\n';
        }

        if (skill.risk_level) {
          markdown += `**Risk Level:** ${skill.risk_level}\n\n`;
        }
      }

      markdown += '---\n\n';
    });

    markdown += '## Activation Order\n\n';
    markdown += '1. **Scan** - Analyze the request\n';
    markdown += '2. **Validate** - Check constraints\n';
    markdown += '3. **Plan** - Design the approach\n';
    markdown += '4. **Mutate** - Execute changes\n\n';

    markdown += '## STOP Conditions\n\n';
    markdown += '- TBD (define based on use case)\n\n';

    return NextResponse.json({ format: 'markdown', content: markdown });
  } catch (error) {
    console.error('Export error:', error);
    return NextResponse.json({ error: 'Export failed' }, { status: 500 });
  }
}
