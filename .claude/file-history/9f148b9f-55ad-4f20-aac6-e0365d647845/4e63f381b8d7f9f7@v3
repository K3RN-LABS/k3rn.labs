/**
 * Project Context Summarizer
 * Orchestrates all detectors and generates deterministic summary
 */

import type { ProjectContext, StructuredProjectContext, DetectionSignal } from './types';
import type { RepoMetadata } from './repo-fetcher';
import { detectFramework } from './detectors/framework.detector';
import { detectLanguage, detectRuntime, detectPackageManager } from './detectors/language.detector';
import { detectArchitecture, detectMonorepo } from './detectors/architecture.detector';
import {
  detectORM,
  detectDatabase,
  detectStateManagement,
  detectBuildTool,
} from './detectors/tooling.detector';
import { detectTestFramework } from './detectors/testing.detector';

/**
 * Analyze repository and generate project context
 * Returns both structured context (source of truth) and legacy fields
 */
export function analyzeProject(metadata: RepoMetadata): ProjectContext {
  const { tree, packageJson, info } = metadata;

  // Run all detectors
  const framework = detectFramework(packageJson);
  const language = detectLanguage(packageJson, tree, info.language);
  const runtime = detectRuntime(packageJson);
  const packageManager = detectPackageManager(tree);
  const architecture = detectArchitecture(tree);
  const monorepo = detectMonorepo(packageJson, tree);
  const orm = detectORM(packageJson);
  const database = detectDatabase(packageJson);
  const stateManagement = detectStateManagement(packageJson);
  const buildTool = detectBuildTool(packageJson);
  const testFramework = detectTestFramework(packageJson);

  const detections = {
    framework,
    language,
    runtime,
    packageManager,
    architecture,
    monorepo,
    orm,
    database,
    stateManagement,
    buildTool,
    testFramework,
  };

  // 1. Generate structured context (source of truth)
  const structured = generateStructuredContext(detections, packageJson !== null);

  // 2. Derive markdown notes from structured context
  const notes = generateNotesFromStructured(structured, detections);

  // 3. Return full context (structured + legacy fields)
  return {
    structured,
    // Legacy fields (for backward compatibility)
    framework: framework?.value || null,
    language: language?.value || null,
    runtime: runtime?.value || null,
    package_manager: packageManager?.value || null,
    architecture_style: architecture?.value || null,
    state_management: stateManagement?.value || null,
    orm: orm?.value || null,
    database: database?.value || null,
    test_framework: testFramework?.value || null,
    build_tool: buildTool?.value || null,
    monorepo,
    notes,
  };
}

/**
 * Generate structured project context (source of truth)
 * Calculates confidence score and tracks detection sources
 */
function generateStructuredContext(
  detections: {
    framework: any;
    language: any;
    runtime: any;
    packageManager: any;
    architecture: any;
    monorepo: boolean;
    orm: any;
    database: any;
    stateManagement: any;
    buildTool: any;
    testFramework: any;
  },
  hasPackageJson: boolean
): StructuredProjectContext {
  // Calculate confidence score (0-100)
  const confidenceScore = calculateConfidenceScore(detections);

  // Track detection sources
  const detectionSources: string[] = [];
  if (hasPackageJson) detectionSources.push('package.json');
  if (detections.architecture || detections.monorepo) detectionSources.push('file structure');

  // Map runtime to standardized enum
  const runtimeValue = detections.runtime?.value || 'Node.js';
  const runtime = mapRuntimeToEnum(runtimeValue);

  return {
    framework: detections.framework?.value,
    language: detections.language?.value || 'JavaScript',
    runtime,
    packageManager: detections.packageManager?.value,
    testing: detections.testFramework?.value,
    architecture: detections.architecture?.value,
    confidenceScore,
    detectionSources,
  };
}

/**
 * Calculate confidence score based on detection quality
 * High confidence detections = 20 points each
 * Medium = 10 points, Low = 5 points
 */
function calculateConfidenceScore(detections: any): number {
  let score = 0;
  const weights = { high: 20, medium: 10, low: 5 };

  Object.entries(detections).forEach(([key, detection]) => {
    if (
      detection &&
      typeof detection === 'object' &&
      'confidence' in detection &&
      detection.confidence
    ) {
      const conf = (detection as DetectionSignal).confidence;
      score += weights[conf] || 0;
    }
  });

  return Math.min(100, score); // Cap at 100
}

/**
 * Map runtime string to standardized enum
 */
function mapRuntimeToEnum(runtime: string): 'node' | 'edge' | 'browser' {
  const lower = runtime.toLowerCase();
  if (lower.includes('deno') || lower.includes('bun')) return 'node';
  if (lower.includes('edge') || lower.includes('vercel')) return 'edge';
  if (lower.includes('browser') || lower.includes('client')) return 'browser';
  return 'node'; // default
}

/**
 * Generate markdown notes from structured context
 * Structured context is the source of truth
 */
function generateNotesFromStructured(
  structured: StructuredProjectContext,
  detections: any
): string {
  const sections: string[] = [];

  // Stack technique
  const stack: string[] = [];
  if (structured.language) stack.push(structured.language);
  if (structured.framework) stack.push(structured.framework);
  stack.push(`(${structured.runtime})`);
  sections.push(`**Stack technique:** ${stack.join(' + ')}`);

  // Architecture
  if (structured.architecture) {
    sections.push(`**Architecture:** ${structured.architecture}`);
  }

  // Package manager
  if (structured.packageManager) {
    sections.push(`**Package manager:** ${structured.packageManager}`);
  }

  // Testing
  if (structured.testing) {
    sections.push(`**Tests:** ${structured.testing}`);
  }

  // Confidence summary
  sections.push(
    `\n*Score de confiance: ${structured.confidenceScore}% • Sources: ${structured.detectionSources.join(', ')}*`
  );

  return sections.join('\n');
}
