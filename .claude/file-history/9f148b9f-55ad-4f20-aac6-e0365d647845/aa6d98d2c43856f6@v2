'use client';

import Link from 'next/link';

interface ResultsListProps {
  results: any[];
  query: string;
  addToStack: (skillId: number) => void;
  stack: number[];
}

export default function ResultsList({
  results,
  query,
  addToStack,
  stack,
}: ResultsListProps) {
  if (results.length === 0) {
    return (
      <div className="card text-center py-12">
        <p className="text-gray-600">
          {query ? 'No skills found. Try a different search.' : 'Enter a search query to find skills.'}
        </p>
      </div>
    );
  }

  return (
    <div className="space-y-3">
      <div className="text-sm text-gray-600 mb-2">
        Found {results.length} skill{results.length !== 1 ? 's' : ''}
      </div>

      {results.map((skill) => (
        <div key={skill.id} className="card hover:shadow-md transition-shadow">
          <div className="flex justify-between items-start">
            <div className="flex-1">
              <div className="flex items-center gap-3">
                <Link
                  href={`/skills/${skill.id}`}
                  className="text-lg font-semibold text-blue-600 hover:text-blue-800"
                >
                  {skill.name}
                </Link>
                <span className="px-2 py-1 text-xs bg-gray-100 text-gray-700 rounded">
                  {skill.category}
                </span>
                {skill.score !== 0 && (
                  <span className="px-2 py-1 text-xs bg-green-100 text-green-700 rounded">
                    Score: {Math.abs(skill.score).toFixed(2)}
                  </span>
                )}
              </div>

              <p className="mt-2 text-gray-700 text-sm line-clamp-2">
                {skill.description}
              </p>

              <div className="mt-2 flex flex-wrap gap-1">
                {skill.tags.slice(0, 5).map((tag: string) => (
                  <span
                    key={tag}
                    className="px-2 py-1 text-xs bg-blue-50 text-blue-700 rounded"
                  >
                    {tag}
                  </span>
                ))}
                {skill.tags.length > 5 && (
                  <span className="px-2 py-1 text-xs text-gray-500">
                    +{skill.tags.length - 5} more
                  </span>
                )}
              </div>

              {skill.matched_fields && (
                <div className="mt-2 text-xs text-gray-500">
                  Matched: {skill.matched_fields}
                </div>
              )}
            </div>

            <button
              className={`ml-4 px-3 py-1 text-sm rounded ${
                stack.includes(skill.id)
                  ? 'bg-green-100 text-green-700 cursor-default'
                  : 'bg-blue-600 text-white hover:bg-blue-700'
              }`}
              onClick={() => addToStack(skill.id)}
              disabled={stack.includes(skill.id)}
            >
              {stack.includes(skill.id) ? 'In Stack' : 'Add to Stack'}
            </button>
          </div>
        </div>
      ))}
    </div>
  );
}
