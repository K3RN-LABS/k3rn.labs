/* k3rn.labs — Design Tokens (Canonical)
   Rule: Use ONLY tokens. If a value repeats, promote to token.
   Rule: Green is reserved for PRIMARY CTA ONLY.
*/
:root {
  /* --- Color: Primary (CTA only) --- */
  --primary-900: #103322; /* Primary CTA bg */
  --primary-850: #113726; /* Primary CTA hover */
  --primary-700: #146B4F; /* Accents, badges (subtle) */
  --primary-600: #1E9E73; /* Limited: charts / success nuance */

  /* --- Color: Ink / Text --- */
  --ink-900: #0E1F14;     /* Default action button bg */
  --ink-700: #1F2F25;
  --text:     #0E1F14;
  --text-2:   #5B635F;
  --muted:    #9AA19C;

  /* --- Color: Surfaces --- */
  --bg:       #F5F8F6;     /* App background */
  --bg-2:     #F3F5F4;     /* Alt bg for subtle sections */
  --surface:  #FFFFFF;     /* Cards / panels */
  --divider:  #EEF1EF;     /* Hairline separators */

  /* --- Color: Borders / Focus --- */
  --border-soft: rgba(16,24,40,0.06);
  --border:      rgba(16,24,40,0.10);
  --focus:       rgba(20,107,79,0.22);

  /* --- Color: System States --- */
  --white:       #FFFFFF;
  --error-900:   #991B1B;  /* Error text dark */
  --error-700:   #B91C1C;  /* Error text */
  --error-500:   #DC2626;  /* Error border/icon */
  --error-50:    rgba(220, 38, 38, 0.05);  /* Error bg subtle */
  --error-100:   rgba(220, 38, 38, 0.20);  /* Error border subtle */

  --warning-900: #92400E;  /* Warning text dark */
  --warning-500: #F59E0B;  /* Warning border/icon */
  --warning-50:  rgba(245, 158, 11, 0.10); /* Warning bg subtle */
  --warning-100: rgba(245, 158, 11, 0.20); /* Warning border subtle */

  /* --- Color: Overlays / Alpha --- */
  --overlay-white: rgba(255, 255, 255, 0.88); /* Blur topbar */
  --overlay-dark-4: rgba(14, 31, 20, 0.04);   /* Hover subtle */
  --overlay-dark-8: rgba(14, 31, 20, 0.08);   /* Active subtle */
  --overlay-primary-2: rgba(20, 107, 79, 0.02); /* Primary tint bg */
  --overlay-primary-4: rgba(20, 107, 79, 0.04); /* Primary tint subtle */
  --overlay-primary-6: rgba(20, 107, 79, 0.06); /* Primary tint */
  --overlay-primary-8: rgba(20, 107, 79, 0.08); /* Primary tint border */
  --overlay-primary-12: rgba(20, 107, 79, 0.12); /* Primary tint border strong */

  /* --- Typography --- */
  --font-sans: ui-sans-serif, system-ui, -apple-system, Segoe UI, Inter, Roboto, Helvetica, Arial, "Apple Color Emoji","Segoe UI Emoji";
  --font-mono: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono","Courier New", monospace;

  --fs-h1: 54px; --lh-h1: 62px; --fw-h1: 600; --ls-h1: -0.04em;
  --fs-h2: 34px; --lh-h2: 42px; --fw-h2: 600; --ls-h2: -0.03em;
  --fs-h3: 24px; --lh-h3: 32px; --fw-h3: 600; --ls-h3: -0.02em;

  --fs-body: 15px; --lh-body: 24px; --fw-body: 450;
  --fs-small: 13px; --lh-small: 20px; --fw-small: 450;

  --fs-kicker: 11px; --lh-kicker: 16px; --fw-kicker: 800; --ls-kicker: 0.10em;

  /* --- Spacing (4px base) --- */
  --sp-1: 4px;
  --sp-2: 8px;
  --sp-3: 12px;
  --sp-4: 16px;
  --sp-5: 24px;
  --sp-6: 32px;
  --sp-7: 48px;
  --sp-8: 80px;
  --sp-9: 120px;

  /* --- Radius --- */
  --r-pill: 999px;
  --r-btn:  14px;
  --r-input:12px;
  --r-card: 22px;
  --r-panel:26px;

  /* --- Shadow --- */
  --sh-xs: 0 1px 2px rgba(16,24,40,0.05);
  --sh-sm: 0 2px 10px rgba(16,24,40,0.05);
  --sh-md: 0 12px 30px rgba(16,24,40,0.08);
  --sh-lg: 0 18px 44px rgba(16,24,40,0.10);
}
