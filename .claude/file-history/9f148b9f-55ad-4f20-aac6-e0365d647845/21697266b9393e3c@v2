#!/usr/bin/env node
/**
 * Deep Clean Script
 *
 * Nettoie complètement tous les caches et artifacts de build.
 * À utiliser en cas de problèmes persistants.
 *
 * Usage: npm run clean
 */

const fs = require('fs');
const path = require('path');
const { execSync } = require('child_process');

const DIRS_TO_CLEAN = [
  '.next',
  'node_modules/.cache',
  '.turbo'
];

console.log('🧹 Nettoyage complet du projet...\n');

// Arrêter tout processus Next.js en cours
try {
  console.log('🛑 Arrêt des processus Next.js...');
  execSync('pkill -f "next dev" 2>/dev/null || true', { stdio: 'ignore' });
  execSync('pkill -f "next build" 2>/dev/null || true', { stdio: 'ignore' });
  console.log('✅ Processus arrêtés\n');
} catch (error) {
  // Ignorer les erreurs (aucun processus à arrêter)
}

// Nettoyer les répertoires
DIRS_TO_CLEAN.forEach(dir => {
  const fullPath = path.join(process.cwd(), dir);

  if (fs.existsSync(fullPath)) {
    console.log(`🗑️  Suppression de ${dir}...`);
    try {
      fs.rmSync(fullPath, { recursive: true, force: true });
      console.log(`✅ ${dir} supprimé`);
    } catch (error) {
      console.error(`❌ Erreur: ${error.message}`);
    }
  } else {
    console.log(`⏭️  ${dir} n'existe pas (ignoré)`);
  }
});

console.log('\n✨ Nettoyage terminé!');
console.log('\n💡 Prochaines étapes:');
console.log('   npm install    # Réinstaller si nécessaire');
console.log('   npm run dev    # Redémarrer le serveur');
