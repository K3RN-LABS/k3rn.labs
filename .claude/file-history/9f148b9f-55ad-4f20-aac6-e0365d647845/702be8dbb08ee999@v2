/**
 * Tooling Detector
 * Detect ORM, database, state management, build tools
 */

import type { PackageJson, DetectionSignal } from '../types';

/**
 * Detect ORM
 */
export function detectORM(packageJson: PackageJson | null): DetectionSignal | null {
  if (!packageJson) {
    return null;
  }

  const allDeps = {
    ...packageJson.dependencies,
    ...packageJson.devDependencies,
  };

  const ormRules: Array<{ signal: string; orm: string }> = [
    { signal: 'prisma', orm: 'Prisma' },
    { signal: '@prisma/client', orm: 'Prisma' },
    { signal: 'typeorm', orm: 'TypeORM' },
    { signal: 'sequelize', orm: 'Sequelize' },
    { signal: 'mongoose', orm: 'Mongoose' },
    { signal: 'drizzle-orm', orm: 'Drizzle ORM' },
    { signal: 'kysely', orm: 'Kysely' },
    { signal: 'mikro-orm', orm: 'MikroORM' },
  ];

  for (const rule of ormRules) {
    if (allDeps[rule.signal]) {
      return {
        confidence: 'high',
        evidence: `Dependency: ${rule.signal}`,
        value: rule.orm,
      };
    }
  }

  return null;
}

