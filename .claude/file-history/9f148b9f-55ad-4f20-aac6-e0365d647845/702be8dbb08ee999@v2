/**
 * Detect build tool
 */
export function detectBuildTool(packageJson: PackageJson | null): DetectionSignal | null {
  if (!packageJson) {
    return null;
  }

  const allDeps = {
    ...packageJson.dependencies,
    ...packageJson.devDependencies,
  };

  const buildRules: Array<{ signal: string; tool: string; confidence: 'high' | 'medium' }> = [
    { signal: 'vite', tool: 'Vite', confidence: 'high' },
    { signal: 'webpack', tool: 'Webpack', confidence: 'high' },
    { signal: 'turbopack', tool: 'Turbopack', confidence: 'high' },
    { signal: 'esbuild', tool: 'esbuild', confidence: 'high' },
    { signal: 'rollup', tool: 'Rollup', confidence: 'high' },
    { signal: 'parcel', tool: 'Parcel', confidence: 'high' },
    { signal: '@swc/core', tool: 'SWC', confidence: 'medium' },
    { signal: 'tsup', tool: 'tsup', confidence: 'high' },
  ];

  for (const rule of buildRules) {
    if (allDeps[rule.signal]) {
      return {
        confidence: rule.confidence,
        evidence: `Dependency: ${rule.signal}`,
        value: rule.tool,
      };
    }
  }

  // Check Next.js (has built-in bundler)
  if (allDeps.next) {
    return {
      confidence: 'medium',
      evidence: 'Next.js built-in bundler',
      value: 'Next.js (built-in)',
    };
  }

  return null;
}
