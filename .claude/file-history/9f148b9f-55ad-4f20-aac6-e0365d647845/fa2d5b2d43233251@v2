#!/usr/bin/env node
/**
 * Brand Drift Check - Guardrail Script
 *
 * Ensures that design tokens are sourced from canonical brand directory.
 * Fails if:
 * - src/app/tokens.css exists (should be deleted, use brand/ directly)
 * - Hardcoded colors found in src/app or src/components/ui
 *
 * Usage: npm run brand:check
 */

const fs = require('fs');
const path = require('path');

const CANONICAL_TOKENS = 'brand/02_DESIGN_TOKENS/tokens.css';
const DUPLICATE_TOKENS = 'src/app/tokens.css';
const SCAN_PATHS = [
  'src/app/globals.css',
  'src/components/ui'
];

let exitCode = 0;

// Check 1: Duplicate tokens file
console.log('🔍 Check 1: Verifying single source of truth...');
if (fs.existsSync(DUPLICATE_TOKENS)) {
  console.error(`❌ FAIL: ${DUPLICATE_TOKENS} should not exist.`);
  console.error(`   Use canonical source: ${CANONICAL_TOKENS}`);
  exitCode = 1;
} else {
  console.log('✅ PASS: No duplicate tokens file');
}

// Check 2: Canonical tokens exists
console.log('\n🔍 Check 2: Verifying canonical tokens exists...');
if (!fs.existsSync(CANONICAL_TOKENS)) {
  console.error(`❌ FAIL: Canonical tokens not found at ${CANONICAL_TOKENS}`);
  exitCode = 1;
} else {
  console.log('✅ PASS: Canonical tokens found');
}

// Check 3: Hardcoded colors in critical files (spot check)
console.log('\n🔍 Check 3: Checking for hardcoded colors...');
const COLOR_PATTERN = /#[0-9A-Fa-f]{6}(?![0-9A-Fa-f])|#[0-9A-Fa-f]{3}(?![0-9A-Fa-f])|rgb\(|rgba\(/;
let hardcodedFound = false;

function scanFile(filePath) {
  const content = fs.readFileSync(filePath, 'utf8');
  const lines = content.split('\n');
  const violations = [];

  lines.forEach((line, index) => {
    // Skip if it's inside a CSS custom property definition
    if (line.includes('--') && line.includes(':')) return;

    // Skip if it's a comment
    if (line.trim().startsWith('/*') || line.trim().startsWith('//')) return;

    if (COLOR_PATTERN.test(line)) {
      violations.push({ line: index + 1, content: line.trim() });
    }
  });

  return violations;
}

function scanDirectory(dir) {
  const files = fs.readdirSync(dir, { withFileTypes: true });

  for (const file of files) {
    const fullPath = path.join(dir, file.name);

    if (file.isDirectory()) {
      scanDirectory(fullPath);
    } else if (file.name.endsWith('.tsx') || file.name.endsWith('.css')) {
      const violations = scanFile(fullPath);
      if (violations.length > 0) {
        console.error(`❌ ${fullPath}:`);
        violations.forEach(v => {
          console.error(`   Line ${v.line}: ${v.content.substring(0, 80)}`);
        });
        hardcodedFound = true;
      }
    }
  }
}

// Scan globals.css separately (it can have colors in comments/tokens definitions)
const globalsContent = fs.readFileSync('src/app/globals.css', 'utf8');
const globalsLines = globalsContent.split('\n');
const globalsViolations = [];

globalsLines.forEach((line, index) => {
  // Only flag hardcoded colors that are NOT in var() and NOT in token definitions
  if (COLOR_PATTERN.test(line) &&
      !line.includes('var(--') &&
      !line.includes(':root') &&
      !(line.includes('--') && line.includes(':')) &&
      !line.trim().startsWith('/*')) {
    globalsViolations.push({ line: index + 1, content: line.trim() });
  }
});

if (globalsViolations.length > 0) {
  console.error('❌ src/app/globals.css:');
  globalsViolations.forEach(v => {
    console.error(`   Line ${v.line}: ${v.content.substring(0, 80)}`);
  });
  hardcodedFound = true;
}

// Scan UI components
if (fs.existsSync('src/components/ui')) {
  scanDirectory('src/components/ui');
}

if (!hardcodedFound) {
  console.log('✅ PASS: No hardcoded colors in critical files');
} else {
  console.error('\n⚠️  WARNING: Hardcoded colors found. Use design tokens instead.');
  // Don't fail build for now, just warn
  // exitCode = 1;
}

// Summary
console.log('\n' + '='.repeat(50));
if (exitCode === 0) {
  console.log('✅ Brand drift check PASSED');
} else {
  console.log('❌ Brand drift check FAILED');
}

process.exit(exitCode);
