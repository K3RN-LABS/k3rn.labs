/**
 * TicketPack v1 - Types TypeScript alignés sur le schéma JSON
 */

export interface TicketPackMeta {
  pack_id: string;
  created_at: string; // ISO 8601
  language: 'fr';
  target_llm: 'claude';
  target_mode: 'claude_code';
  source_summary?: string;
}

export interface ProjectRepo {
  repo_name: string;
  important_paths: string[];
  notes?: string;
}

export interface Project {
  name: string;
  repo: ProjectRepo;
  deliverable_type: 'saas' | 'app' | 'landing_page' | 'feature' | 'bugfix';
}

export interface PRDScope {
  in_scope: string[];
  out_of_scope: string[];
}

export interface PRDAcceptance {
  definition_of_done: string[];
  quality_bar: string[];
}

export interface PRDConstraints {
  product: string[];
  technical: string[];
  security?: string[];
}

export interface PRD {
  problem_statement: string;
  goals: string[];
  non_goals: string[];
  scope: PRDScope;
  acceptance: PRDAcceptance;
  constraints: PRDConstraints;
}

export interface ADRAlternative {
  option: string;
  pros: string[];
  cons: string[];
}

export interface ADR {
  adr_id: string; // ADR-001
  title: string;
  status: 'proposed' | 'accepted';
  context: string;
  decision: string;
  alternatives: ADRAlternative[];
  consequences: string[];
}

export interface RoadmapPhase {
  phase_id: string; // P-01
  name: string;
  objective: string;
  exit_criteria: string[];
}

export interface Roadmap {
  phases: RoadmapPhase[];
}

export interface TicketRisk {
  risk: string;
  mitigation: string;
}

export interface Ticket {
  ticket_id: string; // T-001
  phase_id: string; // P-01
  title: string;
  type: 'epic' | 'story' | 'task';
  description: string;
  dependencies: string[]; // T-xxx
  acceptance_criteria: string[];
  risks: TicketRisk[];
  claude_code_prompt_ref: string; // PROMPT-T-001
}

export interface TicketPackSelectedSkill {
  skill_id: string;
  name: string;
  purpose: string;
  activation: string;
}

export interface RecommendedSkill {
  skill_id: string;
  score: number; // 0-1
  rationale: string;
}

export interface Skills {
  selected: TicketPackSelectedSkill[];
  recommended: RecommendedSkill[];
}

export interface TicketPrompt {
  prompt_id: string; // PROMPT-T-001
  ticket_id: string; // T-001
  content: string; // XML
}

export interface Prompts {
  global_prompt: string; // XML
  ticket_prompts: TicketPrompt[];
}

export interface Runbook {
  verification_commands: string[];
  notes: string[];
}

export interface TicketPack {
  version: '1.0.0';
  meta: TicketPackMeta;
  project: Project;
  prd: PRD;
  adrs: ADR[];
  roadmap: Roadmap;
  tickets: Ticket[];
  skills: Skills;
  prompts: Prompts;
  runbook: Runbook;
}

// Target repo context
export interface TargetRepoContext {
  githubUrl?: string;
  branch?: string;
  notes?: string;
  packageJson?: string;
  repoTree?: string;
}

// Input de l'utilisateur (UI → API)
export interface TicketPackInput {
  brief: string;
  sources: Array<{ type: 'text' | 'url'; content: string }>;
  deliverable_type: 'saas' | 'app' | 'landing_page' | 'feature' | 'bugfix';
  project_name?: string;
  selected_skills?: SelectedSkillsStack;
  operation_mode?: 'new_project' | 'feature_on_existing_repo';
  target_repo_context?: TargetRepoContext;
}

// Skills Stack Import (minimal JSON from Skills page)
export interface SelectedSkill {
  id: number;
  slug: string;
  priority: 'primary' | 'support';
}

export interface SelectedSkillsStack {
  version: string;
  skills: SelectedSkill[];
}
