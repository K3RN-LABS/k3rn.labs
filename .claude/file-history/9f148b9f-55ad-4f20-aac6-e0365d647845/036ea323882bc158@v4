@tailwind base;
@tailwind components;
@tailwind utilities;

/* k3rn.labs Global Styles */
body {
  font-family: var(--font-sans);
  font-size: var(--fs-body);
  line-height: var(--lh-body);
  font-weight: var(--fw-body);
  color: var(--text);
  margin: 0;
  padding: 0;
  /* Premium background: radial gradient + base color */
  background:
    radial-gradient(1200px 600px at 50% 0%, var(--overlay-primary-6), transparent 65%),
    var(--bg);
  background-attachment: fixed;
}

/* Layout Shell: Blur Topbar */
.topbar {
  position: sticky;
  top: 0;
  z-index: 50;
  background: var(--overlay-white);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border-soft);
}

.topbar-container {
  max-width: 1180px;
  margin: 0 auto;
  padding: 0 var(--sp-6);
}

.topbar-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 64px;
}

.topbar-left {
  display: flex;
  align-items: center;
  gap: var(--sp-7);
}

.topbar-logo {
  font-size: 18px;
  font-weight: 600;
  color: var(--text);
  text-decoration: none;
  letter-spacing: -0.02em;
}

.topbar-nav {
  display: flex;
  gap: var(--sp-2);
}

.nav-link {
  display: inline-flex;
  align-items: center;
  height: 36px;
  padding: 0 var(--sp-3);
  border-radius: var(--r-input);
  font-size: 14px;
  font-weight: 520;
  color: var(--text-2);
  text-decoration: none;
  transition: all 0.18s ease;
}

.nav-link:hover {
  background: var(--overlay-dark-4);
  color: var(--text);
}

.nav-link.active {
  background: var(--overlay-dark-8);
  color: var(--text);
  font-weight: 560;
}

/* ========================================
   UI Primitives (k3rn.labs)
   ======================================== */

/* Button */
.btn {
  height: 44px;
  padding: 0 18px;
  border-radius: var(--r-btn);
  border: 1px solid transparent;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: var(--sp-2);
  font-size: 14px;
  font-weight: 560;
  transition: all 0.18s ease;
  cursor: pointer;
  text-decoration: none;
}

.btn.primary {
  background: var(--primary-900);
  color: var(--white);
}

.btn.primary:hover {
  background: var(--primary-850);
}

.btn.dark {
  background: var(--ink-900);
  color: var(--white);
}

.btn.dark:hover {
  background: var(--ink-700);
}

.btn.secondary {
  background: var(--surface);
  border-color: var(--border-soft);
  color: var(--text);
}

.btn.secondary:hover {
  background: var(--bg-2);
  border-color: var(--border);
}

.btn:focus-visible {
  outline: none;
  box-shadow: 0 0 0 3px var(--focus);
}

.btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

/* Input */
.input-wrapper {
  display: flex;
  flex-direction: column;
  gap: var(--sp-2);
}

.input-label {
  font-size: var(--fs-small);
  font-weight: 560;
  color: var(--text);
}

.input {
  height: 44px;
  padding: 0 var(--sp-4);
  border-radius: var(--r-input);
  border: 1px solid var(--border);
  background: var(--surface);
  font-size: var(--fs-body);
  color: var(--text);
  transition: all 0.18s ease;
}

.input::placeholder {
  color: var(--muted);
}

.input:focus {
  outline: none;
  border-color: var(--primary-700);
  box-shadow: 0 0 0 3px var(--focus);
}

.input.input-error {
  border-color: var(--error-500);
}

.input-error-text {
  font-size: var(--fs-small);
  color: var(--error-500);
}

/* Badge / Pill */
.pill {
  display: inline-flex;
  align-items: center;
  height: 28px;
  padding: 0 10px;
  border-radius: var(--r-pill);
  border: 1px solid var(--border-soft);
  background: var(--surface);
  font-size: 12px;
  font-weight: 520;
  color: var(--text-2);
}

.pill-success {
  background: var(--overlay-primary-6);
  border-color: var(--overlay-primary-12);
  color: var(--primary-700);
}

/* Card */
.card {
  background: var(--surface);
  border: 1px solid var(--border-soft);
  border-radius: var(--r-card);
  padding: var(--sp-5);
  box-shadow: var(--sh-xs);
}

.card-clickable {
  cursor: pointer;
  transition: all 0.18s ease;
}

.card-clickable:hover {
  box-shadow: var(--sh-sm);
  border-color: var(--border);
}

/* Typography */
.h1 {
  font-size: var(--fs-h1);
  line-height: var(--lh-h1);
  font-weight: var(--fw-h1);
  letter-spacing: var(--ls-h1);
  color: var(--text);
  margin: 0;
}

.h2 {
  font-size: var(--fs-h2);
  line-height: var(--lh-h2);
  font-weight: var(--fw-h2);
  letter-spacing: var(--ls-h2);
  color: var(--text);
  margin: 0;
}

.h3 {
  font-size: var(--fs-h3);
  line-height: var(--lh-h3);
  font-weight: var(--fw-h3);
  letter-spacing: var(--ls-h3);
  color: var(--text);
  margin: 0;
}

.kicker {
  font-size: var(--fs-kicker);
  line-height: var(--lh-kicker);
  font-weight: var(--fw-kicker);
  letter-spacing: var(--ls-kicker);
  text-transform: uppercase;
  color: var(--muted);
}

.text-small {
  font-size: var(--fs-small);
  line-height: var(--lh-small);
  color: var(--text);
}

.text-muted {
  color: var(--text-2);
}

/* ========================================
   Page Layout Utilities
   ======================================== */

.page-container {
  min-height: 100vh;
}

.page-header {
  background: var(--surface);
  border-bottom: 1px solid var(--divider);
}

.container {
  max-width: 1180px;
  margin: 0 auto;
  padding: var(--sp-6) var(--sp-6);
}

.page-layout {
  margin-top: var(--sp-6);
  display: flex;
  gap: var(--sp-6);
}

.page-main {
  flex: 1;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--sp-8) 0;
}

.spinner {
  display: inline-block;
  width: 32px;
  height: 32px;
  border: 2px solid var(--divider);
  border-top-color: var(--primary-700);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.skill-link {
  font-size: 18px;
  font-weight: 600;
  color: var(--text);
  text-decoration: none;
  letter-spacing: -0.01em;
  transition: color 0.18s ease;
}

.skill-link:hover {
  color: var(--primary-700);
}

/* Stack Panel */
.stack-panel {
  width: 320px;
  position: sticky;
  top: calc(64px + var(--sp-6));
  align-self: flex-start;
}

.stack-items {
  display: flex;
  flex-direction: column;
  gap: var(--sp-2);
  max-height: 400px;
  overflow-y: auto;
}

.stack-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--sp-2);
  background: var(--bg-2);
  border-radius: var(--r-input);
  border: 1px solid var(--border-soft);
}

.stack-reorder {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.reorder-btn {
  font-size: 10px;
  color: var(--muted);
  background: none;
  border: none;
  cursor: pointer;
  padding: 2px;
  transition: color 0.18s ease;
}

.reorder-btn:hover:not(:disabled) {
  color: var(--text);
}

.reorder-btn:disabled {
  opacity: 0.3;
  cursor: not-allowed;
}

.remove-btn {
  color: var(--error-500);
  background: none;
  border: none;
  cursor: pointer;
  font-size: 14px;
  padding: 4px;
  transition: color 0.18s ease;
}

.remove-btn:hover {
  color: var(--error-900);
}

.source-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--sp-2);
  background: var(--bg-2);
  border-radius: var(--r-input);
  border: 1px solid var(--border-soft);
}

/* Stats Grid */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--sp-4);
}

.stat-card {
  text-align: center;
}

.stat-value {
  font-size: 32px;
  font-weight: 700;
  line-height: 1.2;
  color: var(--text);
  letter-spacing: -0.02em;
}

/* TicketPack Components */
.phase-item {
  border-left: 3px solid var(--primary-700);
  padding-left: var(--sp-4);
}

.skill-selected-card {
  padding: var(--sp-3);
  background: var(--overlay-primary-4);
  border: 1px solid var(--overlay-primary-12);
  border-radius: var(--r-input);
}

.skills-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--sp-3);
}

.skill-rec-card {
  padding: var(--sp-3);
  background: var(--bg-2);
  border: 1px solid var(--border-soft);
  border-radius: var(--r-input);
}

.export-actions-card {
  background: var(--overlay-primary-2);
  border-color: var(--overlay-primary-8);
}

.ticket-card {
  border: 1px solid var(--border);
  border-radius: var(--r-card);
  overflow: hidden;
}

.ticket-header {
  padding: var(--sp-4);
  background: var(--bg-2);
  cursor: pointer;
  transition: background 0.18s ease;
}

.ticket-header:hover {
  background: var(--bg);
}

.ticket-details {
  padding: var(--sp-4);
  border-top: 1px solid var(--divider);
  background: var(--surface);
  display: flex;
  flex-direction: column;
  gap: var(--sp-3);
}

.risk-card {
  background: var(--error-50);
  padding: var(--sp-2);
  border-radius: var(--r-input);
  margin-bottom: var(--sp-1);
}

