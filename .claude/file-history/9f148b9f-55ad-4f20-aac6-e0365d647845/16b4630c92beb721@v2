import Database from 'better-sqlite3';
import path from 'path';

export interface Skill {
  id: number;
  name: string;
  category: string;
  description: string;
  tags_json: string; // JSON array
  triggers_json: string; // JSON array
}

export interface SkillCard {
  skill_id: number;
  use_when_json: string | null;
  avoid_when_json: string | null;
  inputs: string | null;
  outputs: string | null;
  activation: string | null;
  similar_json: string | null;
  diff_notes: string | null;
  risk_level: string | null;
}

export interface SkillWithCard extends Skill {
  card: SkillCard | null;
}

export interface SearchResult extends Skill {
  rank: number;
  matched_fields: string;
  score: number;
}

const DB_PATH = path.join(process.cwd(), 'data', 'skills.db');

let db: Database.Database | null = null;

export function getDb(): Database.Database {
  if (!db) {
    db = new Database(DB_PATH);
    db.pragma('journal_mode = WAL');
  }
  return db;
}

export function closeDb() {
  if (db) {
    db.close();
    db = null;
  }
}

export function initSchema(database: Database.Database) {
  // Create skills table
  database.exec(`
    CREATE TABLE IF NOT EXISTS skills (
      id INTEGER PRIMARY KEY AUTOINCREMENT,
      name TEXT NOT NULL UNIQUE,
      category TEXT NOT NULL,
      description TEXT,
      tags_json TEXT,
      triggers_json TEXT
    )
  `);

  // Create skill_cards table
  database.exec(`
    CREATE TABLE IF NOT EXISTS skill_cards (
      skill_id INTEGER PRIMARY KEY REFERENCES skills(id) ON DELETE CASCADE,
      use_when_json TEXT,
      avoid_when_json TEXT,
      inputs TEXT,
      outputs TEXT,
      activation TEXT,
      similar_json TEXT,
      diff_notes TEXT,
      risk_level TEXT
    )
  `);

  // Create FTS5 virtual table (without external content for simplicity)
  database.exec(`
    CREATE VIRTUAL TABLE IF NOT EXISTS skills_fts USING fts5(
      name,
      description,
      triggers,
      tags
    )
  `);
}
