import { NextRequest, NextResponse } from 'next/server';
import { recommendSkills } from '@/lib/ticketpack/recommender';

export const dynamic = 'force-dynamic';

export async function POST(request: NextRequest) {
  try {
    const body = await request.json();
    const { brief, deliverable_type } = body;

    if (!brief || brief.length < 10) {
      return NextResponse.json({ skills: [] });
    }

    const skills = await recommendSkills(brief, deliverable_type || 'app', 8);

    return NextResponse.json({ skills });
  } catch (error) {
    console.error('Skill recommendation error:', error);
    return NextResponse.json({ error: 'Failed to recommend skills', skills: [] }, { status: 500 });
  }
}
