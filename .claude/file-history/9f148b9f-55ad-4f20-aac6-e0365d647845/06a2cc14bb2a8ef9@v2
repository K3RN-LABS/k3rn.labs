'use client';

import { useState } from 'react';
import { DELIVERABLE_TYPE_LABELS } from '@/lib/ticketpack/constants';

interface InputFormProps {
  onGenerate: (input: {
    brief: string;
    sources: Array<{ type: 'text' | 'url'; content: string }>;
    deliverable_type: string;
    project_name: string;
  }) => void;
  loading: boolean;
  error: string | null;
}

export default function InputForm({ onGenerate, loading, error }: InputFormProps) {
  const [brief, setBrief] = useState('');
  const [projectName, setProjectName] = useState('');
  const [deliverableType, setDeliverableType] = useState<string>('saas');
  const [sources, setSources] = useState<Array<{ type: 'text' | 'url'; content: string }>>([]);
  const [currentSource, setCurrentSource] = useState('');
  const [sourceType, setSourceType] = useState<'text' | 'url'>('text');

  const handleAddSource = () => {
    if (currentSource.trim()) {
      setSources([...sources, { type: sourceType, content: currentSource.trim() }]);
      setCurrentSource('');
    }
  };

  const handleRemoveSource = (index: number) => {
    setSources(sources.filter((_, i) => i !== index));
  };

  const handleSubmit = (e: React.FormEvent) => {
    e.preventDefault();
    onGenerate({
      brief,
      sources,
      deliverable_type: deliverableType,
      project_name: projectName || 'Mon Projet',
    });
  };

  const canSubmit = brief.trim().length >= 10 && !loading;

  return (
    <form onSubmit={handleSubmit} className="space-y-6">
      <div className="card">
        <h2 className="text-xl font-semibold text-gray-900 mb-4">
          1. Décrivez votre idée
        </h2>

        <div className="space-y-4">
          <div>
            <label className="block text-sm font-medium text-gray-700 mb-2">
              Nom du projet (optionnel)
            </label>
            <input
              type="text"
              className="input w-full"
              placeholder="Ex: Mon Application SaaS"
              value={projectName}
              onChange={(e) => setProjectName(e.target.value)}
            />
          </div>

          <div>
            <label className="block text-sm font-medium text-gray-700 mb-2">
              Brief / Idée *
            </label>
            <textarea
              className="input w-full"
              rows={8}
              placeholder="Décrivez votre projet, fonctionnalités souhaitées, contraintes... (minimum 10 caractères)"
              value={brief}
              onChange={(e) => setBrief(e.target.value)}
              required
            />
            <p className="text-sm text-gray-500 mt-1">
              {brief.length} caractère{brief.length > 1 ? 's' : ''}
              {brief.length < 10 && ' (minimum 10)'}
            </p>
          </div>

          <div>
            <label className="block text-sm font-medium text-gray-700 mb-2">
              Type de livrable *
            </label>
            <select
              className="input w-full"
              value={deliverableType}
              onChange={(e) => setDeliverableType(e.target.value)}
            >
              {Object.entries(DELIVERABLE_TYPE_LABELS).map(([value, label]) => (
                <option key={value} value={value}>
                  {label}
                </option>
              ))}
            </select>
          </div>
        </div>
      </div>

      <div className="card">
        <h2 className="text-xl font-semibold text-gray-900 mb-4">
          2. Sources additionnelles (optionnel)
        </h2>

        <div className="space-y-4">
          <div className="flex gap-2">
            <select
              className="input"
              value={sourceType}
              onChange={(e) => setSourceType(e.target.value as 'text' | 'url')}
            >
              <option value="text">Texte</option>
              <option value="url">URL</option>
            </select>

            <input
              type="text"
              className="input flex-1"
              placeholder={
                sourceType === 'url'
                  ? 'https://example.com/doc'
                  : 'Collez du texte ou des notes...'
              }
              value={currentSource}
              onChange={(e) => setCurrentSource(e.target.value)}
            />

            <button
              type="button"
              className="btn-secondary"
              onClick={handleAddSource}
              disabled={!currentSource.trim()}
            >
              Ajouter
            </button>
          </div>

          {sources.length > 0 && (
            <div className="space-y-2">
              <p className="text-sm font-medium text-gray-700">
                Sources ajoutées ({sources.length})
              </p>
              {sources.map((source, index) => (
                <div
                  key={index}
                  className="flex items-center justify-between p-2 bg-gray-50 rounded"
                >
                  <div className="flex-1">
                    <span className="text-xs font-medium text-gray-500 uppercase">
                      {source.type}
                    </span>
                    <p className="text-sm text-gray-900 truncate">
                      {source.content.slice(0, 100)}
                      {source.content.length > 100 && '...'}
                    </p>
                  </div>
                  <button
                    type="button"
                    className="text-red-600 hover:text-red-800 ml-2"
                    onClick={() => handleRemoveSource(index)}
                  >
                    ✕
                  </button>
                </div>
              ))}
            </div>
          )}
        </div>
      </div>

      {error && (
        <div className="card bg-red-50 border-red-200">
          <p className="text-red-800">
            <strong>Erreur:</strong> {error}
          </p>
        </div>
      )}

      <div className="flex justify-end">
        <button
          type="submit"
          className="btn-primary px-8 py-3 text-lg"
          disabled={!canSubmit}
        >
          {loading ? 'Génération en cours...' : 'Générer le Pack'}
        </button>
      </div>
    </form>
  );
}
