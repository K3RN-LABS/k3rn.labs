'use client';

interface FiltersProps {
  metadata: any;
  category: string;
  setCategory: (category: string) => void;
  tags: string;
  setTags: (tags: string) => void;
  hasCard: boolean;
  setHasCard: (hasCard: boolean) => void;
}

export default function Filters({
  metadata,
  category,
  setCategory,
  tags,
  setTags,
  hasCard,
  setHasCard,
}: FiltersProps) {
  if (!metadata) {
    return <div className="card">Loading filters...</div>;
  }

  return (
    <div className="card">
      <h3 className="font-semibold text-gray-900 mb-4">Filters</h3>

      <div className="space-y-4">
        <div>
          <label className="block text-sm font-medium text-gray-700 mb-1">
            Category
          </label>
          <select
            className="input w-full"
            value={category}
            onChange={(e) => setCategory(e.target.value)}
          >
            <option value="">All Categories</option>
            {metadata.categories.map((cat: any) => (
              <option key={cat.category} value={cat.category}>
                {cat.category} ({cat.count})
              </option>
            ))}
          </select>
        </div>

        <div>
          <label className="block text-sm font-medium text-gray-700 mb-1">
            Tags
          </label>
          <input
            type="text"
            className="input w-full"
            placeholder="Filter by tag..."
            value={tags}
            onChange={(e) => setTags(e.target.value)}
          />
          <div className="mt-2 flex flex-wrap gap-1">
            {metadata.tags.slice(0, 20).map((tag: any) => (
              <button
                key={tag.tag}
                className="px-2 py-1 text-xs bg-gray-100 hover:bg-gray-200 rounded"
                onClick={() => setTags(tag.tag)}
              >
                {tag.tag} ({tag.count})
              </button>
            ))}
          </div>
        </div>

        <div className="flex items-center">
          <input
            type="checkbox"
            id="hasCard"
            className="mr-2"
            checked={hasCard}
            onChange={(e) => setHasCard(e.target.checked)}
          />
          <label htmlFor="hasCard" className="text-sm text-gray-700">
            Only show skills with enriched Skill Cards
          </label>
        </div>
      </div>
    </div>
  );
}
