export interface ExternalSkillRef {
  id: number;
  source_id: number;
  slug: string;
  name: string;
  description: string | null;
  tags_json: string | null;
  triggers_json: string | null;
  license: string | null;
  repo_url: string;
  version: string | null;
  sha: string | null;
  last_seen_at: string;
  created_at: string;
}

export interface UnifiedSearchResult {
  id: number;
  name: string;
  category: string;
  description: string;
  rank: number;
  score: number;
  source_type: 'local' | 'external';
  source_name?: string;
  repo_url?: string;
  license?: string;
}

const DB_PATH = path.join(process.cwd(), 'data', 'skills.db');

let db: Database.Database | null = null;

export function getDb(): Database.Database {
  if (!db) {
    db = new Database(DB_PATH);
    db.pragma('journal_mode = WAL');
  }
  return db;
}

export function closeDb() {
  if (db) {
    db.close();
    db = null;
  }
}

/**
 * Search external skills with FTS5
 */
export function searchExternalSkills(
  database: Database.Database,
  query: string,
  limit: number = 50
): UnifiedSearchResult[] {
  try {
    const ftsSql = `
      SELECT
        e.id,
        e.name,
        'external' as category,
        e.description,
        fts.rank as score,
        'external' as source_type,
        src.name as source_name,
        e.repo_url,
        e.license
      FROM external_skills_fts fts
      JOIN external_skill_refs e ON e.name = fts.name
      JOIN skill_sources src ON src.id = e.source_id
      WHERE fts MATCH ? AND src.enabled = 1
      ORDER BY fts.rank
      LIMIT ?
    `;

    const results = database.prepare(ftsSql).all(query, limit) as any[];

    return results.map((r, index) => ({
      id: r.id,
      name: r.name,
      category: r.category,
      description: r.description || '',
      rank: index + 1,
      score: r.score || 0,
      source_type: 'external' as const,
      source_name: r.source_name,
      repo_url: r.repo_url,
      license: r.license,
    }));
  } catch (error) {
    console.warn('External skills FTS search failed:', error);
    return [];
  }
}

export function initSchema(database: Database.Database) {
  // Create skills table
  database.exec(`
    CREATE TABLE IF NOT EXISTS skills (
      id INTEGER PRIMARY KEY AUTOINCREMENT,
      name TEXT NOT NULL UNIQUE,
      category TEXT NOT NULL,
      description TEXT,
      tags_json TEXT,
      triggers_json TEXT
    )
  `);

  // Create skill_cards table
  database.exec(`
    CREATE TABLE IF NOT EXISTS skill_cards (
      skill_id INTEGER PRIMARY KEY REFERENCES skills(id) ON DELETE CASCADE,
      use_when_json TEXT,
      avoid_when_json TEXT,
      inputs TEXT,
      outputs TEXT,
      activation TEXT,
      similar_json TEXT,
      diff_notes TEXT,
      risk_level TEXT
    )
  `);

  // Create FTS5 virtual table (without external content for simplicity)
  database.exec(`
    CREATE VIRTUAL TABLE IF NOT EXISTS skills_fts USING fts5(
      name,
      description,
      triggers,
      tags
    )
  `);

  // Create skill_sources table for external skill repositories
  database.exec(`
    CREATE TABLE IF NOT EXISTS skill_sources (
      id INTEGER PRIMARY KEY AUTOINCREMENT,
      name TEXT NOT NULL UNIQUE,
      type TEXT NOT NULL CHECK(type IN ('local', 'github')),
      config_json TEXT NOT NULL DEFAULT '{}',
      terms_url TEXT,
      enabled INTEGER NOT NULL DEFAULT 1,
      last_sync_at TEXT,
      created_at TEXT NOT NULL DEFAULT (datetime('now'))
    )
  `);

  // Create external_skill_refs table for indexed external skills
  database.exec(`
    CREATE TABLE IF NOT EXISTS external_skill_refs (
      id INTEGER PRIMARY KEY AUTOINCREMENT,
      source_id INTEGER NOT NULL REFERENCES skill_sources(id) ON DELETE CASCADE,
      slug TEXT NOT NULL,
      name TEXT NOT NULL,
      description TEXT,
      tags_json TEXT,
      triggers_json TEXT,
      license TEXT,
      repo_url TEXT NOT NULL,
      version TEXT,
      sha TEXT,
      last_seen_at TEXT NOT NULL DEFAULT (datetime('now')),
      created_at TEXT NOT NULL DEFAULT (datetime('now')),
      UNIQUE(source_id, slug)
    )
  `);

  // Create index for external skills search
  database.exec(`
    CREATE INDEX IF NOT EXISTS idx_external_skill_refs_source
    ON external_skill_refs(source_id)
  `);

  database.exec(`
    CREATE INDEX IF NOT EXISTS idx_external_skill_refs_name
    ON external_skill_refs(name)
  `);

  // Create FTS5 for external skills
  database.exec(`
    CREATE VIRTUAL TABLE IF NOT EXISTS external_skills_fts USING fts5(
      name,
      description,
      triggers,
      tags
    )
  `);

  // Initialize local source if not exists
  database.exec(`
    INSERT OR IGNORE INTO skill_sources (id, name, type, config_json, enabled)
    VALUES (1, 'Local (.agent/skills)', 'local', '{}', 1)
  `);
}
