import Database from 'better-sqlite3';
import path from 'path';

export interface Skill {
  id: number;
  name: string;
  category: string;
  description: string;
  tags_json: string; // JSON array
  triggers_json: string; // JSON array
}

export interface SkillCard {
  skill_id: number;
  use_when_json: string | null;
  avoid_when_json: string | null;
  inputs: string | null;
  outputs: string | null;
  activation: string | null;
  similar_json: string | null;
  diff_notes: string | null;
  risk_level: string | null;
}

export interface SkillWithCard extends Skill {
  card: SkillCard | null;
}

export interface SearchResult extends Skill {
  rank: number;
  matched_fields: string;
  score: number;
}

export interface SkillSource {
  id: number;
  name: string;
  type: 'local' | 'github';
  config_json: string; // { repo_url?, branch?, patterns? }
  terms_url: string | null;
  enabled: number; // 0/1 boolean
  last_sync_at: string | null; // ISO timestamp
