"use client";

import { useState, useEffect } from "react";
import { cn } from "@/lib/utils";
import { Check } from "lucide-react";
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { DecisionBadge } from "@/components/ui/decision-badge";
import {
    Dialog,
    DialogContent,
    DialogHeader,
    DialogTitle,
    DialogFooter,
} from "@/components/ui/dialog";
import { useLanguageStore } from "@/store/language-store";

const COLOR_PRESETS = [
    { hex: "#6B7280", label: "Gray" },
    { hex: "#F75105", label: "Orange" },
    { hex: "#3B82F6", label: "Blue" },
    { hex: "#8B5CF6", label: "Violet" },
    { hex: "#10B981", label: "Emerald" },
    { hex: "#F59E0B", label: "Amber" },
    { hex: "#EF4444", label: "Red" },
    { hex: "#EC4899", label: "Pink" },
];

interface DossierProject {
    id: string;
    title?: string;
    text: string;
    description?: string;
    color?: string;
    globalScore?: number;
    recommendation?: string;
    viabilityScore?: number;
    classification?: string;
}

interface DossierSettingsDialogProps {
    project: DossierProject;
    open: boolean;
    onOpenChange: (open: boolean) => void;
    onSave: (updates: { title?: string; description?: string; color?: string }) => void;
}

export function DossierSettingsDialog({ project, open, onOpenChange, onSave }: DossierSettingsDialogProps) {
    const { t } = useLanguageStore();
    const d = (t?.workspace as any)?.dossiers;

    const [title, setTitle] = useState(project.title || project.text || "");
    const [description, setDescription] = useState(project.description || "");
    const [color, setColor] = useState(project.color || "#6B7280");

    useEffect(() => {
        setTitle(project.title || project.text || "");
        setDescription(project.description || "");
        setColor(project.color || "#6B7280");
    }, [project]);

    const score = project.globalScore ?? project.viabilityScore;
    const decision = project.recommendation ?? project.classification ?? "DRAFT";

    function handleSave() {
        onSave({ title, description, color });
        onOpenChange(false);
    }

    return (
        <Dialog open={open} onOpenChange={onOpenChange}>
            <DialogContent className="bg-[#1A1A1A] border-white/10 rounded-2xl max-w-md">
                <DialogHeader>
                    <DialogTitle className="text-white text-lg font-medium">
                        {d?.settingsTitle || "Dossier Settings"}
                    </DialogTitle>
                </DialogHeader>

                <div className="space-y-5 py-2">
                    {/* Title */}
                    <div className="space-y-2">
                        <label className="text-xs text-[#D2D3D4] uppercase tracking-widest font-medium">
                            {d?.titleLabel || "Title"}
                        </label>
                        <Input
                            value={title}
                            onChange={(e) => setTitle(e.target.value)}
                            className="h-10 bg-[#22242B] border-white/10 text-white rounded-lg focus:border-[#F75105]/50 focus:ring-[#F75105]/20"
                        />
                    </div>

                    {/* Description */}
                    <div className="space-y-2">
                        <label className="text-xs text-[#D2D3D4] uppercase tracking-widest font-medium">
                            {d?.descriptionLabel || "Description"}
                        </label>
                        <textarea
                            value={description}
                            onChange={(e) => setDescription(e.target.value)}
                            placeholder={d?.descriptionPlaceholder || "Add a description..."}
                            rows={3}
                            className="w-full bg-[#22242B] border border-white/10 text-white rounded-lg px-3 py-2 text-sm placeholder:text-[#5D5C5B] focus:border-[#F75105]/50 focus:ring-1 focus:ring-[#F75105]/20 focus:outline-none resize-none"
                        />
                    </div>

                    {/* Score & Decision (read-only) */}
                    {score !== undefined && (
                        <div className="space-y-2">
                            <label className="text-xs text-[#D2D3D4] uppercase tracking-widest font-medium">
                                {d?.scoreLabel || "Score"}
                            </label>
                            <div className="flex items-center gap-4 p-3 bg-[#22242B] rounded-lg border border-white/5">
                                <span className={cn(
                                    "text-2xl font-light tabular-nums",
                                    score >= 70 ? "text-white" : "text-[#D2D3D4]"
                                )}>
                                    {score}
                                </span>
                                <DecisionBadge decision={decision} />
                            </div>
                        </div>
                    )}

                    {/* Color Picker */}
                    <div className="space-y-2">
                        <label className="text-xs text-[#D2D3D4] uppercase tracking-widest font-medium">
                            {d?.colorLabel || "Color"}
                        </label>
                        <div className="flex gap-2">
                            {COLOR_PRESETS.map((preset) => (
                                <button
                                    key={preset.hex}
                                    onClick={() => setColor(preset.hex)}
                                    className={cn(
                                        "w-8 h-8 rounded-full border-2 flex items-center justify-center transition-all",
                                        color === preset.hex
                                            ? "border-white scale-110"
                                            : "border-transparent hover:border-white/30 hover:scale-105"
                                    )}
                                    style={{ backgroundColor: preset.hex }}
                                    title={preset.label}
                                >
                                    {color === preset.hex && <Check className="w-4 h-4 text-white" />}
                                </button>
                            ))}
                        </div>
                    </div>
                </div>

                <DialogFooter>
                    <Button
                        variant="ghost"
                        onClick={() => onOpenChange(false)}
                        className="text-[#D2D3D4] hover:text-white hover:bg-white/5"
                    >
                        {d?.cancel || "Cancel"}
                    </Button>
                    <Button
                        onClick={handleSave}
                        className="bg-[#F75105] hover:bg-[#F78E21] text-white"
                    >
                        {d?.save || "Save"}
                    </Button>
                </DialogFooter>
            </DialogContent>
        </Dialog>
    );
}
