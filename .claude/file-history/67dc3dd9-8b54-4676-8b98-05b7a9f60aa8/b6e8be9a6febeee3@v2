"use client";

import { useState, useEffect } from "react";
import { cn } from "@/lib/utils";
import { ArrowLeft, ArrowRight, CheckCircle2, SkipForward, Loader2, TrendingUp, TrendingDown, Minus } from "lucide-react";
import { Button } from "@/components/ui/button";
import { toast } from "sonner";
import { useLanguageStore } from "@/store/language-store";
import { DecisionBadge } from "@/components/ui/decision-badge";
import type { AnalysisAxes, AnalysisScores, AnalysisDecision, EnrichmentQuestion, EnrichmentResponse } from "@/lib/analysis/types";

interface EnrichmentFlowProps {
    analysis: AnalysisAxes;
    scores: AnalysisScores;
    decision: AnalysisDecision;
    ideaId: string;
    ideaSummary: string;
    onComplete: (updatedResult: any) => void;
    onCancel: () => void;
}

type FlowState = "loading" | "questions" | "submitting" | "result";

export function EnrichmentFlow({ analysis, scores, decision, ideaId, ideaSummary, onComplete, onCancel }: EnrichmentFlowProps) {
    const { t } = useLanguageStore();
    const [state, setState] = useState<FlowState>("loading");
    const [questions, setQuestions] = useState<EnrichmentQuestion[]>([]);
    const [enrichmentId, setEnrichmentId] = useState<string>("");
    const [currentIndex, setCurrentIndex] = useState(0);
    const [responses, setResponses] = useState<Map<string, EnrichmentResponse>>(new Map());
    const [selectedOptions, setSelectedOptions] = useState<Set<string>>(new Set());
    const [recalcResult, setRecalcResult] = useState<any>(null);

    // Generate questions on mount
    useEffect(() => {
        generateQuestions();
        // eslint-disable-next-line react-hooks/exhaustive-deps
    }, []);

    async function generateQuestions() {
        setState("loading");
        try {
            const res = await fetch("/api/enrichment", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    action: "generate",
                    idea_id: ideaId,
                    idea_summary: ideaSummary,
                    analysis,
                    scores: { global_score: scores.global_score },
                    decision: {
                        recommendation: decision.recommendation,
                        confidence_level: decision.confidence_level,
                    },
                }),
            });

            const data = await res.json();
            if (!res.ok) throw new Error(data.error?.message || "Failed to generate questions");

            if (!data.required || !data.questions?.length) {
                toast.info(t?.analysis?.enrichment?.notNeeded || "No enrichment needed");
                onCancel();
                return;
            }

            setEnrichmentId(data.enrichment_id);
            setQuestions(data.questions);
            setState("questions");
        } catch (error: any) {
            console.error("Enrichment generation failed:", error);
            toast.error(t?.analysis?.enrichment?.generateFailed || "Could not generate questions");
            onCancel();
        }
    }

    function handleSelectOption(optionId: string, isMulti: boolean) {
        setSelectedOptions((prev) => {
            const next = new Set(prev);
            if (isMulti) {
                if (next.has(optionId)) next.delete(optionId);
                else next.add(optionId);
            } else {
                next.clear();
                next.add(optionId);
            }
            return next;
        });
    }

    function confirmAnswer() {
        const question = questions[currentIndex];
        const response: EnrichmentResponse = {
            question_id: question.question_id,
            status: "completed",
            selected_option_ids: Array.from(selectedOptions),
        };
        setResponses((prev) => new Map(prev).set(question.question_id, response));
        advance();
    }

    function skipQuestion() {
        const question = questions[currentIndex];
        const response: EnrichmentResponse = {
            question_id: question.question_id,
            status: "skipped",
        };
        setResponses((prev) => new Map(prev).set(question.question_id, response));
        advance();
    }

    function advance() {
        setSelectedOptions(new Set());
        if (currentIndex < questions.length - 1) {
            setCurrentIndex(currentIndex + 1);
        } else {
            submitResponses();
        }
    }

    async function submitResponses() {
        setState("submitting");
        try {
            const allResponses = Array.from(responses.values());
            // Add current if not yet saved
            const currentQ = questions[currentIndex];
            if (!responses.has(currentQ.question_id)) {
                allResponses.push({
                    question_id: currentQ.question_id,
                    status: "skipped",
                });
            }

            const res = await fetch("/api/enrichment", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    action: "submit",
                    enrichment_id: enrichmentId,
                    idea_id: ideaId,
                    analysis,
                    scores: { global_score: scores.global_score },
                    decision: { confidence_level: decision.confidence_level },
                    questions: questions.map((q) => ({
                        question_id: q.question_id,
                        axis: q.axis,
                        options: q.options.map((o) => ({ id: o.id, score_adjustment: o.score_adjustment })),
                    })),
                    responses: allResponses,
                }),
            });

            const data = await res.json();
            if (!res.ok) throw new Error(data.error?.message || "Failed to submit");

            setRecalcResult(data);
            setState("result");
        } catch (error: any) {
            console.error("Enrichment submission failed:", error);
            toast.error(t?.analysis?.enrichment?.submitFailed || "Could not submit answers");
            setState("questions");
        }
    }

    if (state === "loading" || state === "submitting") {
        return (
            <div className="bg-[#2F323A] rounded-xl shadow-2xl p-12 border border-white/5 flex flex-col items-center gap-6 min-h-[300px] justify-center">
                <Loader2 className="w-10 h-10 text-[#F75105] animate-spin" />
                <p className="text-gray-400 text-sm uppercase tracking-widest">
                    {state === "loading"
                        ? (t?.analysis?.enrichment?.generating || "Generating questions...")
                        : (t?.analysis?.enrichment?.submitting || "Recalculating scores...")
                    }
                </p>
            </div>
        );
    }

    if (state === "result" && recalcResult) {
        const scoresBefore = recalcResult.scores_before || {};
        const scoresAfter = recalcResult.scores_after || {};
        const globalBefore = scoresBefore.global ?? scores.global_score;
        const globalAfter = scoresAfter.global ?? globalBefore;
        const diff = globalAfter - globalBefore;

        return (
            <div className="bg-[#2F323A] rounded-xl shadow-2xl border-0 overflow-hidden ring-1 ring-white/5 animate-in zoom-in-95 duration-500">
                <div className="p-8 space-y-8">
                    <h3 className="text-lg font-medium text-white text-center uppercase tracking-widest">
                        {t?.analysis?.enrichment?.resultsTitle || "Enrichment Results"}
                    </h3>

                    {/* Score Comparison */}
                    <div className="flex items-center justify-center gap-8">
                        <div className="text-center">
                            <span className="text-[10px] text-gray-500 uppercase tracking-widest block mb-1">
                                {t?.analysis?.enrichment?.before || "Before"}
                            </span>
                            <span className="text-4xl font-bold text-gray-400">{globalBefore}</span>
                        </div>
                        <ArrowRight className="w-6 h-6 text-[#F75105]" />
                        <div className="text-center">
                            <span className="text-[10px] text-gray-500 uppercase tracking-widest block mb-1">
                                {t?.analysis?.enrichment?.after || "After"}
                            </span>
                            <span className={cn("text-4xl font-bold", globalAfter >= 70 ? "text-white" : "text-gray-400")}>
                                {globalAfter}
                            </span>
                        </div>
                        <div className={cn(
                            "flex items-center gap-1 text-sm font-bold",
                            diff > 0 ? "text-emerald-400" : diff < 0 ? "text-red-400" : "text-gray-500"
                        )}>
                            {diff > 0 ? <TrendingUp className="w-4 h-4" /> : diff < 0 ? <TrendingDown className="w-4 h-4" /> : <Minus className="w-4 h-4" />}
                            {diff > 0 ? "+" : ""}{diff}
                        </div>
                    </div>

                    {/* Decision Comparison */}
                    <div className="flex items-center justify-center gap-6">
                        <DecisionBadge decision={recalcResult.decision_before?.recommendation || decision.recommendation} />
                        <ArrowRight className="w-4 h-4 text-gray-500" />
                        <DecisionBadge decision={recalcResult.decision_after?.recommendation || decision.recommendation} />
                    </div>

                    {/* Axis Changes */}
                    {recalcResult.adjustments?.length > 0 && (
                        <div className="space-y-2 max-w-md mx-auto">
                            {recalcResult.adjustments.map((adj: any, i: number) => (
                                <div key={i} className="flex items-center justify-between text-sm px-4 py-2 bg-[#22242B]/50 rounded-lg">
                                    <span className="text-gray-400 capitalize">{adj.axis.replace("_", " ")}</span>
                                    <span className={cn(
                                        "font-mono font-bold",
                                        adj.adjustment > 0 ? "text-emerald-400" : adj.adjustment < 0 ? "text-red-400" : "text-gray-500"
                                    )}>
                                        {adj.adjustment > 0 ? "+" : ""}{adj.adjustment}
                                    </span>
                                </div>
                            ))}
                        </div>
                    )}

                    <div className="flex justify-center pt-4">
                        <Button
                            onClick={() => onComplete(recalcResult)}
                            className="bg-[#F75105] hover:bg-[#F78E21] text-white font-medium shadow-lg px-8"
                        >
                            <CheckCircle2 className="w-4 h-4 mr-2" />
                            {t?.analysis?.enrichment?.apply || "Apply & Continue"}
                        </Button>
                    </div>
                </div>
            </div>
        );
    }

    // Questions state
    const question = questions[currentIndex];
    if (!question) return null;
    const isMulti = question.type === "multi_select";
    const progress = ((currentIndex + 1) / questions.length) * 100;

    return (
        <div className="bg-[#2F323A] rounded-xl shadow-2xl border-0 overflow-hidden ring-1 ring-white/5 animate-in zoom-in-95 duration-500">
            <div className="p-8 space-y-6">
                {/* Header */}
                <div className="flex items-center justify-between">
                    <button onClick={onCancel} className="text-gray-500 hover:text-white transition-colors flex items-center gap-2 text-sm">
                        <ArrowLeft className="w-4 h-4" />
                        {t?.analysis?.enrichment?.back || "Back to results"}
                    </button>
                    <span className="text-[10px] text-gray-500 uppercase tracking-widest">
                        {currentIndex + 1} / {questions.length}
                    </span>
                </div>

                {/* Progress */}
                <div className="w-full h-1 bg-[#3A3D45] rounded-full overflow-hidden">
                    <div className="h-full bg-[#F75105] transition-all duration-300" style={{ width: `${progress}%` }} />
                </div>

                {/* Axis Tag */}
                <div className="flex items-center gap-2">
                    <span className="text-[10px] font-bold text-[#F75105] uppercase tracking-widest bg-[#F75105]/10 px-3 py-1 rounded-full border border-[#F75105]/20">
                        {question.axis.replace("_", " ")}
                    </span>
                    {isMulti && (
                        <span className="text-[10px] text-gray-500 uppercase tracking-wider">
                            {t?.analysis?.enrichment?.multiSelect || "Select multiple"}
                        </span>
                    )}
                </div>

                {/* Question */}
                <h3 className="text-xl font-medium text-white leading-relaxed">
                    {question.prompt}
                </h3>

                {/* Options */}
                <div className="space-y-3">
                    {question.options.map((option) => {
                        const selected = selectedOptions.has(option.id);
                        return (
                            <button
                                key={option.id}
                                onClick={() => handleSelectOption(option.id, isMulti)}
                                className={cn(
                                    "w-full text-left p-4 rounded-lg border transition-all duration-200",
                                    selected
                                        ? "bg-[#F75105]/10 border-[#F75105]/40 text-white"
                                        : "bg-[#22242B]/50 border-white/5 text-gray-300 hover:border-[#F75105]/20 hover:bg-[#22242B]"
                                )}
                            >
                                <div className="flex items-center gap-3">
                                    <div className={cn(
                                        "w-5 h-5 rounded-full border-2 flex items-center justify-center shrink-0 transition-colors",
                                        selected ? "border-[#F75105] bg-[#F75105]" : "border-gray-600"
                                    )}>
                                        {selected && <CheckCircle2 className="w-3 h-3 text-white" />}
                                    </div>
                                    <span className="text-sm">{option.label}</span>
                                </div>
                            </button>
                        );
                    })}
                </div>

                {/* Actions */}
                <div className="flex items-center justify-between pt-4 border-t border-[#3A3D45]">
                    {question.allow_skip && (
                        <Button
                            variant="ghost"
                            onClick={skipQuestion}
                            className="text-gray-500 hover:text-white"
                        >
                            <SkipForward className="w-4 h-4 mr-2" />
                            {t?.analysis?.enrichment?.skip || "Skip"}
                        </Button>
                    )}
                    <div className="flex-1" />
                    <Button
                        onClick={confirmAnswer}
                        disabled={selectedOptions.size === 0}
                        className={cn(
                            "px-6",
                            selectedOptions.size > 0
                                ? "bg-[#F75105] hover:bg-[#F78E21] text-white"
                                : "bg-[#3A3D45] text-gray-500 cursor-not-allowed"
                        )}
                    >
                        {currentIndex < questions.length - 1
                            ? (t?.analysis?.enrichment?.next || "Next")
                            : (t?.analysis?.enrichment?.submit || "Submit")
                        }
                        <ArrowRight className="w-4 h-4 ml-2" />
                    </Button>
                </div>
            </div>
        </div>
    );
}
