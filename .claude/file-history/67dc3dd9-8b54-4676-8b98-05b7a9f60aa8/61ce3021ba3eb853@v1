"use client";

import { cn } from "@/lib/utils";
import { Folder, Clock, Plus, MoreHorizontal, ArrowUpRight } from "lucide-react";
import { DecisionBadge } from "@/components/ui/decision-badge";
import { Button } from "@/components/ui/button";

interface Project {
    id: string;
    title?: string;
    text: string;
    description?: string;
    globalScore?: number;
    recommendation?: string;
    timestamp: string;
    color?: string;
}

interface ProCardProps {
    project?: Project;
    isNew?: boolean;
    onClick?: () => void;
    className?: string;
}

export function ProCard({ project, isNew, onClick, className }: ProCardProps) {
    if (isNew) {
        return (
            <div
                onClick={onClick}
                className={cn(
                    "group relative w-full aspect-[4/3] cursor-pointer bg-[#050505] border border-dashed border-[#333] hover:border-white/50 hover:bg-[#0A0A0A] rounded-xl transition-all duration-200 flex flex-col items-center justify-center gap-4",
                    className
                )}
            >
                <div className="h-12 w-12 rounded-full bg-[#111] border border-[#333] flex items-center justify-center group-hover:bg-white group-hover:text-black transition-all duration-300">
                    <Plus className="w-5 h-5 text-[#666] group-hover:text-black transition-colors" />
                </div>
                <span className="text-xs font-bold text-[#666] group-hover:text-white uppercase tracking-widest transition-colors">
                    Nouveau Projet
                </span>
            </div>
        );
    }

    if (!project) return null;

    const decision = project.recommendation || "DRAFT";
    const score = project.globalScore || 0;

    return (
        <div
            onClick={onClick}
            className={cn(
                "group relative w-full aspect-[4/3] cursor-pointer bg-[#050505] rounded-xl border border-[#222] overflow-hidden transition-all duration-300",
                "hover:border-[#444] hover:shadow-[0_4px_20px_-10px_rgba(255,255,255,0.1)] hover:-translate-y-0.5",
                className
            )}
        >
            <div className="p-6 flex flex-col h-full relative z-10">
                {/* Header */}
                <div className="flex justify-between items-start mb-4">
                    <DecisionBadge decision={decision} className="border border-[#333] bg-[#111] text-[10px] px-2 py-0.5" />
                    <Button variant="ghost" size="icon" className="h-6 w-6 text-[#444] hover:text-white -mr-2 -mt-2">
                        <MoreHorizontal className="w-4 h-4" />
                    </Button>
                </div>

                {/* Score (Absolute, Right) */}
                <div className="absolute top-6 right-6 text-right">
                    <div className="text-3xl font-bold text-white tracking-tighter">
                        {score}
                    </div>
                </div>

                {/* Body */}
                <div className="mt-2 mb-auto">
                    <h3 className="text-lg font-bold text-white leading-tight mb-2 line-clamp-2 group-hover:text-brand-primary transition-colors">
                        {project.title || project.text}
                    </h3>
                    <p className="text-xs text-[#888] line-clamp-3 leading-relaxed">
                        {project.description || "Aucune description disponible."}
                    </p>
                </div>

                {/* Footer */}
                <div className="mt-4 pt-4 border-t border-[#1A1A1A] flex items-center justify-between">
                    <span className="flex items-center gap-2 text-[10px] font-medium text-[#555] group-hover:text-[#888] transition-colors uppercase tracking-wider">
                        <Clock className="w-3 h-3" />
                        {new Date(project.timestamp).toLocaleDateString()}
                    </span>
                    <div className="opacity-0 group-hover:opacity-100 transition-opacity transform translate-x-2 group-hover:translate-x-0 duration-300">
                        <ArrowUpRight className="w-4 h-4 text-white" />
                    </div>
                </div>
            </div>
        </div>
    );
}
