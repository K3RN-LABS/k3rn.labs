"use client";

import { useState, ReactNode } from "react";
import Link from "next/link";
import { usePathname } from "next/navigation";
import { motion, AnimatePresence } from "framer-motion";
import { cn } from "@/lib/utils";

interface NavItem {
  name: string;
  href: string;
  icon: string;
  subitems?: NavItem[];
}

const navItems: NavItem[] = [
  { name: "Dashboard", href: "/dashboard", icon: "📊" },
  { name: "Cortex", href: "/cortex", icon: "🧠" },
  {
    name: "Labs",
    href: "/labs/k0",
    icon: "🔬",
    subitems: [
      { name: "k0", href: "/labs/k0", icon: "🎯" },
      { name: "Brainstorming", href: "/labs/brainstorming", icon: "💡" },
      { name: "System", href: "/labs/system", icon: "🏗️" },
      { name: "Execution", href: "/labs/execution", icon: "⚡" },
      { name: "Pitch", href: "/labs/pitch", icon: "🎤" },
    ],
  },
  { name: "Projects", href: "/projects", icon: "📦" },
  { name: "Settings", href: "/settings", icon: "⚙️" },
];

interface AppShellProps {
  children: ReactNode;
}

export default function AppShell({ children }: AppShellProps) {
  const [sidebarOpen, setSidebarOpen] = useState(false);
  const [labsExpanded, setLabsExpanded] = useState(true);
  const pathname = usePathname();

  const isActive = (href: string) => pathname === href;
  const isLabsActive = pathname?.startsWith("/labs");

  return (
    <div className="flex h-screen bg-bg-base">
      {/* Sidebar Desktop */}
      <aside className="hidden lg:flex lg:flex-col lg:w-64 border-r border-neutral-800 bg-bg-elevated">
        {/* Logo */}
        <div className="h-16 flex items-center gap-2 px-6 border-b border-neutral-800">
          <div className="w-8 h-8 rounded-lg bg-gradient-to-br from-orange-500 via-orange-600 to-orange-700 flex items-center justify-center">
            <span className="text-white font-bold text-sm">k3</span>
          </div>
          <span className="text-lg font-semibold text-fg-primary">k3rn</span>
        </div>

        {/* Navigation */}
        <nav className="flex-1 overflow-y-auto p-4 space-y-1">
          {navItems.map((item) => (
            <div key={item.name}>
              {/* Main nav item */}
              {item.subitems ? (
                <button
                  onClick={() => setLabsExpanded(!labsExpanded)}
                  className={cn(
                    "w-full flex items-center justify-between gap-3 px-3 py-2 rounded-lg text-sm transition-colors duration-200",
                    isLabsActive
                      ? "bg-orange-500/10 text-orange-500"
                      : "text-fg-secondary hover:text-fg-primary hover:bg-neutral-800/50"
                  )}
                >
                  <div className="flex items-center gap-3">
                    <span className="text-lg">{item.icon}</span>
                    <span className="font-medium">{item.name}</span>
                  </div>
                  <svg
                    className={cn(
                      "w-4 h-4 transition-transform duration-200",
                      labsExpanded && "rotate-180"
                    )}
                    fill="none"
                    strokeLinecap="round"
                    strokeLinejoin="round"
                    strokeWidth="2"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path d="M19 9l-7 7-7-7" />
                  </svg>
                </button>
              ) : (
                <Link
                  href={item.href}
                  className={cn(
                    "flex items-center gap-3 px-3 py-2 rounded-lg text-sm transition-colors duration-200",
                    isActive(item.href)
                      ? "bg-orange-500/10 text-orange-500"
                      : "text-fg-secondary hover:text-fg-primary hover:bg-neutral-800/50"
                  )}
                >
                  <span className="text-lg">{item.icon}</span>
                  <span className="font-medium">{item.name}</span>
                </Link>
              )}

              {/* Subitems */}
              {item.subitems && labsExpanded && (
                <motion.div
                  initial={{ height: 0, opacity: 0 }}
                  animate={{ height: "auto", opacity: 1 }}
                  exit={{ height: 0, opacity: 0 }}
                  transition={{ duration: 0.2 }}
                  className="ml-6 mt-1 space-y-1"
                >
                  {item.subitems.map((subitem) => (
                    <Link
                      key={subitem.name}
                      href={subitem.href}
                      className={cn(
                        "flex items-center gap-2 px-3 py-1.5 rounded-lg text-sm transition-colors duration-200",
                        isActive(subitem.href)
                          ? "bg-orange-500/10 text-orange-500"
                          : "text-fg-tertiary hover:text-fg-primary hover:bg-neutral-800/50"
                      )}
                    >
                      <span>{subitem.icon}</span>
                      <span>{subitem.name}</span>
                    </Link>
                  ))}
                </motion.div>
              )}
            </div>
          ))}
        </nav>

        {/* User Section */}
        <div className="p-4 border-t border-neutral-800">
          <div className="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-neutral-800/50 transition-colors duration-200 cursor-pointer">
            <div className="w-8 h-8 rounded-full bg-gradient-to-br from-orange-500 to-orange-700 flex items-center justify-center">
              <span className="text-white text-sm font-medium">U</span>
            </div>
            <div className="flex-1 min-w-0">
              <p className="text-sm font-medium text-fg-primary truncate">
                Utilisateur
              </p>
              <p className="text-xs text-fg-tertiary truncate">
                user@k3rn.app
              </p>
            </div>
          </div>
        </div>
      </aside>

      {/* Mobile Sidebar */}
      <AnimatePresence>
        {sidebarOpen && (
          <>
            {/* Backdrop */}
            <motion.div
              initial={{ opacity: 0 }}
              animate={{ opacity: 1 }}
              exit={{ opacity: 0 }}
              onClick={() => setSidebarOpen(false)}
              className="fixed inset-0 bg-black/50 z-40 lg:hidden"
            />

            {/* Sidebar */}
            <motion.aside
              initial={{ x: -280 }}
              animate={{ x: 0 }}
              exit={{ x: -280 }}
              transition={{ type: "spring", damping: 25, stiffness: 200 }}
              className="fixed inset-y-0 left-0 w-64 bg-bg-elevated border-r border-neutral-800 z-50 lg:hidden flex flex-col"
            >
              {/* Logo */}
              <div className="h-16 flex items-center gap-2 px-6 border-b border-neutral-800">
                <div className="w-8 h-8 rounded-lg bg-gradient-to-br from-orange-500 via-orange-600 to-orange-700 flex items-center justify-center">
                  <span className="text-white font-bold text-sm">k3</span>
                </div>
                <span className="text-lg font-semibold text-fg-primary">
                  k3rn
                </span>
              </div>

              {/* Navigation - same as desktop */}
              <nav className="flex-1 overflow-y-auto p-4 space-y-1">
                {navItems.map((item) => (
                  <div key={item.name}>
                    {item.subitems ? (
                      <button
                        onClick={() => setLabsExpanded(!labsExpanded)}
                        className={cn(
                          "w-full flex items-center justify-between gap-3 px-3 py-2 rounded-lg text-sm transition-colors duration-200",
                          isLabsActive
                            ? "bg-orange-500/10 text-orange-500"
                            : "text-fg-secondary hover:text-fg-primary hover:bg-neutral-800/50"
                        )}
                      >
                        <div className="flex items-center gap-3">
                          <span className="text-lg">{item.icon}</span>
                          <span className="font-medium">{item.name}</span>
                        </div>
                        <svg
                          className={cn(
                            "w-4 h-4 transition-transform duration-200",
                            labsExpanded && "rotate-180"
                          )}
                          fill="none"
                          strokeLinecap="round"
                          strokeLinejoin="round"
                          strokeWidth="2"
                          viewBox="0 0 24 24"
                          stroke="currentColor"
                        >
                          <path d="M19 9l-7 7-7-7" />
                        </svg>
                      </button>
                    ) : (
                      <Link
                        href={item.href}
                        onClick={() => setSidebarOpen(false)}
                        className={cn(
                          "flex items-center gap-3 px-3 py-2 rounded-lg text-sm transition-colors duration-200",
                          isActive(item.href)
                            ? "bg-orange-500/10 text-orange-500"
                            : "text-fg-secondary hover:text-fg-primary hover:bg-neutral-800/50"
                        )}
                      >
                        <span className="text-lg">{item.icon}</span>
                        <span className="font-medium">{item.name}</span>
                      </Link>
                    )}

                    {item.subitems && labsExpanded && (
                      <motion.div
                        initial={{ height: 0, opacity: 0 }}
                        animate={{ height: "auto", opacity: 1 }}
                        exit={{ height: 0, opacity: 0 }}
                        transition={{ duration: 0.2 }}
                        className="ml-6 mt-1 space-y-1"
                      >
                        {item.subitems.map((subitem) => (
                          <Link
                            key={subitem.name}
                            href={subitem.href}
                            onClick={() => setSidebarOpen(false)}
                            className={cn(
                              "flex items-center gap-2 px-3 py-1.5 rounded-lg text-sm transition-colors duration-200",
                              isActive(subitem.href)
                                ? "bg-orange-500/10 text-orange-500"
                                : "text-fg-tertiary hover:text-fg-primary hover:bg-neutral-800/50"
                            )}
                          >
                            <span>{subitem.icon}</span>
                            <span>{subitem.name}</span>
                          </Link>
                        ))}
                      </motion.div>
                    )}
                  </div>
                ))}
              </nav>
            </motion.aside>
          </>
        )}
      </AnimatePresence>

      {/* Main Content */}
      <div className="flex-1 flex flex-col overflow-hidden">
        {/* Topbar */}
        <header className="h-16 border-b border-neutral-800 bg-bg-elevated flex items-center justify-between px-4 lg:px-6">
          {/* Mobile menu button */}
          <button
            onClick={() => setSidebarOpen(true)}
            className="lg:hidden p-2 text-fg-secondary hover:text-fg-primary transition-colors duration-200"
          >
            <svg
              className="w-6 h-6"
              fill="none"
              strokeLinecap="round"
              strokeLinejoin="round"
              strokeWidth="2"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>

          {/* Page title */}
          <h1 className="text-lg font-semibold text-fg-primary">
            {navItems.find((item) => isActive(item.href))?.name ||
              navItems
                .find((item) => item.subitems)
                ?.subitems?.find((sub) => isActive(sub.href))?.name ||
              "k3rn"}
          </h1>

          {/* Right side actions */}
          <div className="flex items-center gap-2">
            <button className="p-2 text-fg-secondary hover:text-fg-primary transition-colors duration-200">
              <svg
                className="w-5 h-5"
                fill="none"
                strokeLinecap="round"
                strokeLinejoin="round"
                strokeWidth="2"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
              </svg>
            </button>
          </div>
        </header>

        {/* Page content */}
        <main className="flex-1 overflow-y-auto bg-bg-base">{children}</main>
      </div>
    </div>
  );
}
