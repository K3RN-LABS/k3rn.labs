// PRIORITY CONFLICTS (Section 5.2)
// ═══════════════════════════════════════════════════════════════════

describe('Priority conflicts', () => {
  test('KILL should override GO when blocking_gap exists', () => {
    // Score = 72 (GO range) but blocking_gap HIGH → KILL
    const analysis = makeAnalysis({
      market: { score: 80, blocking_gap: true },
    });
    const result = determineDecision(72, analysis, 'HIGH');
    expect(result.recommendation).toBe('KILL');
  });

  test('KILL should override EXPLORE when problem < 20', () => {
    const analysis = makeAnalysis({
      problem: { score: 10 },
    });
    const result = determineDecision(60, analysis, 'MEDIUM');
    expect(result.recommendation).toBe('KILL');
  });
});
