import { describe, test, expect } from 'vitest';
import {
  detectEnrichmentTriggers,
  prioritizeAxes,
  computeEnrichmentDecision,
  applyEnrichmentAdjustments,
  updateConfidenceLevel,
} from '@/lib/analysis/enrichment';
import type { AnalysisAxes } from '@/lib/analysis/types';
import type { AnalysisAxis } from '@/lib/analysis/constants';
import validOutput from '@/lib/analysis/fixtures/analysis-v1.0/outputs/valid-simple-idea-expected-output.json';

const fixtureAnalysis = validOutput.analysis as AnalysisAxes;

// ═══════════════════════════════════════════════════════════════════
// TRIGGER DETECTION
// ═══════════════════════════════════════════════════════════════════

describe('detectEnrichmentTriggers', () => {
  test('should detect feasibility < 40 in fixture', () => {
    // feasibility = 42, which is >= 40, so no trigger on that alone
    // But the fixture says enrichment is required on feasibility and business
    // Let's test with score explicitly < 40
    const analysis: AnalysisAxes = {
      ...fixtureAnalysis,
      feasibility: { ...fixtureAnalysis.feasibility, score: 35 },
    };
    const triggers = detectEnrichmentTriggers(analysis, 55, 'MEDIUM');
    const feasibilityTrigger = triggers.find((t) => t.axis === 'feasibility');
    expect(feasibilityTrigger).toBeDefined();
    expect(feasibilityTrigger!.type).toBe('axis_below_threshold');
  });

  test('should NOT trigger when score >= 40', () => {
    const analysis: AnalysisAxes = {
      ...fixtureAnalysis,
      feasibility: { ...fixtureAnalysis.feasibility, score: 42 },
    };
    const triggers = detectEnrichmentTriggers(analysis, 58, 'MEDIUM');
    const axisTriggers = triggers.filter((t) => t.type === 'axis_below_threshold');
    // No axis should be < 40 in the fixture (feasibility=42 is >= 40)
    expect(axisTriggers.every((t) => t.axis !== 'feasibility')).toBe(true);
  });

  test('should NOT trigger when blocking_gap = true', () => {
    const analysis: AnalysisAxes = {
      ...fixtureAnalysis,
      feasibility: { score: 30, justification: 'Test blocking gap handling.', blocking_gap: true },
    };
    const triggers = detectEnrichmentTriggers(analysis, 55, 'MEDIUM');
    const feasibilityTrigger = triggers.find(
      (t) => t.axis === 'feasibility' && t.type === 'axis_below_threshold'
    );
    expect(feasibilityTrigger).toBeUndefined();
  });

  test('should trigger on low confidence with medium score', () => {
    const triggers = detectEnrichmentTriggers(fixtureAnalysis, 58, 'LOW');
    const confidenceTrigger = triggers.find(
      (t) => t.type === 'low_confidence_medium_score'
    );
    expect(confidenceTrigger).toBeDefined();
  });

  test('should NOT trigger low confidence when score < 50', () => {
    const triggers = detectEnrichmentTriggers(fixtureAnalysis, 45, 'LOW');
    const confidenceTrigger = triggers.find(
      (t) => t.type === 'low_confidence_medium_score'
    );
    expect(confidenceTrigger).toBeUndefined();
  });

  test('should NOT trigger low confidence when score >= 70', () => {
    const triggers = detectEnrichmentTriggers(fixtureAnalysis, 70, 'LOW');
    const confidenceTrigger = triggers.find(
      (t) => t.type === 'low_confidence_medium_score'
    );
    expect(confidenceTrigger).toBeUndefined();
  });

  test('should NOT trigger when confidence is MEDIUM or HIGH', () => {
    const triggersM = detectEnrichmentTriggers(fixtureAnalysis, 58, 'MEDIUM');
    const triggersMConf = triggersM.filter(
      (t) => t.type === 'low_confidence_medium_score'
    );
    expect(triggersMConf).toHaveLength(0);

    const triggersH = detectEnrichmentTriggers(fixtureAnalysis, 58, 'HIGH');
    const triggersHConf = triggersH.filter(
      (t) => t.type === 'low_confidence_medium_score'
    );
    expect(triggersHConf).toHaveLength(0);
  });
});

// ═══════════════════════════════════════════════════════════════════
// AXIS PRIORITIZATION
// ═══════════════════════════════════════════════════════════════════

describe('prioritizeAxes', () => {
  test('should prioritize axes by (100 - score) × weight, max 2', () => {
    // Example from docs:
    // Problème: 65, 0.20 → 35×0.20 = 7.00
    // Marché: 38, 0.20 → 62×0.20 = 12.40
    // Différenciation: 42, 0.15 → 58×0.15 = 8.70
    const analysis: AnalysisAxes = {
      problem: { score: 65, justification: 'Test priority calculation problem.', blocking_gap: false },
      market: { score: 38, justification: 'Test priority calculation market.', blocking_gap: false },
      differentiation: { score: 42, justification: 'Test priority calc differentiation.', blocking_gap: false },
      feasibility: { score: 70, justification: 'Test priority calc feasibility.', blocking_gap: false },
      business: { score: 70, justification: 'Test priority calc business axis.', blocking_gap: false },
      founder_fit: { score: 70, justification: 'Test priority calc founder fit.', blocking_gap: false },
    };

    const triggers = detectEnrichmentTriggers(analysis, 55, 'MEDIUM');
    const prioritized = prioritizeAxes(analysis, triggers);

    expect(prioritized.length).toBeLessThanOrEqual(2);
    expect(prioritized[0].axis).toBe('market');
    expect(prioritized[0].priority).toBeCloseTo(12.4, 1);
  });

  test('should return max 2 axes', () => {
    const analysis: AnalysisAxes = {
      problem: { score: 30, justification: 'Test max 2 axes for problem.', blocking_gap: false },
      market: { score: 25, justification: 'Test max 2 axes for market.', blocking_gap: false },
      differentiation: { score: 35, justification: 'Test max 2 axes for diff.', blocking_gap: false },
      feasibility: { score: 20, justification: 'Test max 2 axes for feasibility.', blocking_gap: false },
      business: { score: 28, justification: 'Test max 2 axes for business.', blocking_gap: false },
      founder_fit: { score: 30, justification: 'Test max 2 axes for founder fit.', blocking_gap: false },
    };

    const triggers = detectEnrichmentTriggers(analysis, 27, 'LOW');
    const prioritized = prioritizeAxes(analysis, triggers);

    expect(prioritized.length).toBe(2);
  });
});

// ═══════════════════════════════════════════════════════════════════
// COMPUTE ENRICHMENT DECISION
// ═══════════════════════════════════════════════════════════════════

describe('computeEnrichmentDecision', () => {
  test('should require enrichment when axes are below threshold', () => {
    const analysis: AnalysisAxes = {
      ...fixtureAnalysis,
      feasibility: { ...fixtureAnalysis.feasibility, score: 35 },
      business: { ...fixtureAnalysis.business, score: 38 },
    };
    const result = computeEnrichmentDecision(analysis, 55, 'MEDIUM');
    expect(result.required).toBe(true);
    expect(result.trigger_axes.length).toBeGreaterThan(0);
    expect(result.trigger_axes.length).toBeLessThanOrEqual(2);
    expect(result.max_questions).toBeLessThanOrEqual(5);
  });

  test('should not require enrichment when all axes >= 40 and confidence not LOW', () => {
    const analysis: AnalysisAxes = {
      problem: { score: 70, justification: 'No enrichment needed for problem.', blocking_gap: false },
      market: { score: 60, justification: 'No enrichment needed for market.', blocking_gap: false },
      differentiation: { score: 65, justification: 'No enrichment needed for diff.', blocking_gap: false },
      feasibility: { score: 55, justification: 'No enrichment needed feasibility.', blocking_gap: false },
      business: { score: 60, justification: 'No enrichment needed for business.', blocking_gap: false },
      founder_fit: { score: 50, justification: 'No enrichment needed founder fit.', blocking_gap: false },
    };
    const result = computeEnrichmentDecision(analysis, 62, 'HIGH');
    expect(result.required).toBe(false);
    expect(result.trigger_axes).toHaveLength(0);
    expect(result.max_questions).toBe(0);
  });
});

// ═══════════════════════════════════════════════════════════════════
// SCORE ADJUSTMENT (Section 8.2)
// ═══════════════════════════════════════════════════════════════════

describe('applyEnrichmentAdjustments', () => {
  test('should apply adjustments and recalculate score (example from docs)', () => {
    // Axe Marché initial: 38
    // Question 1 (taille marché) : +18 points
    // Question 2 (timing) : +12 points
    // Question 3 (concurrence) : -5 points
    // → Score enrichi Marché = 38 + 18 + 12 - 5 = 63
    const analysis: AnalysisAxes = {
      ...fixtureAnalysis,
      market: { ...fixtureAnalysis.market, score: 38 },
    };

    const adjustments = [
      { axis: 'market' as AnalysisAxis, question_id: 'q1', adjustment: 18 },
      { axis: 'market' as AnalysisAxis, question_id: 'q2', adjustment: 12 },
      { axis: 'market' as AnalysisAxis, question_id: 'q3', adjustment: -5 },
    ];

    const { updatedAnalysis } = applyEnrichmentAdjustments(analysis, adjustments);
    expect(updatedAnalysis.market.score).toBe(63);
  });

  test('should clamp to [0, 100]', () => {
    const adjustments = [
      { axis: 'problem' as AnalysisAxis, question_id: 'q1', adjustment: 50 },
    ];
    const { updatedAnalysis } = applyEnrichmentAdjustments(fixtureAnalysis, adjustments);
    expect(updatedAnalysis.problem.score).toBe(100); // 72 + 50 = 122 → 100
  });

  test('should track enriched axes', () => {
    const adjustments = [
      { axis: 'feasibility' as AnalysisAxis, question_id: 'q1', adjustment: 10 },
      { axis: 'business' as AnalysisAxis, question_id: 'q2', adjustment: 15 },
    ];
    const { enrichedAxes } = applyEnrichmentAdjustments(fixtureAnalysis, adjustments);
    expect(enrichedAxes.has('feasibility')).toBe(true);
    expect(enrichedAxes.has('business')).toBe(true);
    expect(enrichedAxes.size).toBe(2);
  });
});

// ═══════════════════════════════════════════════════════════════════
// CONFIDENCE UPDATE
// ═══════════════════════════════════════════════════════════════════

describe('updateConfidenceLevel', () => {
  test('LOW → MEDIUM when 2+ axes enriched', () => {
    const enriched = new Set<AnalysisAxis>(['feasibility', 'business']);
    const result = updateConfidenceLevel('LOW', enriched, fixtureAnalysis);
    expect(result).toBe('MEDIUM');
  });

  test('LOW stays LOW when < 2 axes enriched', () => {
    const enriched = new Set<AnalysisAxis>(['feasibility']);
    const result = updateConfidenceLevel('LOW', enriched, fixtureAnalysis);
    expect(result).toBe('LOW');
  });

  test('HIGH stays HIGH always', () => {
    const enriched = new Set<AnalysisAxis>(['feasibility']);
    const result = updateConfidenceLevel('HIGH', enriched, fixtureAnalysis);
    expect(result).toBe('HIGH');
  });
});
