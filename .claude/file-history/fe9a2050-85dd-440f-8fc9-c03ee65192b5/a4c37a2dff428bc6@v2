    "raw_summary": "string (10-500 chars) — résumé factuel de l'idée (pas une copie verbatim)"
  },
  "analysis": {
    "problem": {
      "score": integer (0-100),
      "justification": "string (20-300 chars) — factuel, spécifique",
      "blocking_gap": boolean
    },
    "market": {
      "score": integer (0-100),
      "justification": "string (20-300 chars)",
      "blocking_gap": boolean
    },
    "differentiation": {
      "score": integer (0-100),
      "justification": "string (20-300 chars)",
      "blocking_gap": boolean
    },
    "feasibility": {
      "score": integer (0-100) — INVERSÉ: 100=facile, 0=impossible,
      "justification": "string (20-300 chars)",
      "blocking_gap": boolean
    },
    "business": {
      "score": integer (0-100),
      "justification": "string (20-300 chars)",
      "blocking_gap": boolean
