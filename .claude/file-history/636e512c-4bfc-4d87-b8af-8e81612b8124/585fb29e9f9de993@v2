"use client";

import { useState, useEffect } from "react";
import { Users, Plus, X, Briefcase, Target, Check } from "lucide-react";
import { cn } from "@/lib/utils";
import { Button } from "@/components/ui/button";

interface TargetActorCanvasProps {
    projectId: string;
}

interface ActorCard {
    id: string;
    name: string;
    role: string;
    description: string;
    problemRelevance: string;
    validated: boolean;
}

export function TargetActorCanvas({ projectId }: TargetActorCanvasProps) {
    const [actors, setActors] = useState<ActorCard[]>([]);
    const [isLoading, setIsLoading] = useState(true);
    const [showAddForm, setShowAddForm] = useState(false);
    const [newActor, setNewActor] = useState({
        name: "",
        role: "",
        description: "",
        problemRelevance: ""
    });

    useEffect(() => {
        loadActors();
    }, [projectId]);

    async function loadActors() {
        try {
            setIsLoading(true);
            const response = await fetch(`/api/projects/${projectId}/cards?type=TARGET_ACTOR&phase=IDEATION`);
            if (response.ok) {
                const data = await response.json();
                const cards = data.data || [];
                setActors(cards.map((card: any) => ({
                    id: card.id,
                    name: card.label || "",
                    role: card.metadata?.role || "",
                    description: card.description || "",
                    problemRelevance: card.metadata?.problemRelevance || "",
                    validated: card.validated || false
                })));
            }
        } catch (error) {
            console.error("Failed to load actors:", error);
        } finally {
            setIsLoading(false);
        }
    }

    async function addActor() {
        if (!newActor.name.trim() || !newActor.role.trim()) return;

        try {
            const response = await fetch(`/api/projects/${projectId}/cards`, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    type: "TARGET_ACTOR",
                    label: newActor.name.trim(),
                    description: newActor.description.trim(),
                    phase: "IDEATION",
                    status: "DRAFT",
                    priority: "MEDIUM",
                    metadata: {
                        role: newActor.role.trim(),
                        problemRelevance: newActor.problemRelevance.trim()
                    }
                })
            });

            if (response.ok) {
                await loadActors();
                setNewActor({ name: "", role: "", description: "", problemRelevance: "" });
                setShowAddForm(false);
            }
        } catch (error) {
            console.error("Failed to add actor:", error);
        }
    }

    async function toggleValidation(id: string) {
        const actor = actors.find(a => a.id === id);
        if (!actor) return;

        try {
            await fetch(`/api/cards/${id}`, {
                method: "PATCH",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ validated: !actor.validated })
            });

            setActors(actors.map(a => a.id === id ? { ...a, validated: !a.validated } : a));
        } catch (error) {
            console.error("Failed to toggle validation:", error);
        }
    }

    async function deleteActor(id: string) {
        try {
            await fetch(`/api/cards/${id}`, { method: "DELETE" });
            setActors(actors.filter(a => a.id !== id));
        } catch (error) {
            console.error("Failed to delete actor:", error);
        }
    }

    if (isLoading) {
        return (
            <div className="flex items-center justify-center py-12">
                <div className="text-gray-500 text-sm">Chargement...</div>
            </div>
        );
    }

    return (
        <div className="space-y-4">
            {/* Header */}
            <div className="flex items-center justify-between">
                <div>
                    <h2 className="text-xs text-gray-500 uppercase tracking-widest font-bold mb-1 flex items-center gap-2">
                        <Users className="w-3.5 h-3.5 text-blue-400" />
                        Acteurs Cibles
                    </h2>
                    <p className="text-[11px] text-gray-400">
                        Identifiez les segments et personas concernés par le problème
                    </p>
                </div>
                <Button
                    onClick={() => setShowAddForm(!showAddForm)}
                    variant="ghost"
                    size="sm"
                    className="text-[#F75105] hover:text-[#F78E21] hover:bg-[#F75105]/10 text-xs"
                >
                    <Plus className="w-3.5 h-3.5 mr-1" />
                    Ajouter
                </Button>
            </div>

            {/* Add Form */}
            {showAddForm && (
                <div className="p-4 rounded-xl bg-[#2F323A] border border-[#F75105]/30 space-y-3">
                    <div className="grid grid-cols-2 gap-3">
                        <div>
                            <label className="text-[10px] text-gray-500 uppercase tracking-widest font-bold block mb-2">
                                Nom du segment / Persona
                            </label>
                            <input
                                type="text"
                                value={newActor.name}
                                onChange={(e) => setNewActor({ ...newActor, name: e.target.value })}
                                placeholder="Ex: PME Tech, Freelances, CTOs..."
                                className="w-full px-3 py-2 bg-[#22242B] border border-white/10 rounded-lg text-sm text-white placeholder:text-gray-500 focus:outline-none focus:border-[#F75105]/50"
                                autoFocus
                            />
                        </div>

                        <div>
                            <label className="text-[10px] text-gray-500 uppercase tracking-widest font-bold block mb-2">
                                <Briefcase className="w-3 h-3 inline mr-1" />
                                Rôle
                            </label>
                            <input
                                type="text"
                                value={newActor.role}
                                onChange={(e) => setNewActor({ ...newActor, role: e.target.value })}
                                placeholder="Ex: CTO, Marketeur, Manager..."
                                className="w-full px-3 py-2 bg-[#22242B] border border-white/10 rounded-lg text-sm text-white placeholder:text-gray-500 focus:outline-none focus:border-[#F75105]/50"
                            />
                        </div>
                    </div>

                    <div>
                        <label className="text-[10px] text-gray-500 uppercase tracking-widest font-bold block mb-2">
                            Description détaillée
                        </label>
                        <textarea
                            value={newActor.description}
                            onChange={(e) => setNewActor({ ...newActor, description: e.target.value })}
                            placeholder="Caractéristiques, besoins, contexte d'usage..."
                            className="w-full min-h-[60px] px-3 py-2 bg-[#22242B] border border-white/10 rounded-lg text-sm text-white placeholder:text-gray-500 focus:outline-none focus:border-[#F75105]/50 resize-none"
                        />
                    </div>

                    <div>
                        <label className="text-[10px] text-gray-500 uppercase tracking-widest font-bold block mb-2">
                            <Target className="w-3 h-3 inline mr-1" />
                            Pourquoi ce problème le concerne
                        </label>
                        <input
                            type="text"
                            value={newActor.problemRelevance}
                            onChange={(e) => setNewActor({ ...newActor, problemRelevance: e.target.value })}
                            placeholder="En quoi est-il directement impacté par le problème ?"
                            className="w-full px-3 py-2 bg-[#22242B] border border-white/10 rounded-lg text-sm text-white placeholder:text-gray-500 focus:outline-none focus:border-[#F75105]/50"
                        />
                    </div>

                    <div className="flex gap-2">
                        <Button
                            onClick={addActor}
                            disabled={!newActor.name.trim() || !newActor.role.trim()}
                            className="bg-[#F75105] hover:bg-[#F78E21] text-white"
                        >
                            Ajouter
                        </Button>
                        <Button
                            onClick={() => {
                                setShowAddForm(false);
                                setNewActor({ name: "", role: "", description: "", problemRelevance: "" });
                            }}
                            variant="ghost"
                            className="text-gray-400"
                        >
                            Annuler
                        </Button>
                    </div>
                </div>
            )}

            {/* Actor List */}
            {actors.length === 0 && !showAddForm ? (
                <div className="text-center py-8 text-gray-500 text-sm">
                    Aucun acteur identifié. Ajoutez les segments de marché ou personas concernés.
                </div>
            ) : (
                <div className="grid grid-cols-1 md:grid-cols-2 gap-3">
                    {actors.map((actor) => (
                        <div
                            key={actor.id}
                            className={cn(
                                "p-4 rounded-xl border transition-all",
                                actor.validated
                                    ? "bg-emerald-500/5 border-emerald-500/20"
                                    : "bg-[#2F323A] border-white/5"
                            )}
                        >
                            <div className="flex items-start gap-3">
                                {/* Validation Checkbox */}
                                <button
                                    onClick={() => toggleValidation(actor.id)}
                                    className={cn(
                                        "mt-0.5 w-5 h-5 rounded border flex items-center justify-center shrink-0 transition-colors",
                                        actor.validated
                                            ? "bg-emerald-500 border-emerald-500 text-white"
                                            : "border-gray-500 hover:border-[#F75105]"
                                    )}
                                >
                                    {actor.validated && <Check className="w-3 h-3" />}
                                </button>

                                {/* Content */}
                                <div className="flex-1 min-w-0">
                                    <div className="flex items-center justify-between mb-1">
                                        <h3 className="text-sm font-medium text-white">{actor.name}</h3>
                                        <button
                                            onClick={() => deleteActor(actor.id)}
                                            className="p-1 rounded text-gray-600 hover:text-gray-400 hover:bg-white/5 transition-colors shrink-0"
                                        >
                                            <X className="w-3.5 h-3.5" />
                                        </button>
                                    </div>

                                    <div className="flex items-center gap-1 text-[11px] text-blue-400 mb-2">
                                        <Briefcase className="w-3 h-3" />
                                        <span>{actor.role}</span>
                                    </div>

                                    {actor.description && (
                                        <p className="text-xs text-gray-400 mb-2 leading-relaxed">
                                            {actor.description}
                                        </p>
                                    )}

                                    {actor.problemRelevance && (
                                        <div className="text-[11px] text-gray-500 flex items-start gap-1">
                                            <Target className="w-3 h-3 shrink-0 mt-0.5" />
                                            <span>{actor.problemRelevance}</span>
                                        </div>
                                    )}
                                </div>
                            </div>
                        </div>
                    ))}
                </div>
            )}
        </div>
    );
}
