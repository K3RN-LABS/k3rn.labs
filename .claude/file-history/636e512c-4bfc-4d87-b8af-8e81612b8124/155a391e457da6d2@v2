"use client";

import { useState } from "react";
import { ChevronRight, CheckCircle2, Circle, Lock, User } from "lucide-react";
import { cn } from "@/lib/utils";
import { Button } from "@/components/ui/button";
import type { LabDefinition, LabStep } from "@/lib/workflow/definitions";

interface WorkflowStepperProps {
    labName: string;
    labNumber: number;
    currentStep: number;
    totalSteps: number;
    steps: LabStep[];
    onAdvanceStep: () => Promise<void>;
    isAdvancing?: boolean;
}

export function WorkflowStepper({
    labName,
    labNumber,
    currentStep,
    totalSteps,
    steps,
    onAdvanceStep,
    isAdvancing = false
}: WorkflowStepperProps) {
    const [isExpanded, setIsExpanded] = useState(false);

    const currentStepDef = steps[currentStep];
    const progress = ((currentStep) / totalSteps) * 100;
    const isCompleted = currentStep >= totalSteps;

    // Get expert name from expertId
    const getExpertName = (expertId?: string) => {
        const expertNames: Record<string, string> = {
            'marcus': 'Marcus',
            'sarah': 'Sarah',
            'elena': 'Elena',
            'david': 'David',
            'sophie': 'Sophie',
            'thomas': 'Thomas'
        };
        return expertId ? expertNames[expertId] || expertId : null;
    };

    const currentExpert = currentStepDef ? getExpertName(currentStepDef.expertId) : null;

    return (
        <div className="sticky top-0 z-40 bg-[#2F323A] border-b border-[#3A3D45] shadow-lg">
            {/* Compact View */}
            <div className="px-6 py-3">
                <div className="flex items-center justify-between gap-4">
                    {/* Left: Lab Info + Progress */}
                    <div className="flex items-center gap-4 flex-1 min-w-0">
                        {/* Lab Badge */}
                        <div className="flex items-center gap-2 shrink-0">
                            <div className="w-8 h-8 rounded-lg bg-[#F75105]/10 flex items-center justify-center">
                                <span className="text-sm font-bold text-[#F75105]">{labNumber}</span>
                            </div>
                            <div className="hidden sm:block">
                                <div className="text-xs font-medium text-white">{labName}</div>
                                <div className="text-[10px] text-gray-500">
                                    {isCompleted ? 'Complété' : `Étape ${currentStep + 1}/${totalSteps}`}
                                </div>
                            </div>
                        </div>

                        {/* Progress Bar */}
                        <div className="flex-1 min-w-0 max-w-md">
                            <div className="h-2 bg-[#22242B] rounded-full overflow-hidden">
                                <div
                                    className={cn(
                                        "h-full transition-all duration-500 ease-out",
                                        isCompleted ? "bg-emerald-500" : "bg-[#F75105]"
                                    )}
                                    style={{ width: `${progress}%` }}
                                />
                            </div>
                            <div className="mt-1 text-[10px] text-gray-500 flex items-center justify-between">
                                <span>{Math.round(progress)}% complété</span>
                                <button
                                    onClick={() => setIsExpanded(!isExpanded)}
                                    className="text-[#F75105] hover:text-[#F78E21] transition-colors"
                                >
                                    {isExpanded ? 'Réduire' : 'Voir les étapes'}
                                </button>
                            </div>
                        </div>

                        {/* Current Step Info (desktop) */}
                        {!isCompleted && currentStepDef && (
                            <div className="hidden lg:flex items-center gap-3 px-4 py-2 rounded-lg bg-[#22242B] border border-[#3A3D45]">
                                <div className="flex-1 min-w-0">
                                    <div className="text-xs font-medium text-white truncate">
                                        {currentStepDef.title}
                                    </div>
                                    {currentExpert && (
                                        <div className="text-[10px] text-gray-500 flex items-center gap-1 mt-0.5">
                                            <User className="w-3 h-3" />
                                            <span>Expert : {currentExpert}</span>
                                        </div>
                                    )}
                                </div>
                            </div>
                        )}
                    </div>

                    {/* Right: CTA Button */}
                    {!isCompleted && (
                        <Button
                            onClick={onAdvanceStep}
                            disabled={isAdvancing}
                            className="bg-[#F75105] hover:bg-[#F78E21] text-white font-medium shrink-0 h-9"
                        >
                            {isAdvancing ? (
                                <>
                                    <div className="w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin mr-2" />
                                    <span className="hidden sm:inline">Progression...</span>
                                </>
                            ) : (
                                <>
                                    <span className="hidden sm:inline">Continuer</span>
                                    <span className="sm:hidden">Next</span>
                                    <ChevronRight className="w-4 h-4 ml-1" />
                                </>
                            )}
                        </Button>
                    )}

                    {isCompleted && (
                        <div className="flex items-center gap-2 text-emerald-400">
                            <CheckCircle2 className="w-5 h-5" />
                            <span className="text-sm font-medium hidden sm:inline">Lab terminé</span>
                        </div>
                    )}
                </div>

                {/* Current Step Info (mobile) */}
                {!isCompleted && currentStepDef && (
                    <div className="mt-3 lg:hidden px-4 py-2 rounded-lg bg-[#22242B] border border-[#3A3D45]">
                        <div className="text-xs font-medium text-white">
                            {currentStepDef.title}
                        </div>
                        {currentExpert && (
                            <div className="text-[10px] text-gray-500 flex items-center gap-1 mt-1">
                                <User className="w-3 h-3" />
                                <span>Expert : {currentExpert}</span>
                            </div>
                        )}
                        <div className="text-[10px] text-gray-400 mt-1">
                            {currentStepDef.description}
                        </div>
                    </div>
                )}
            </div>

            {/* Expanded View - All Steps */}
            {isExpanded && (
                <div className="px-6 pb-4 border-t border-[#3A3D45]/50">
                    <div className="mt-4 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
                        {steps.map((step, index) => {
                            const isStepCompleted = index < currentStep;
                            const isStepCurrent = index === currentStep;
                            const isStepLocked = index > currentStep;

                            return (
                                <div
                                    key={step.id}
                                    className={cn(
                                        "p-3 rounded-lg border transition-all",
                                        isStepCompleted && "bg-emerald-500/5 border-emerald-500/20",
                                        isStepCurrent && "bg-[#F75105]/10 border-[#F75105]/30 ring-2 ring-[#F75105]/20",
                                        isStepLocked && "bg-[#22242B] border-[#3A3D45] opacity-50"
                                    )}
                                >
                                    <div className="flex items-start gap-2">
                                        <div className="shrink-0 mt-0.5">
                                            {isStepCompleted && (
                                                <CheckCircle2 className="w-4 h-4 text-emerald-400" />
                                            )}
                                            {isStepCurrent && (
                                                <Circle className="w-4 h-4 text-[#F75105] fill-[#F75105]" />
                                            )}
                                            {isStepLocked && (
                                                <Lock className="w-4 h-4 text-gray-600" />
                                            )}
                                        </div>
                                        <div className="flex-1 min-w-0">
                                            <div className="flex items-center gap-2">
                                                <span className="text-[10px] font-mono text-gray-500">
                                                    {index + 1}/{totalSteps}
                                                </span>
                                                {step.type === 'GATE_CHECK' && (
                                                    <span className="text-[9px] px-1.5 py-0.5 rounded bg-amber-500/10 text-amber-400 font-bold uppercase tracking-wider">
                                                        Gate
                                                    </span>
                                                )}
                                            </div>
                                            <div className={cn(
                                                "text-xs font-medium mt-1",
                                                isStepCurrent ? "text-white" : "text-gray-400"
                                            )}>
                                                {step.title}
                                            </div>
                                            {step.expertId && (
                                                <div className="text-[10px] text-gray-500 flex items-center gap-1 mt-1">
                                                    <User className="w-3 h-3" />
                                                    {getExpertName(step.expertId)}
                                                </div>
                                            )}
                                            <div className="text-[10px] text-gray-500 mt-1 line-clamp-2">
                                                {step.description}
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            );
                        })}
                    </div>
                </div>
            )}
        </div>
    );
}
