"use client";

import { useState, useEffect } from "react";
import { Zap, Plus, X, Users, DollarSign, Check } from "lucide-react";
import { cn } from "@/lib/utils";
import { Button } from "@/components/ui/button";
import type { ObservedPain } from "@/lib/lab1/types";

interface ObservedPainCanvasProps {
    projectId: string;
}

interface PainCard {
    id: string;
    description: string;
    affectedActors: string[];
    currentWorkarounds: string;
    cost: string;
    validated: boolean;
}

export function ObservedPainCanvas({ projectId }: ObservedPainCanvasProps) {
    const [pains, setPains] = useState<PainCard[]>([]);
    const [isLoading, setIsLoading] = useState(true);
    const [showAddForm, setShowAddForm] = useState(false);
    const [newPain, setNewPain] = useState({
        description: "",
        affectedActors: "",
        currentWorkarounds: "",
        cost: ""
    });

    // Load pains from API
    useEffect(() => {
        loadPains();
    }, [projectId]);

    async function loadPains() {
        try {
            setIsLoading(true);
            const response = await fetch(`/api/projects/${projectId}/cards?type=OBSERVED_PAIN&phase=IDEATION`);
            if (response.ok) {
                const data = await response.json();
                const cards = data.data || [];
                setPains(cards.map((card: any) => ({
                    id: card.id,
                    description: card.label || "",
                    affectedActors: card.metadata?.affectedActors || [],
                    currentWorkarounds: card.metadata?.currentWorkarounds || "",
                    cost: card.metadata?.cost || "",
                    validated: card.validated || false
                })));
            }
        } catch (error) {
            console.error("Failed to load pains:", error);
        } finally {
            setIsLoading(false);
        }
    }

    async function addPain() {
        if (!newPain.description.trim()) return;

        try {
            const response = await fetch(`/api/projects/${projectId}/cards`, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    type: "OBSERVED_PAIN",
                    label: newPain.description.trim(),
                    phase: "IDEATION",
                    status: "DRAFT",
                    priority: "MEDIUM",
                    metadata: {
                        affectedActors: newPain.affectedActors.split(",").map(a => a.trim()).filter(Boolean),
                        currentWorkarounds: newPain.currentWorkarounds,
                        cost: newPain.cost
                    }
                })
            });

            if (response.ok) {
                await loadPains();
                setNewPain({ description: "", affectedActors: "", currentWorkarounds: "", cost: "" });
                setShowAddForm(false);
            }
        } catch (error) {
            console.error("Failed to add pain:", error);
        }
    }

    async function toggleValidation(id: string) {
        const pain = pains.find(p => p.id === id);
        if (!pain) return;

        try {
            await fetch(`/api/cards/${id}`, {
                method: "PATCH",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ validated: !pain.validated })
            });

            setPains(pains.map(p => p.id === id ? { ...p, validated: !p.validated } : p));
        } catch (error) {
            console.error("Failed to toggle validation:", error);
        }
    }

    async function deletePain(id: string) {
        try {
            await fetch(`/api/cards/${id}`, { method: "DELETE" });
            setPains(pains.filter(p => p.id !== id));
        } catch (error) {
            console.error("Failed to delete pain:", error);
        }
    }

    if (isLoading) {
        return (
            <div className="flex items-center justify-center py-12">
                <div className="text-gray-500 text-sm">Chargement...</div>
            </div>
        );
    }

    return (
        <div className="space-y-4">
            {/* Header */}
            <div className="flex items-center justify-between">
                <div>
                    <h2 className="text-xs text-gray-500 uppercase tracking-widest font-bold mb-1 flex items-center gap-2">
                        <Zap className="w-3.5 h-3.5 text-amber-400" />
                        Douleurs Observées
                    </h2>
                    <p className="text-[11px] text-gray-400">
                        Documentez les douleurs concrètes ressenties par les utilisateurs
                    </p>
                </div>
                <Button
                    onClick={() => setShowAddForm(!showAddForm)}
                    variant="ghost"
                    size="sm"
                    className="text-[#F75105] hover:text-[#F78E21] hover:bg-[#F75105]/10 text-xs"
                >
                    <Plus className="w-3.5 h-3.5 mr-1" />
                    Ajouter
                </Button>
            </div>

            {/* Add Form */}
            {showAddForm && (
                <div className="p-4 rounded-xl bg-[#2F323A] border border-[#F75105]/30 space-y-3">
                    <div>
                        <label className="text-[10px] text-gray-500 uppercase tracking-widest font-bold block mb-2">
                            Description de la douleur
                        </label>
                        <textarea
                            value={newPain.description}
                            onChange={(e) => setNewPain({ ...newPain, description: e.target.value })}
                            placeholder="Ex: Les utilisateurs perdent 2h par jour à chercher des informations dispersées..."
                            className="w-full min-h-[60px] px-3 py-2 bg-[#22242B] border border-white/10 rounded-lg text-sm text-white placeholder:text-gray-500 focus:outline-none focus:border-[#F75105]/50 resize-none"
                            autoFocus
                        />
                    </div>

                    <div className="grid grid-cols-2 gap-3">
                        <div>
                            <label className="text-[10px] text-gray-500 uppercase tracking-widest font-bold block mb-2">
                                <Users className="w-3 h-3 inline mr-1" />
                                Qui est affecté ?
                            </label>
                            <input
                                type="text"
                                value={newPain.affectedActors}
                                onChange={(e) => setNewPain({ ...newPain, affectedActors: e.target.value })}
                                placeholder="Ex: PME, Freelances, Managers"
                                className="w-full px-3 py-2 bg-[#22242B] border border-white/10 rounded-lg text-sm text-white placeholder:text-gray-500 focus:outline-none focus:border-[#F75105]/50"
                            />
                            <span className="text-[10px] text-gray-500 mt-1">Séparer par virgules</span>
                        </div>

                        <div>
                            <label className="text-[10px] text-gray-500 uppercase tracking-widest font-bold block mb-2">
                                <DollarSign className="w-3 h-3 inline mr-1" />
                                Coût estimé
                            </label>
                            <input
                                type="text"
                                value={newPain.cost}
                                onChange={(e) => setNewPain({ ...newPain, cost: e.target.value })}
                                placeholder="Ex: 2h/jour, 500€/mois"
                                className="w-full px-3 py-2 bg-[#22242B] border border-white/10 rounded-lg text-sm text-white placeholder:text-gray-500 focus:outline-none focus:border-[#F75105]/50"
                            />
                        </div>
                    </div>

                    <div>
                        <label className="text-[10px] text-gray-500 uppercase tracking-widest font-bold block mb-2">
                            Solutions actuelles (workarounds)
                        </label>
                        <input
                            type="text"
                            value={newPain.currentWorkarounds}
                            onChange={(e) => setNewPain({ ...newPain, currentWorkarounds: e.target.value })}
                            placeholder="Ex: Excel, emails, post-its..."
                            className="w-full px-3 py-2 bg-[#22242B] border border-white/10 rounded-lg text-sm text-white placeholder:text-gray-500 focus:outline-none focus:border-[#F75105]/50"
                        />
                    </div>

                    <div className="flex gap-2">
                        <Button
                            onClick={addPain}
                            disabled={!newPain.description.trim()}
                            className="bg-[#F75105] hover:bg-[#F78E21] text-white"
                        >
                            Ajouter
                        </Button>
                        <Button
                            onClick={() => {
                                setShowAddForm(false);
                                setNewPain({ description: "", affectedActors: "", currentWorkarounds: "", cost: "" });
                            }}
                            variant="ghost"
                            className="text-gray-400"
                        >
                            Annuler
                        </Button>
                    </div>
                </div>
            )}

            {/* Pain List */}
            {pains.length === 0 && !showAddForm ? (
                <div className="text-center py-8 text-gray-500 text-sm">
                    Aucune douleur documentée. Ajoutez les problèmes concrets que vous avez observés.
                </div>
            ) : (
                <div className="space-y-3">
                    {pains.map((pain) => (
                        <div
                            key={pain.id}
                            className={cn(
                                "p-4 rounded-xl border transition-all",
                                pain.validated
                                    ? "bg-emerald-500/5 border-emerald-500/20"
                                    : "bg-[#2F323A] border-white/5"
                            )}
                        >
                            <div className="flex items-start gap-3">
                                {/* Validation Checkbox */}
                                <button
                                    onClick={() => toggleValidation(pain.id)}
                                    className={cn(
                                        "mt-0.5 w-5 h-5 rounded border flex items-center justify-center shrink-0 transition-colors",
                                        pain.validated
                                            ? "bg-emerald-500 border-emerald-500 text-white"
                                            : "border-gray-500 hover:border-[#F75105]"
                                    )}
                                >
                                    {pain.validated && <Check className="w-3 h-3" />}
                                </button>

                                {/* Content */}
                                <div className="flex-1 min-w-0">
                                    <div className="text-sm text-white mb-2">{pain.description}</div>

                                    <div className="grid grid-cols-1 md:grid-cols-3 gap-2 text-[11px]">
                                        {pain.affectedActors.length > 0 && (
                                            <div className="flex items-center gap-1 text-gray-400">
                                                <Users className="w-3 h-3" />
                                                <span>{pain.affectedActors.join(", ")}</span>
                                            </div>
                                        )}
                                        {pain.cost && (
                                            <div className="flex items-center gap-1 text-amber-400">
                                                <DollarSign className="w-3 h-3" />
                                                <span>{pain.cost}</span>
                                            </div>
                                        )}
                                        {pain.currentWorkarounds && (
                                            <div className="text-gray-500">
                                                Workaround: {pain.currentWorkarounds}
                                            </div>
                                        )}
                                    </div>
                                </div>

                                {/* Delete Button */}
                                <button
                                    onClick={() => deletePain(pain.id)}
                                    className="p-1 rounded text-gray-600 hover:text-gray-400 hover:bg-white/5 transition-colors shrink-0"
                                >
                                    <X className="w-3.5 h-3.5" />
                                </button>
                            </div>
                        </div>
                    ))}
                </div>
            )}
        </div>
    );
}
