### 3. `/src/app/workspace/laboratoire-1-discovery/[id]/page.tsx`

**Imports ajoutés** :
```typescript
import { useEffect, useState } from "react";
import { checkLab1GateRequirements, type GateCheckResult } from "@/lib/lab1/gate-check";
```

**State ajouté** :
```typescript
const [gateCheck, setGateCheck] = useState<GateCheckResult>({
    canProceed: true,
    missingRequirements: []
});
```

**useEffect pour vérification** :
```typescript
useEffect(() => {
    const checkGate = async () => {
        const result = await checkLab1GateRequirements(id);
        setGateCheck(result);
    };

    checkGate(); // Check initial

    // Re-check toutes les 10 secondes
    const interval = setInterval(checkGate, 10000);
    return () => clearInterval(interval);
}, [id]);
```

**Props passées à WorkflowStepper** :
```typescript
<WorkflowStepper
    // ... existing props
    canAdvance={gateCheck.canProceed}
    blockingMessage={gateCheck.blockingMessage}
/>
```

