"use client";

import { useState, useEffect } from "react";
import { Target, AlertTriangle, Clock, TrendingUp } from "lucide-react";
import { cn } from "@/lib/utils";
import type { ProblemStatement } from "@/lib/lab1/types";

interface ProblemStatementCanvasProps {
    projectId: string;
}

export function ProblemStatementCanvas({ projectId }: ProblemStatementCanvasProps) {
    const [statement, setStatement] = useState<Partial<ProblemStatement>>({
        statement: "",
        context: "",
        severity: "MEDIUM",
        frequency: "WEEKLY",
        validated: false
    });
    const [isLoading, setIsLoading] = useState(true);
    const [isSaving, setIsSaving] = useState(false);
    const [statementCardId, setStatementCardId] = useState<string | null>(null);

    // Load problem statement from API
    useEffect(() => {
        async function loadStatement() {
            try {
                setIsLoading(true);
                const response = await fetch(`/api/projects/${projectId}/cards?type=PROBLEM_STATEMENT&phase=IDEATION`);
                if (response.ok) {
                    const data = await response.json();
                    const cards = data.data || [];
                    if (cards.length > 0) {
                        const card = cards[0]; // Premier problem statement
                        const metadata = card.metadata || {};
                        setStatement({
                            statement: card.label || "",
                            context: card.description || "",
                            severity: metadata.severity || "MEDIUM",
                            frequency: metadata.frequency || "WEEKLY",
                            validated: card.validated || false
                        });
                        setStatementCardId(card.id);
                    }
                }
            } catch (error) {
                console.error("Failed to load problem statement:", error);
            } finally {
                setIsLoading(false);
            }
        }
        loadStatement();
    }, [projectId]);

    async function saveStatement() {
        try {
            setIsSaving(true);

            if (statementCardId) {
                // Update existing
                await fetch(`/api/cards/${statementCardId}`, {
                    method: "PATCH",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        label: statement.statement,
                        description: statement.context,
                        metadata: {
                            severity: statement.severity,
                            frequency: statement.frequency
                        }
                    })
                });
            } else {
                // Create new
                const response = await fetch(`/api/projects/${projectId}/cards`, {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        type: "PROBLEM_STATEMENT",
                        label: statement.statement,
                        description: statement.context,
                        phase: "IDEATION",
                        status: "DRAFT",
                        priority: statement.severity,
                        metadata: {
                            severity: statement.severity,
                            frequency: statement.frequency
                        }
                    })
                });

                if (response.ok) {
                    const data = await response.json();
                    setStatementCardId(data.data.id);
                }
            }
        } catch (error) {
            console.error("Failed to save problem statement:", error);
        } finally {
            setIsSaving(false);
        }
    }

    // Auto-save on blur
    function handleBlur() {
        if (statement.statement || statement.context) {
            saveStatement();
        }
    }

    if (isLoading) {
        return (
            <div className="flex items-center justify-center py-12">
                <div className="text-gray-500 text-sm">Chargement...</div>
            </div>
        );
    }

    return (
        <div className="space-y-6">
            {/* Header */}
            <div className="flex items-center justify-between">
                <div>
                    <h2 className="text-xs text-gray-500 uppercase tracking-widest font-bold mb-1 flex items-center gap-2">
                        <Target className="w-3.5 h-3.5 text-[#F75105]" />
                        Énoncé du Problème
                    </h2>
                    <p className="text-[11px] text-gray-400">
                        Décrivez clairement le problème réel que vous adressez
                    </p>
                </div>
                {isSaving && (
                    <span className="text-xs text-gray-500">Sauvegarde...</span>
                )}
            </div>

            {/* Problem Statement */}
            <div className="p-5 rounded-xl bg-[#2F323A] border border-white/5">
                <label className="text-[10px] text-gray-500 uppercase tracking-widest font-bold block mb-2">
                    Problème Principal
                </label>
                <textarea
                    value={statement.statement}
                    onChange={(e) => setStatement({ ...statement, statement: e.target.value })}
                    onBlur={handleBlur}
                    placeholder="Ex: Les PME perdent en moyenne 15h/semaine à gérer manuellement leurs factures..."
                    className="w-full min-h-[100px] bg-transparent text-sm text-white placeholder:text-gray-600 focus:outline-none resize-none leading-relaxed"
                />
            </div>

            {/* Context */}
            <div className="p-5 rounded-xl bg-[#2F323A] border border-white/5">
                <label className="text-[10px] text-gray-500 uppercase tracking-widest font-bold block mb-2">
                    Contexte
                </label>
                <textarea
                    value={statement.context}
                    onChange={(e) => setStatement({ ...statement, context: e.target.value })}
                    onBlur={handleBlur}
                    placeholder="Dans quel contexte ce problème se manifeste-t-il ? Qui est affecté ? Quand cela se produit-il ?"
                    className="w-full min-h-[80px] bg-transparent text-sm text-gray-300 placeholder:text-gray-600 focus:outline-none resize-none leading-relaxed"
                />
            </div>

            {/* Metadata Grid */}
            <div className="grid grid-cols-2 gap-4">
                {/* Severity */}
                <div className="p-4 rounded-xl bg-[#2F323A] border border-white/5">
                    <label className="text-[10px] text-gray-500 uppercase tracking-widest font-bold block mb-3 flex items-center gap-1">
                        <AlertTriangle className="w-3 h-3" />
                        Sévérité
                    </label>
                    <div className="space-y-2">
                        {(["HIGH", "MEDIUM", "LOW"] as const).map((level) => (
                            <button
                                key={level}
                                onClick={() => {
                                    setStatement({ ...statement, severity: level });
                                    saveStatement();
                                }}
                                className={cn(
                                    "w-full px-3 py-2 rounded-lg text-xs font-medium transition-all",
                                    statement.severity === level
                                        ? level === "HIGH" ? "bg-red-500/20 text-red-400 border border-red-500/30" :
                                          level === "MEDIUM" ? "bg-amber-500/20 text-amber-400 border border-amber-500/30" :
                                          "bg-gray-500/20 text-gray-400 border border-gray-500/30"
                                        : "bg-[#22242B] text-gray-500 border border-transparent hover:border-white/10"
                                )}
                            >
                                {level === "HIGH" ? "Élevée" : level === "MEDIUM" ? "Moyenne" : "Faible"}
                            </button>
                        ))}
                    </div>
                </div>

                {/* Frequency */}
                <div className="p-4 rounded-xl bg-[#2F323A] border border-white/5">
                    <label className="text-[10px] text-gray-500 uppercase tracking-widest font-bold block mb-3 flex items-center gap-1">
                        <Clock className="w-3 h-3" />
                        Fréquence
                    </label>
                    <div className="space-y-2">
                        {(["DAILY", "WEEKLY", "MONTHLY", "RARELY"] as const).map((freq) => (
                            <button
                                key={freq}
                                onClick={() => {
                                    setStatement({ ...statement, frequency: freq });
                                    saveStatement();
                                }}
                                className={cn(
                                    "w-full px-3 py-2 rounded-lg text-xs font-medium transition-all",
                                    statement.frequency === freq
                                        ? "bg-[#F75105]/20 text-[#F75105] border border-[#F75105]/30"
                                        : "bg-[#22242B] text-gray-500 border border-transparent hover:border-white/10"
                                )}
                            >
                                {freq === "DAILY" ? "Quotidien" :
                                 freq === "WEEKLY" ? "Hebdomadaire" :
                                 freq === "MONTHLY" ? "Mensuel" :
                                 "Rare"}
                            </button>
                        ))}
                    </div>
                </div>
            </div>

            {/* Guidance */}
            {(!statement.statement || !statement.context) && (
                <div className="p-4 rounded-lg bg-blue-500/10 border border-blue-500/20">
                    <div className="flex items-start gap-2">
                        <TrendingUp className="w-4 h-4 text-blue-400 shrink-0 mt-0.5" />
                        <div className="text-xs text-blue-300 leading-relaxed">
                            <strong>Conseil :</strong> Un bon énoncé de problème décrit la douleur réelle, pas la solution.
                            Évitez "Il faut une app pour..." et focalisez sur "Les utilisateurs perdent du temps car..."
                        </div>
                    </div>
                </div>
            )}
        </div>
    );
}
