/**
 * Script pour exécuter la migration SQL directement via PostgreSQL
 * Usage: node scripts/run-migration-direct.mjs
 */

import pg from 'pg'
import { readFileSync } from 'fs'
import { join, dirname } from 'path'
import { fileURLToPath } from 'url'
import dotenv from 'dotenv'

const { Client } = pg

// Load environment variables
dotenv.config({ path: '.env' })
dotenv.config({ path: '.env.local' })

const __filename = fileURLToPath(import.meta.url)
const __dirname = dirname(__filename)

const databaseUrl = process.env.DIRECT_URL

if (!databaseUrl) {
  console.error('❌ Erreur: DIRECT_URL manquant dans .env')
  process.exit(1)
}

async function runMigration() {
  const client = new Client({
    connectionString: databaseUrl,
  })

  try {
    console.log('🔌 Connexion à PostgreSQL...')
    await client.connect()
    console.log('✅ Connecté !')
    console.log('')

    console.log('📄 Lecture du fichier de migration...')
    const migrationPath = join(__dirname, '..', 'supabase', 'migrations', '20260211_create_public_user_trigger.sql')
    const sql = readFileSync(migrationPath, 'utf-8')
    console.log('✅ Fichier lu')
    console.log('')

    console.log('🚀 Exécution de la migration SQL...')
    console.log('')

    // Execute the SQL
    await client.query(sql)

    console.log('✅ Migration exécutée avec succès !')
    console.log('')

    // Verify users were synced
    console.log('🔍 Vérification des utilisateurs synchronisés...')
    const result = await client.query('SELECT id, email, created_at FROM public.users ORDER BY created_at DESC LIMIT 10')

    if (result.rows.length > 0) {
      console.log(`✅ ${result.rows.length} utilisateur(s) trouvé(s) dans public.users :`)
      console.log('')
      result.rows.forEach(u => {
        console.log(`  📧 ${u.email}`)
        console.log(`     ID: ${u.id}`)
        console.log(`     Créé: ${u.created_at}`)
        console.log('')
      })
    } else {
      console.log('⚠️  Aucun utilisateur trouvé dans public.users')
    }

    console.log('✅ Migration terminée avec succès !')
    console.log('')
    console.log('🧪 Testez maintenant :')
    console.log('   1. Aller sur http://localhost:3001/capture')
    console.log('   2. Saisir une nouvelle idée')
    console.log('   3. Cliquer "Analyser"')
    console.log('   4. ✅ Le projet devrait apparaître dans /workspace')
    console.log('')

  } catch (error) {
    console.error('❌ Erreur lors de l\'exécution de la migration:')
    console.error(error.message)
    if (error.stack) {
      console.error('')
      console.error('Stack trace:')
      console.error(error.stack)
    }
    process.exit(1)
  } finally {
    await client.end()
  }
}

runMigration()
