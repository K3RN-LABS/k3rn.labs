"use client";

import { useState, useEffect } from "react";
import type { AnalysisOutput } from "@/lib/analysis/types";

export interface StoredProject {
    id: string;
    title: string;
    text: string;
    description: string;
    globalScore: number;
    recommendation: "GO" | "EXPLORE" | "PARK" | "KILL";
    confidenceLevel: "LOW" | "MEDIUM" | "HIGH";
    analysis: {
        axes: Array<{ label: string; score: number; justification?: string }>;
        synthesis: string;
        risks: string[];
    };
    timestamp: string;
    isDemo: boolean;
    fullResult?: AnalysisOutput;
}

export function useProject(id: string | undefined) {
    const [project, setProject] = useState<StoredProject | null>(null);
    const [isLoading, setIsLoading] = useState(true);
    const [error, setError] = useState<string | null>(null);

    useEffect(() => {
        if (!id) {
            setIsLoading(false);
            return;
        }

        async function fetchProject() {
            try {
                setIsLoading(true);
                const response = await fetch(`/api/projects/${id}`);

                if (!response.ok) {
                    // Try localStorage fallback for demo/legacy projects
                    const localProject = tryLocalStorageFallback(id);
                    if (localProject) {
                        setProject(localProject);
                        setIsLoading(false);
                        return;
                    }

                    throw new Error('Failed to fetch project');
                }

                const data = await response.json();
                const apiProject = data.data;

                // Convert API project to StoredProject format
                setProject(apiProjectToStoredProject(apiProject));
                setError(null);
            } catch (err) {
                console.error('Error fetching project:', err);
                setError(err instanceof Error ? err.message : 'Failed to load project');

                // Final fallback to localStorage
                const localProject = tryLocalStorageFallback(id);
                if (localProject) {
                    setProject(localProject);
                } else {
                    setProject(null);
                }
            } finally {
                setIsLoading(false);
            }
        }

        fetchProject();
    }, [id]);

    return { project, isLoading, error };
}

// Convert API project to StoredProject format
function apiProjectToStoredProject(apiProject: any): StoredProject {
    const analysisData = apiProject.analysis_data as AnalysisOutput | undefined;

    return {
        id: apiProject.id,
        title: apiProject.name || "Untitled",
        text: analysisData?.idea?.raw_summary || apiProject.description || "",
        description: apiProject.description || "",
        globalScore: apiProject.score || 0,
        recommendation: analysisData?.decision?.recommendation || "EXPLORE",
        confidenceLevel: analysisData?.decision?.confidence_level || "MEDIUM",
        analysis: {
            axes: analysisData ? extractAxes(analysisData) : [],
            synthesis: analysisData?.decision?.reasoning || "",
            risks: analysisData?.risks?.map(r => r.description) || [],
        },
        timestamp: apiProject.created_at || new Date().toISOString(),
        isDemo: false,
        fullResult: analysisData,
    };
}

// Extract axes from AnalysisOutput
function extractAxes(analysisOutput: AnalysisOutput) {
    const { analysis } = analysisOutput;
    return [
        { label: "Problem", score: analysis.problem.score, justification: analysis.problem.justification },
        { label: "Market", score: analysis.market.score, justification: analysis.market.justification },
        { label: "Differentiation", score: analysis.differentiation.score, justification: analysis.differentiation.justification },
        { label: "Feasibility", score: analysis.feasibility.score, justification: analysis.feasibility.justification },
        { label: "Business", score: analysis.business.score, justification: analysis.business.justification },
        { label: "Founder Fit", score: analysis.founder_fit.score, justification: analysis.founder_fit.justification },
    ];
}

// Fallback to localStorage for demo/legacy projects
function tryLocalStorageFallback(id: string): StoredProject | null {
    // Try k3rn_projects first
    const projectsRaw = localStorage.getItem("k3rn_projects");
    if (projectsRaw) {
        try {
            const projects: any[] = JSON.parse(projectsRaw);
            const found = projects.find((p) => p.id === id);
            if (found) {
                return normalizeProject(found);
            }
        } catch { /* ignore parse errors */ }
    }

    // Fallback: k3rn_active_project
    const activeRaw = localStorage.getItem("k3rn_active_project");
    if (activeRaw) {
        try {
            const active = JSON.parse(activeRaw);
            if (active.id === id) {
                return normalizeProject(active);
            }
        } catch { /* ignore parse errors */ }
    }

    return null;
}

function normalizeProject(raw: any): StoredProject {
    return {
        id: raw.id || "",
        title: raw.title || raw.text || "Untitled",
        text: raw.text || "",
        description: raw.description || raw.text || "",
        globalScore: raw.globalScore ?? raw.viabilityScore ?? 0,
        recommendation: raw.recommendation ?? raw.classification ?? "EXPLORE",
        confidenceLevel: raw.confidenceLevel ?? "MEDIUM",
        analysis: {
            axes: raw.analysis?.axes ?? [],
            synthesis: raw.analysis?.synthesis ?? "",
            risks: raw.analysis?.risks ?? [],
        },
        timestamp: raw.timestamp || new Date().toISOString(),
        isDemo: raw.isDemo ?? false,
        fullResult: raw.fullResult ?? undefined,
    };
}
