"use client";

import { useState, useEffect } from "react";
import { AlertOctagon, Plus, X, Check } from "lucide-react";
import { cn } from "@/lib/utils";
import { Button } from "@/components/ui/button";

interface ConstraintCanvasProps {
    projectId: string;
}

interface ConstraintCard {
    id: string;
    type: "TECHNICAL" | "BUSINESS" | "REGULATORY" | "RESOURCE" | "TIME";
    description: string;
    impact: "BLOCKING" | "MAJOR" | "MINOR";
    mitigationIdeas: string;
    validated: boolean;
}

const CONSTRAINT_TYPES = [
    { value: "TECHNICAL", label: "Technique", color: "blue" },
    { value: "BUSINESS", label: "Business", color: "purple" },
    { value: "REGULATORY", label: "Réglemen.", color: "red" },
    { value: "RESOURCE", label: "Ressources", color: "amber" },
    { value: "TIME", label: "Temps", color: "gray" }
] as const;

const IMPACT_LEVELS = [
    { value: "BLOCKING", label: "Bloquant", color: "red" },
    { value: "MAJOR", label: "Majeur", color: "amber" },
    { value: "MINOR", label: "Mineur", color: "gray" }
] as const;

export function ConstraintCanvas({ projectId }: ConstraintCanvasProps) {
    const [constraints, setConstraints] = useState<ConstraintCard[]>([]);
    const [isLoading, setIsLoading] = useState(true);
    const [showAddForm, setShowAddForm] = useState(false);
    const [newConstraint, setNewConstraint] = useState<Partial<ConstraintCard>>({
        type: "TECHNICAL",
        description: "",
        impact: "MAJOR",
        mitigationIdeas: ""
    });

    useEffect(() => {
        loadConstraints();
    }, [projectId]);

    async function loadConstraints() {
        try {
            setIsLoading(true);
            const response = await fetch(`/api/projects/${projectId}/cards?type=CONSTRAINT&phase=IDEATION`);
            if (response.ok) {
                const data = await response.json();
                const cards = data.data || [];
                setConstraints(cards.map((card: any) => ({
                    id: card.id,
                    type: card.metadata?.constraintType || "TECHNICAL",
                    description: card.label || "",
                    impact: card.metadata?.impact || "MAJOR",
                    mitigationIdeas: card.metadata?.mitigationIdeas || "",
                    validated: card.validated || false
                })));
            }
        } catch (error) {
            console.error("Failed to load constraints:", error);
        } finally {
            setIsLoading(false);
        }
    }

    async function addConstraint() {
        if (!newConstraint.description?.trim()) return;

        try {
            const response = await fetch(`/api/projects/${projectId}/cards`, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    type: "CONSTRAINT",
                    label: newConstraint.description.trim(),
                    phase: "IDEATION",
                    status: "DRAFT",
                    priority: newConstraint.impact,
                    metadata: {
                        constraintType: newConstraint.type,
                        impact: newConstraint.impact,
                        mitigationIdeas: newConstraint.mitigationIdeas
                    }
                })
            });

            if (response.ok) {
                await loadConstraints();
                setNewConstraint({ type: "TECHNICAL", description: "", impact: "MAJOR", mitigationIdeas: "" });
                setShowAddForm(false);
            }
        } catch (error) {
            console.error("Failed to add constraint:", error);
        }
    }

    async function toggleValidation(id: string) {
        const constraint = constraints.find(c => c.id === id);
        if (!constraint) return;

        try {
            await fetch(`/api/cards/${id}`, {
                method: "PATCH",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ validated: !constraint.validated })
            });

            setConstraints(constraints.map(c => c.id === id ? { ...c, validated: !c.validated } : c));
        } catch (error) {
            console.error("Failed to toggle validation:", error);
        }
    }

    async function deleteConstraint(id: string) {
        try {
            await fetch(`/api/cards/${id}`, { method: "DELETE" });
            setConstraints(constraints.filter(c => c.id !== id));
        } catch (error) {
            console.error("Failed to delete constraint:", error);
        }
    }

    function getTypeColor(type: string) {
        return CONSTRAINT_TYPES.find(t => t.value === type)?.color || "gray";
    }

    function getImpactColor(impact: string) {
        return IMPACT_LEVELS.find(i => i.value === impact)?.color || "gray";
    }

    if (isLoading) {
        return (
            <div className="flex items-center justify-center py-12">
                <div className="text-gray-500 text-sm">Chargement...</div>
            </div>
        );
    }

    return (
        <div className="space-y-4">
            {/* Header */}
            <div className="flex items-center justify-between">
                <div>
                    <h2 className="text-xs text-gray-500 uppercase tracking-widest font-bold mb-1 flex items-center gap-2">
                        <AlertOctagon className="w-3.5 h-3.5 text-red-400" />
                        Contraintes
                    </h2>
                    <p className="text-[11px] text-gray-400">
                        Listez les contraintes majeures (techniques, business, réglementaires...)
                    </p>
                </div>
                <Button
                    onClick={() => setShowAddForm(!showAddForm)}
                    variant="ghost"
                    size="sm"
                    className="text-[#F75105] hover:text-[#F78E21] hover:bg-[#F75105]/10 text-xs"
                >
                    <Plus className="w-3.5 h-3.5 mr-1" />
                    Ajouter
                </Button>
            </div>

            {/* Add Form */}
            {showAddForm && (
                <div className="p-4 rounded-xl bg-[#2F323A] border border-[#F75105]/30 space-y-3">
                    <div className="grid grid-cols-2 gap-3">
                        <div>
                            <label className="text-[10px] text-gray-500 uppercase tracking-widest font-bold block mb-2">
                                Type de contrainte
                            </label>
                            <select
                                value={newConstraint.type}
                                onChange={(e) => setNewConstraint({ ...newConstraint, type: e.target.value as any })}
                                className="w-full px-3 py-2 bg-[#22242B] border border-white/10 rounded-lg text-sm text-white focus:outline-none focus:border-[#F75105]/50"
                            >
                                {CONSTRAINT_TYPES.map(type => (
                                    <option key={type.value} value={type.value}>{type.label}</option>
                                ))}
                            </select>
                        </div>

                        <div>
                            <label className="text-[10px] text-gray-500 uppercase tracking-widest font-bold block mb-2">
                                Impact
                            </label>
                            <select
                                value={newConstraint.impact}
                                onChange={(e) => setNewConstraint({ ...newConstraint, impact: e.target.value as any })}
                                className="w-full px-3 py-2 bg-[#22242B] border border-white/10 rounded-lg text-sm text-white focus:outline-none focus:border-[#F75105]/50"
                            >
                                {IMPACT_LEVELS.map(impact => (
                                    <option key={impact.value} value={impact.value}>{impact.label}</option>
                                ))}
                            </select>
                        </div>
                    </div>

                    <div>
                        <label className="text-[10px] text-gray-500 uppercase tracking-widest font-bold block mb-2">
                            Description de la contrainte
                        </label>
                        <textarea
                            value={newConstraint.description}
                            onChange={(e) => setNewConstraint({ ...newConstraint, description: e.target.value })}
                            placeholder="Ex: L'API tierce nécessite une certification qui prend 6 mois..."
                            className="w-full min-h-[60px] px-3 py-2 bg-[#22242B] border border-white/10 rounded-lg text-sm text-white placeholder:text-gray-500 focus:outline-none focus:border-[#F75105]/50 resize-none"
                            autoFocus
                        />
                    </div>

                    <div>
                        <label className="text-[10px] text-gray-500 uppercase tracking-widest font-bold block mb-2">
                            Idées de mitigation (optionnel)
                        </label>
                        <input
                            type="text"
                            value={newConstraint.mitigationIdeas}
                            onChange={(e) => setNewConstraint({ ...newConstraint, mitigationIdeas: e.target.value })}
                            placeholder="Comment contourner ou réduire l'impact ?"
                            className="w-full px-3 py-2 bg-[#22242B] border border-white/10 rounded-lg text-sm text-white placeholder:text-gray-500 focus:outline-none focus:border-[#F75105]/50"
                        />
                    </div>

                    <div className="flex gap-2">
                        <Button
                            onClick={addConstraint}
                            disabled={!newConstraint.description?.trim()}
                            className="bg-[#F75105] hover:bg-[#F78E21] text-white"
                        >
                            Ajouter
                        </Button>
                        <Button
                            onClick={() => {
                                setShowAddForm(false);
                                setNewConstraint({ type: "TECHNICAL", description: "", impact: "MAJOR", mitigationIdeas: "" });
                            }}
                            variant="ghost"
                            className="text-gray-400"
                        >
                            Annuler
                        </Button>
                    </div>
                </div>
            )}

            {/* Constraint List */}
            {constraints.length === 0 && !showAddForm ? (
                <div className="text-center py-8 text-gray-500 text-sm">
                    Aucune contrainte listée. Identifiez les limites techniques, business ou réglementaires.
                </div>
            ) : (
                <div className="space-y-3">
                    {constraints.map((constraint) => (
                        <div
                            key={constraint.id}
                            className={cn(
                                "p-4 rounded-xl border transition-all",
                                constraint.validated
                                    ? "bg-emerald-500/5 border-emerald-500/20"
                                    : "bg-[#2F323A] border-white/5"
                            )}
                        >
                            <div className="flex items-start gap-3">
                                {/* Validation Checkbox */}
                                <button
                                    onClick={() => toggleValidation(constraint.id)}
                                    className={cn(
                                        "mt-0.5 w-5 h-5 rounded border flex items-center justify-center shrink-0 transition-colors",
                                        constraint.validated
                                            ? "bg-emerald-500 border-emerald-500 text-white"
                                            : "border-gray-500 hover:border-[#F75105]"
                                    )}
                                >
                                    {constraint.validated && <Check className="w-3 h-3" />}
                                </button>

                                {/* Content */}
                                <div className="flex-1 min-w-0">
                                    <div className="flex items-center gap-2 mb-2">
                                        <span className={cn(
                                            "text-[9px] font-bold uppercase tracking-wider px-2 py-0.5 rounded",
                                            `bg-${getTypeColor(constraint.type)}-500/10 text-${getTypeColor(constraint.type)}-400`
                                        )}>
                                            {CONSTRAINT_TYPES.find(t => t.value === constraint.type)?.label}
                                        </span>
                                        <span className={cn(
                                            "text-[9px] font-bold uppercase tracking-wider px-2 py-0.5 rounded",
                                            `bg-${getImpactColor(constraint.impact)}-500/10 text-${getImpactColor(constraint.impact)}-400`
                                        )}>
                                            {IMPACT_LEVELS.find(i => i.value === constraint.impact)?.label}
                                        </span>
                                    </div>

                                    <div className="text-sm text-white mb-2">{constraint.description}</div>

                                    {constraint.mitigationIdeas && (
                                        <div className="text-xs text-gray-400 flex items-start gap-1">
                                            <span className="text-emerald-400 shrink-0">→</span>
                                            <span>{constraint.mitigationIdeas}</span>
                                        </div>
                                    )}
                                </div>

                                {/* Delete Button */}
                                <button
                                    onClick={() => deleteConstraint(constraint.id)}
                                    className="p-1 rounded text-gray-600 hover:text-gray-400 hover:bg-white/5 transition-colors shrink-0"
                                >
                                    <X className="w-3.5 h-3.5" />
                                </button>
                            </div>
                        </div>
                    ))}
                </div>
            )}
        </div>
    );
}
