# Docker Compose for kern.labs backend dependencies
# Phase 2 - Local development environment

version: '3.8'

services:
  postgres:
    image: postgres:16-alpine
    container_name: kernlabs-postgres
    environment:
      POSTGRES_USER: kernlabs
      POSTGRES_PASSWORD: kernlabs
      POSTGRES_DB: kernlabs
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U kernlabs"]
      interval: 5s
      timeout: 5s
      retries: 5

  redis:
    image: redis:7-alpine
    container_name: kernlabs-redis
    ports:
      - "6379:6379"
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 5s
      timeout: 5s
      retries: 5

  minio:
    image: minio/minio:latest
    container_name: kernlabs-minio
    environment:
      MINIO_ROOT_USER: minioadmin
      MINIO_ROOT_PASSWORD: minioadmin
    ports:
      - "9000:9000"
      - "9001:9001"
    volumes:
      - minio_data:/data
    command: server /data --console-address ":9001"
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:9000/minio/health/live"]
      interval: 10s
      timeout: 5s
      retries: 5

  # MinIO bucket creation (run once)
  minio-init:
    image: minio/mc:latest
    container_name: kernlabs-minio-init
    depends_on:
      minio:
        condition: service_healthy
    entrypoint: >
      /bin/sh -c "
      mc alias set kernlabs http://minio:9000 minioadmin minioadmin;
      mc mb kernlabs/kernlabs-artifacts --ignore-existing;
      mc anonymous set public kernlabs/kernlabs-artifacts;
      exit 0;
      "

volumes:
  postgres_data:
  minio_data:
