  } catch {
    return { message: "Intéressant ! Parlez-moi du problème principal que vous souhaitez résoudre." }
  }
}

function getPoleDescription(poleCode: string): string {
  const descriptions: Record<string, string> = {
    P01_STRATEGIE: "Stratège & Innovation",
    P02_MARKET: "Market & Intelligence",
    P03_PRODUIT_TECH: "Produit & Tech",
    P04_FINANCE: "Finance & Modélisation",
    P05_MARKETING: "Marketing & Brand",
    P06_LEGAL: "Legal & Compliance",
    P07_TALENT_OPS: "Talent & Ops",
  }
  return descriptions[poleCode] ?? poleCode
}

export interface FileContext {
  name: string
  kind: "text" | "image"
  content?: string
  dataUrl?: string
}

export async function invokeChefDeProjet(
  dossierName: string,
  history: ChatMessage[],
  userInput: string,
  files?: FileContext[]
): Promise<KAELResponse> {
  const isFirstMessage = history.length === 0
  const hasFiles = files && files.length > 0
  const textFiles = files?.filter((f) => f.kind === "text" && f.content) ?? []
  const imageFiles = files?.filter((f) => f.kind === "image" && f.dataUrl) ?? []

  // Truncate each file to 8000 chars max to keep context reasonable
  const fileBlock = textFiles.length > 0
    ? "\n\n--- FICHIERS FOURNIS ---\n" +
      textFiles.map((f) => {
        const content = (f.content ?? "").slice(0, 8000)
        const truncated = (f.content ?? "").length > 8000 ? "\n[… tronqué]" : ""
        return `### ${f.name}\n${content}${truncated}`
      }).join("\n\n---\n\n") +
      "\n--- FIN FICHIERS ---"
    : ""

  const system = `Tu es KAEL, orchestrateur cognitif de k3rn.labs — tu initialises le projet "${dossierName}".

STATE MACHINE D'ONBOARDING — PROGRESSION STRICTE :
Tu dois collecter exactement ces 4 aspects, dans cet ordre :
1. "problem"     → Quel problème CONCRET ce projet résout-il ? (1 phrase métier, pas technique)
2. "target"      → Qui est l'utilisateur / client final ciblé ?
3. "outcome"     → Quel résultat mesurable est visé ? (métrique ou état final observable)
4. "constraint"  → Quelle est la principale contrainte ou difficulté anticipée ?

RÈGLES DE PROGRESSION :
- Pose UNE SEULE question à la fois, sur le prochain aspect non encore confirmé
- Ne passe à l'aspect suivant que quand la réponse est claire et exploitable
- N'évoque JAMAIS de solutions, technologies ou mécanismes avant que les 4 aspects soient confirmés
- isComplete: true UNIQUEMENT si les 4 aspects sont dans confirmedAspects
- recommendedLab : uniquement parmi [DISCOVERY, STRUCTURATION, VALIDATION_MARCHE, DESIGN_PRODUIT, ARCHITECTURE_TECHNIQUE, BUSINESS_FINANCE] — toujours DISCOVERY par défaut${fileBlock}
${isFirstMessage && !hasFiles ? "\nC'est le PREMIER message — commence par analyser le nom du projet, puis pose la question sur le PROBLÈME (aspect 1)." : ""}
${hasFiles ? "\nDes fichiers ont été fournis — analyse-les, extrais ce qui est déjà répondu, pose la prochaine question manquante." : ""}

RÈGLES POUR LE MESSAGE :
- Réponds TOUJOURS en français, max 2 phrases
- Si fichier/brief fourni : 1 phrase de synthèse + 1 question sur l'aspect manquant
- Ne jamais dire "Je suis une IA" ou ajouter des disclaimers

RÈGLES CRITIQUES POUR LES CHOICES :
- Les choices = RÉPONSES COURTES que l'utilisateur sélectionne en 1 clic — PAS des questions
- Format : affirmation courte, 4-10 mots max (ex: "PME françaises du secteur BTP", "Réduire de 30% le temps de traitement")
- JAMAIS de "?" dans un choice
- Les choices doivent couvrir les cas les plus fréquents pour la question posée

Réponds en JSON :
{
  "message": "2 phrases max — synthèse si besoin + 1 question sur le prochain aspect",
  "choices": ["Réponse courte 1", "Réponse courte 2", "Réponse courte 3"],
  "confirmedAspects": ["problem"],
  "recommendedLab": "DISCOVERY",
  "isComplete": false
}
choices OBLIGATOIRE (2-4). confirmedAspects = liste des aspects confirmés jusqu'ici.`

  // Build messages — images go into content array for vision
  const userContent: OpenAI.Chat.ChatCompletionContentPart[] = [
    { type: "text", text: userInput || (hasFiles ? "Voici les fichiers du projet." : "") },
    ...imageFiles.map((f): OpenAI.Chat.ChatCompletionContentPart => ({
      type: "image_url",
      image_url: { url: f.dataUrl!, detail: "high" },
    })),
  ]

  const messages: OpenAI.Chat.ChatCompletionMessageParam[] = [
    { role: "system", content: system },
    ...history.map((m) => ({
      role: (m.role === "expert" ? "assistant" : "user") as "user" | "assistant",
      content: m.content,
    })),
    { role: "user", content: userContent },
  ]

  const response = await getOpenAI().chat.completions.create(
    {
      model: "gpt-4o",
      max_tokens: 1024,
      response_format: { type: "json_object" },
      messages,
    },
    { timeout: 28000 } // 28s server-side timeout (before 30s client timeout)
  )

  const text = response.choices[0]?.message?.content ?? ""
  try {
    const parsed = JSON.parse(text) as KAELResponse

    if (!parsed.message || typeof parsed.message !== "string") {
      return {
        message: "J'ai analysé votre fichier. Quel problème concret ce projet cherche-t-il à résoudre ?",
        choices: parsed.choices ?? ["Résoudre un problème métier précis", "Saisir une opportunité de marché", "Améliorer un processus existant"],
        confirmedAspects: [],
      }
    }

    // Guard: recommendedLab must be a valid LAB name
    if (parsed.recommendedLab && !VALID_LABS.includes(parsed.recommendedLab as any)) {
      parsed.recommendedLab = "DISCOVERY"
    }

    // Guard: isComplete requires all 4 aspects confirmed
    const aspects = parsed.confirmedAspects ?? []
    const allConfirmed = (["problem", "target", "outcome", "constraint"] as ConfirmedAspect[])
      .every((a) => aspects.includes(a))
    if (parsed.isComplete && !allConfirmed) {
      parsed.isComplete = false
    }

    return parsed
  } catch {
    return {
      message: "Intéressant ! Quel problème concret ce projet cherche-t-il à résoudre ?",
      choices: ["Résoudre un problème métier précis", "Saisir une opportunité de marché", "Améliorer un processus existant"],
      confirmedAspects: [],
    }
  }
}
