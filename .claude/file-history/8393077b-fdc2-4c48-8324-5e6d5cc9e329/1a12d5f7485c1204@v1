import { NextRequest } from "next/server"
import { verifySession } from "@/lib/auth"
import { db as prisma } from "@/lib/db"
import { validateBody, apiError, apiSuccess } from "@/lib/validate"
import { invokeChefDeProjet } from "@/lib/claude"
import type { ChatMessage } from "@/lib/claude"
import { randomUUID } from "crypto"
import { z } from "zod"

const schema = z.object({
  message: z.string().min(1).max(4000),
  attachments: z
    .array(z.object({ name: z.string(), type: z.string(), size: z.number().optional() }))
    .optional(),
})

export async function GET(_req: NextRequest, { params }: { params: Promise<{ id: string }> }) {
  const session = await verifySession()
  if (!session) return apiError("Unauthorized", 401)

  const { id } = await params
  const dossier = await prisma.dossier.findFirst({
    where: { id, ownerId: session.userId },
  })
  if (!dossier) return apiError("Dossier not found", 404)

  const history = ((dossier as any).onboardingMessages ?? []) as ChatMessage[]
  return apiSuccess({ messages: history, dossier })
}

export async function POST(req: NextRequest, { params }: { params: Promise<{ id: string }> }) {
  const session = await verifySession()
  if (!session) return apiError("Unauthorized", 401)

  const { id } = await params
  const result = await validateBody(schema, req)
  if ("error" in result) return result.error

  const dossier = await prisma.dossier.findFirst({
    where: { id, ownerId: session.userId },
  })
  if (!dossier) return apiError("Dossier not found", 404)

  const history = ((dossier as any).onboardingMessages ?? []) as ChatMessage[]

  const userMsg: ChatMessage = {
    id: randomUUID(),
    role: "user",
    content: result.data.message,
    timestamp: new Date().toISOString(),
    attachments: result.data.attachments,
  }

  const aiResponse = await invokeChefDeProjet(dossier.name, history, result.data.message)

  const expertMsg: ChatMessage = {
    id: randomUUID(),
    role: "expert",
    content: aiResponse.message,
    timestamp: new Date().toISOString(),
    choices: aiResponse.choices,
  }

  const updatedMessages = [...history, userMsg, expertMsg]

  await prisma.dossier.update({
    where: { id },
    data: { onboardingMessages: updatedMessages as any } as any,
  })

  return apiSuccess({
    messages: updatedMessages,
    response: aiResponse,
    recommendedLab: aiResponse.recommendedLab,
    isComplete: aiResponse.isComplete,
  })
}
